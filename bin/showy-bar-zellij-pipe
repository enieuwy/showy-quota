#!/usr/bin/env bash
# showy-bar — long-running zjstatus pipe loop.
#
# Pipes the rendered ANSI strip into zjstatus on a fixed cadence. We use
# the pipe widget instead of zjstatus's command widget because the command
# widget crashes under WASMI with std::sync::Mutex initialization errors
# (single-threaded WASM).

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"

BAR="${SCRIPT_DIR}/showy-bar-zellij-bar"
[[ -x "${BAR}" ]] || showy_bar_die "missing renderer: ${BAR}"

showy_bar_have "${SHOWY_BAR_ZELLIJ_BIN}" || showy_bar_die "zellij is required for pipe mode: ${SHOWY_BAR_ZELLIJ_BIN}"

interval="${SHOWY_BAR_ZELLIJ_PIPE_INTERVAL}"
widget="${SHOWY_BAR_ZELLIJ_WIDGET}"
pipe_name="${SHOWY_BAR_ZELLIJ_PIPE_NAME}"

# zjstatus consumes the protocol from the payload itself:
#   zjstatus::pipe::<widget>::<output>
# `--name` only routes the message to plugins listening on that name;
# zjstatus listens on any name, so we just use a stable id for clarity.
while :; do
    if output=$("${BAR}" 2>/dev/null) && [[ -n "${output}" ]]; then
        "${SHOWY_BAR_ZELLIJ_BIN}" pipe --name "${pipe_name}" -- \
            "zjstatus::pipe::${widget}::${output}" >/dev/null 2>&1 || true
    fi
    sleep "${interval}"
done
