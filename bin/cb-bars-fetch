#!/usr/bin/env bash
# codexbar-bars — shared CodexBar JSON fetcher.
#
# Returns the cached `codexbar usage --format json --provider all` output.
# Refreshes the cache when older than CB_BARS_REFRESH_SECONDS, atomically.
# Always prints the most recent good cache when codexbar fails.
#
# Exit 0 whenever any cache content was emitted (fresh or stale).
# Exit 1 only when no cache exists and the first fetch fails.
#
# Flags:
#   --refresh   Force a refresh regardless of cache age.
#   --json      Default. Print the cached JSON.
#   --age       Print cache age in seconds and exit.
#   --path      Print the cache file path and exit.
#
# This script is intentionally narrow: every renderer (zellij, tmux,
# sketchybar) reads from the same cache file so we never fan out N parallel
# `codexbar` invocations.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"

mode="json"
force_refresh=0
while (($#)); do
    case "$1" in
        --refresh) force_refresh=1 ;;
        --json)    mode="json" ;;
        --age)     mode="age" ;;
        --path)    mode="path" ;;
        -h|--help)
            sed -n '2,18p' "$0"
            exit 0
            ;;
        *) cb_bars_die "unknown argument: $1" ;;
    esac
    shift
done

mkdir -p "${CB_BARS_CACHE_DIR}"

if [[ "${mode}" == "path" ]]; then
    printf '%s\n' "${CB_BARS_USAGE_FILE}"
    exit 0
fi

if [[ "${mode}" == "age" ]]; then
    cb_bars_age_seconds "${CB_BARS_USAGE_FILE}"
    exit 0
fi

# ── locking primitives ────────────────────────────────────────────────

# Use flock when available (Linux, Homebrew util-linux); else fall back to
# `mkdir` lock with a 60s lease.
#
# Returns:
#   0 = lock was held and the callee ran;
#   2 = lock was held by another worker; caller should wait for cache.
cb_bars_with_lock() {
    if [[ -z "${CB_BARS_FORCE_NO_FLOCK:-}" ]] && cb_bars_have flock; then
        local rc=2
        # subshell + fd 9 so the lock releases on exit.
        (
            exec 9>"${CB_BARS_USAGE_LOCK}"
            if flock -n 9; then
                "$@"
            else
                cb_bars_log "another fetch in flight (flock); will wait"
                exit 2
            fi
        ) && rc=$? || rc=$?
        return "${rc}"
    fi

    local lock_dir="${CB_BARS_USAGE_LOCK}.d"
    if mkdir "${lock_dir}" 2>/dev/null; then
        trap 'rmdir "'"${lock_dir}"'" 2>/dev/null || true' EXIT
        local rc=0
        "$@" || rc=$?
        rmdir "${lock_dir}" 2>/dev/null || true
        trap - EXIT
        return "${rc}"
    fi

    # Stale lock recovery (older than 60s). Only the winner of `rmdir`
    # proceeds; loser treats the lock as still held and waits.
    local mtime now
    now=$(date +%s)
    if mtime=$(stat -f %m "${lock_dir}" 2>/dev/null) \
        || mtime=$(stat -c %Y "${lock_dir}" 2>/dev/null); then
        if (( now - mtime > 60 )); then
            if rmdir "${lock_dir}" 2>/dev/null; then
                # We removed the stale lock; immediately try to claim it.
                if mkdir "${lock_dir}" 2>/dev/null; then
                    trap 'rmdir "'"${lock_dir}"'" 2>/dev/null || true' EXIT
                    local rc=0
                    "$@" || rc=$?
                    rmdir "${lock_dir}" 2>/dev/null || true
                    trap - EXIT
                    return "${rc}"
                fi
            fi
        fi
    fi
    cb_bars_log "another fetch in flight (mkdir); will wait"
    return 2
}

# Block up to N tenths of a second for the cache file to appear or refresh.
# Used by callers that lost the lock; protects against the cold-start case
# where there is no cache yet.
cb_bars_wait_for_cache() {
    local max_tenths="${1:-50}"   # 5.0 s
    local i
    for (( i=0; i<max_tenths; i++ )); do
        if [[ -s "${CB_BARS_USAGE_FILE}" ]] && cb_bars_json_valid "${CB_BARS_USAGE_FILE}"; then
            return 0
        fi
        sleep 0.1
    done
    return 1
}

# ── core refresh ──────────────────────────────────────────────────────

run_codexbar() {
    local args=(usage --format json --pretty)
    if [[ "${CB_BARS_INCLUDE_STATUS}" == "1" ]]; then
        args+=(--status)
    fi
    "${CB_BARS_CODEXBAR_BIN}" "${args[@]}" 2>/dev/null
}

refresh_cache() {
    local out tmp rc
    tmp=$(mktemp "${CB_BARS_CACHE_DIR}/usage.XXXXXX.json")

    if ! command -v "${CB_BARS_CODEXBAR_BIN}" >/dev/null 2>&1; then
        rm -f "${tmp}"
        cb_bars_log "codexbar binary not found: ${CB_BARS_CODEXBAR_BIN}"
        return 1
    fi

    rc=0
    out=$(run_codexbar) || rc=$?

    # Validate first byte without piping (pipefail-safe).
    if [[ -z "${out}" || "${out:0:1}" != '[' ]]; then
        rm -f "${tmp}"
        cb_bars_log "codexbar produced no usable output (rc=${rc})"
        return 1
    fi

    printf '%s' "${out}" > "${tmp}"
    if cb_bars_json_valid "${tmp}"; then
        mv "${tmp}" "${CB_BARS_USAGE_FILE}"
        date +%s > "${CB_BARS_USAGE_STAMP}"
        chmod 644 "${CB_BARS_USAGE_FILE}" "${CB_BARS_USAGE_STAMP}"
        cb_bars_log "cache refreshed (${#out} bytes)"
        return 0
    fi

    rm -f "${tmp}"
    cb_bars_log "codexbar JSON failed validation"
    return 1
}

cache_is_fresh() {
    [[ -s "${CB_BARS_USAGE_FILE}" ]] || return 1
    local age
    age=$(cb_bars_age_seconds "${CB_BARS_USAGE_FILE}")
    (( age < CB_BARS_REFRESH_SECONDS ))
}

lock_rc=0
if (( force_refresh )) || ! cache_is_fresh; then
    cb_bars_with_lock refresh_cache || lock_rc=$?
fi

# Lost the lock contest? Briefly wait for the holder's refresh, but only
# when our own cache is empty/invalid — if we already have a usable cache
# we serve it immediately.
if (( lock_rc == 2 )) && ! [[ -s "${CB_BARS_USAGE_FILE}" ]]; then
    cb_bars_wait_for_cache 100 || true   # up to 10 s
fi

# Always emit whatever we have. Bars must never see an empty payload
# while the cache file exists.
if [[ -s "${CB_BARS_USAGE_FILE}" ]]; then
    cat "${CB_BARS_USAGE_FILE}"
    exit 0
fi

cb_bars_die "no codexbar JSON available and no cache present"
