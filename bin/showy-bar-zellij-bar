#!/usr/bin/env bash
# showy-bar — Zellij/zjstatus ANSI strip renderer.
#
# Reads cached codexbar JSON via showy-bar-fetch and prints a compact ANSI strip
# to stdout. Pass `--json <path|->` to render supplied JSON without fetching,
# which is useful for deterministic previews and tests.
#
# Format per provider:   CL▕<5h/7d half-blocks>▏<countdown>
# Multiple providers are space-separated with no trailing newline.
#
# Output is colorless when NO_COLOR is set or stdout is not a TTY *and*
# SHOWY_BAR_FORCE_COLOR is unset (default: emit color so zjstatus pipe
# rendermode=raw shows the colors).

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/strip.sh"

showy_bar_have jq || showy_bar_die "jq is required"

FETCH="${SHOWY_BAR_FETCH_BIN:-${SCRIPT_DIR}/showy-bar-fetch}"

json_input=""
while (($#)); do
    case "$1" in
        --json)
            shift
            [[ $# -gt 0 ]] || showy_bar_die "--json requires path or -"
            json_input="$1"
            ;;
        -h|--help)
            printf '%s\n' \
                'Usage: showy-bar-zellij-bar [--json <path|->]' \
                '' \
                'Prints a Zellij/zjstatus ANSI usage strip.'
            exit 0
            ;;
        *) showy_bar_die "unknown argument: $1" ;;
    esac
    shift
done

# ── caps ──────────────────────────────────────────────────────────────────
#
# Powerline-Extra glyphs by default (U+E0B6 / U+E0B4); requires a Nerd
# Font or any font with the Powerline Extra range. Override or blank
# either side to taste; common alternatives are '' / ''
# (slant) or '' / '' (flame). Empty string = no cap on
# that side.
CAP_LEFT="${SHOWY_BAR_CAP_LEFT-}"
CAP_RIGHT="${SHOWY_BAR_CAP_RIGHT-}"
# ── color helpers ────────────────────────────────────────────────────

want_color=1
if [[ -n "${NO_COLOR:-}" || "${TERM:-}" == "dumb" ]]; then want_color=0; fi
if [[ -n "${SHOWY_BAR_FORCE_COLOR:-}" ]]; then want_color=1; fi

# Convert a 6-char hex to ANSI 24-bit foreground/background escape.
fg() {
    (( want_color )) || return 0
    local hex="$1"
    local r=$((16#${hex:0:2})) g=$((16#${hex:2:2})) b=$((16#${hex:4:2}))
    printf '\033[38;2;%d;%d;%dm' "${r}" "${g}" "${b}"
}
bg() {
    (( want_color )) || return 0
    local hex="$1"
    local r=$((16#${hex:0:2})) g=$((16#${hex:2:2})) b=$((16#${hex:4:2}))
    printf '\033[48;2;%d;%d;%dm' "${r}" "${g}" "${b}"
}
reset() { (( want_color )) && printf '\033[0m'; return 0; }
dim()   { (( want_color )) && printf '\033[2m'; return 0; }
bold()  { (( want_color )) && printf '\033[1m'; return 0; }

style_text() {
    local text="$1" fg_hex="${2:-}" bg_hex="${3:-}" weight="${4:-}"
    [[ "${weight}" == "bold" ]] && bold
    [[ -n "${fg_hex}" ]] && fg "${fg_hex}"
    [[ -n "${bg_hex}" ]] && bg "${bg_hex}"
    printf '%s' "${text}"
    reset
}

filled_cells() {
    local remaining="${1:-0}" width="$2"
    [[ "${remaining}" =~ ^-?[0-9]+$ ]] || remaining=0
    (( remaining < 0 )) && remaining=0
    (( remaining > 100 )) && remaining=100
    local filled=$(( (remaining * width) / 100 ))
    (( remaining > 0 && filled == 0 )) && filled=1
    printf '%s\n' "${filled}"
}

elapsed_marker_cell() {
    local reset_at="$1" window_minutes="$2" width="$3"
    [[ -n "${reset_at}" && "${window_minutes}" =~ ^[0-9]+$ ]] || return 1
    (( window_minutes > 0 )) || return 1

    local reset_epoch duration start_epoch now elapsed marker
    reset_epoch=$(showy_bar_reset_epoch "${reset_at}") || return 1
    duration=$((window_minutes * 60))
    start_epoch=$((reset_epoch - duration))
    now=$(showy_bar_now_epoch)
    elapsed=$((now - start_epoch))
    (( elapsed < 0 )) && elapsed=0
    (( elapsed > duration )) && elapsed="${duration}"
    marker=$(( (duration - elapsed) * width / duration ))
    (( marker < 0 )) && marker=0
    (( marker >= width )) && marker=$((width - 1))
    printf '%s\n' "${marker}"
}

dual_metric_bar() {
    local p_remaining="$1" s_remaining="$2" s_reset="$3" s_window="$4"
    local width="${SHOWY_BAR_ZELLIJ_BAR_WIDTH:-12}"
    [[ "${width}" =~ ^[0-9]+$ ]] || width=12
    (( width < 8 )) && width=8

    local primary_color secondary_color bg_color surface_color elapsed_color
    primary_color=$(showy_bar_role_color primary "${p_remaining}")
    secondary_color=$(showy_bar_role_color secondary "${s_remaining}")
    bg_color=$(showy_bar_palette bg)
    surface_color=$(showy_bar_palette surface)
    elapsed_color=$(showy_bar_palette elapsed)

    local p_fill s_fill marker i top_color bottom_color
    p_fill=$(filled_cells "${p_remaining}" "${width}")
    s_fill=$(filled_cells "${s_remaining}" "${width}")
    marker=$(elapsed_marker_cell "${s_reset}" "${s_window}" "${width}" || true)

    for (( i=0; i<width; i++ )); do
        if (( i < p_fill )); then top_color="${primary_color}"
        else top_color="${surface_color}"; fi

        if (( i < s_fill )); then bottom_color="${secondary_color}"
        else bottom_color="${surface_color}"; fi

        if [[ "${marker}" =~ ^[0-9]+$ && "${i}" == "${marker}" ]]; then
            style_text '▀' "${top_color}" "${elapsed_color}"
        else
            style_text '▀' "${top_color}" "${bottom_color}"
        fi
    done
    style_text '▏' "${bg_color}" "${surface_color}"
}

# ── data load ────────────────────────────────────────────────────────

if [[ -n "${json_input}" ]]; then
    if [[ "${json_input}" == "-" ]]; then
        data=$(</dev/stdin)
    else
        [[ -r "${json_input}" ]] || showy_bar_die "cannot read JSON input: ${json_input}"
        data=$(< "${json_input}")
    fi
elif ! data=$("${FETCH}" 2>/dev/null) || [[ -z "${data}" ]]; then
    fg "$(showy_bar_role_palette primary unknown)"; printf 'AI ?'; reset; printf '\n'
    exit 0
fi

if [[ -z "${data}" ]]; then
    fg "$(showy_bar_role_palette primary unknown)"; printf 'AI ?'; reset; printf '\n'
    exit 0
fi

filtered=$(printf '%s' "${data}" | showy_bar_filter_renderable)
count=$(printf '%s' "${filtered}" | jq 'length')

if (( count == 0 )); then
    dim; printf 'AI idle'; reset; printf '\n'
    exit 0
fi

# Stale = cache is older than 2x the refresh interval; render quota state
# as last-known data and mark countdowns unknown rather than dimming chunks.
stale=0
if [[ -z "${json_input}" ]]; then
    age=$(showy_bar_age_seconds "${SHOWY_BAR_USAGE_FILE}")
    (( age > SHOWY_BAR_REFRESH_SECONDS * 2 )) && stale=1
fi

# ── per-provider render ─────────────────────────────────────────────

# Emit one record per provider, fields separated by ASCII unit-separator
# (0x1f) to preserve empty fields that read+IFS=$'\t' would collapse.
# CodexBar may emit usedPercent as int OR float; we floor to a 0..100
# integer so bash arithmetic later cannot trip over decimals.
rows=$(printf '%s' "${filtered}" | jq -r '
    def pct(x): if x == null then -1 else ([0, ([100, (x|tonumber|floor)] | min)] | max) end;
    .[]
    | select((.provider | type == "string" and length > 0) and (.usage.primary.usedPercent | type == "number"))
    | [
        .provider,
        pct(.usage.primary.usedPercent),
        (.usage.primary.resetsAt // .usage.primary.resetDescription // ""),
        (.usage.primary.windowMinutes // ""),
        pct(.usage.secondary.usedPercent),
        (.usage.secondary.resetsAt // .usage.secondary.resetDescription // ""),
        (.usage.secondary.windowMinutes // "")
    ] | map(tostring) | join("\u001f")')

first_chunk=1
while IFS=$'\x1f' read -r provider p_used p_reset _p_window s_used s_reset s_window; do
    [[ -n "${provider}" ]] || continue

    p_remaining=$((100 - p_used))
    s_remaining=0
    if (( s_used >= 0 )); then
        s_remaining=$((100 - s_used))
    fi

    sigil=$(showy_bar_provider_sigil "${provider}")

    minutes=""
    if (( ! stale )) && [[ -n "${p_reset}" ]]; then
        minutes=$(showy_bar_minutes_until "${p_reset}" || true)
    fi
    countdown=$(showy_bar_primary_label "${minutes}" "${p_remaining}" "${p_reset}" "${stale}")

    time_color=$(showy_bar_palette countdown)
    if (( stale )); then
        time_color=$(showy_bar_palette countdown_warn)
    elif [[ -n "${minutes}" && "${minutes}" -lt "${SHOWY_BAR_TIME_WARN_MINUTES}" ]]; then
        time_color=$(showy_bar_palette countdown_warn)
    fi

    if (( first_chunk )); then first_chunk=0
    else printf ' '; fi

    marker_reset="${s_reset}"
    marker_window="${s_window}"
    if (( stale )); then
        marker_reset=""
        marker_window=""
    fi
    chunk_bg=$(showy_bar_palette bg)
    surface_color=$(showy_bar_palette surface)
    primary_color=$(showy_bar_role_color primary "${p_remaining}")
    style_text "${CAP_LEFT}" "${primary_color}" "${chunk_bg}"
    style_text "${sigil}" "${chunk_bg}" "${primary_color}" bold
    style_text '▕' "${chunk_bg}" "${primary_color}"
    dual_metric_bar "${p_remaining}" "${s_remaining}" "${marker_reset}" "${marker_window}"
    style_text "${countdown}" "${time_color}" "${surface_color}" bold
    style_text "${CAP_RIGHT}" "${surface_color}" "${chunk_bg}"
done <<< "${rows}"

# Strip CR; emit single newline so zjstatus pipe widget sees a clean record.
printf '\n'
