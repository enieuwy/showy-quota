#!/usr/bin/env bash
# showy-quota — stable state surface for layout managers and adapters.
#
# Reads the shared CodexBar cache through showy-quota-fetch, applies the same
# renderable-provider filtering as every bar renderer, and emits compact JSON
# that external coordinators can consume without knowing CodexBar's schema.
#
# Flags:
#   --json       Default. Print the full state JSON.
#   --count      Print only the filtered provider count.
#   --providers  Print filtered provider ids, one per line.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/strip.sh"

mode="json"
while (($#)); do
    case "$1" in
        --json)      mode="json" ;;
        --count)     mode="count" ;;
        --providers) mode="providers" ;;
        -h|--help)
            printf '%s\n' \
                'Usage: showy-quota-state [--json|--count|--providers]' \
                '' \
                'Emits filtered CodexBar provider state for external layout managers.'
            exit 0
            ;;
        *) showy_quota_die "unknown argument: $1" ;;
    esac
    shift
done

showy_quota_have jq || showy_quota_die "jq is required"

FETCH="${SHOWY_QUOTA_FETCH_BIN:-${SCRIPT_DIR}/showy-quota-fetch}"
FETCH="$(showy_quota_valid_bin "${FETCH}")" || FETCH="${SCRIPT_DIR}/showy-quota-fetch"
threshold="${SHOWY_QUOTA_SKETCHYBAR_COMPACT_PROVIDER_COUNT:-5}"
if [[ ! "${threshold}" =~ ^[0-9]+$ ]]; then
    threshold=5
fi

showy_quota_state_minutes_json() {
    local filtered_json="$1"
    local minutes_json='{}'
    local reset_raw minutes value

    while IFS= read -r reset_raw; do
        [[ -n "${reset_raw}" ]] || continue
        minutes=$(showy_quota_minutes_until "${reset_raw}" || true)
        if [[ "${minutes}" =~ ^[0-9]+$ ]]; then
            value="${minutes}"
        else
            value="null"
        fi
        minutes_json=$(printf '%s' "${minutes_json}" | jq -c --arg reset "${reset_raw}" --argjson value "${value}" '. + {($reset): $value}')
    done < <(printf '%s' "${filtered_json}" | jq -r '
        .[]
        | [
            .usage.primary,
            .usage.secondary,
            .usage.tertiary,
            ((.usage.extraRateWindows // []) | if type == "array" then .[]?.window else empty end)
        ][]
        | select(. != null)
        | (.resetsAt // .resetDescription // empty)
        | select(type == "string" and length > 0)
    ' | sort -u)

    printf '%s' "${minutes_json}"
}


data=""
available=false
if data=$("${FETCH}" 2>/dev/null) && [[ -n "${data}" ]]; then
    available=true
fi

if [[ "${available}" == true ]]; then
    filtered_json=$(printf '%s' "${data}" | showy_quota_filter_renderable | jq -c '.')
    provider_ids_json=$(printf '%s' "${filtered_json}" | jq -c '[ .[].provider ]')
    reset_minutes_json=$(showy_quota_state_minutes_json "${filtered_json}")
    provider_metrics_json=$(printf '%s' "${filtered_json}" | jq -c --argjson reset_minutes "${reset_minutes_json}" '
        def pct($x):
            if ($x | type) == "number" then [0, ([100, ($x | floor)] | min)] | max else null end;
        def nonneg_int($x):
            if (($x | type) == "number") and $x >= 0 then ($x | floor) else null end;
        def string_or_null($x):
            if $x == null then null elif ($x | type) == "string" then $x else null end;
        def reset_key($w):
            string_or_null($w.resetsAt) // string_or_null($w.resetDescription);
        def minutes_until_reset($w):
            (reset_key($w)) as $raw
            | if $raw == null then null else ($reset_minutes[$raw] // null) end;
        def window_state($w):
            if $w != null and (($w.usedPercent | type) == "number") then
                (pct($w.usedPercent)) as $used
                | {
                    usedPercent: $used,
                    remainingPercent: (100 - $used),
                    resetsAt: string_or_null($w.resetsAt),
                    resetDescription: string_or_null($w.resetDescription),
                    windowMinutes: nonneg_int($w.windowMinutes),
                    minutesUntilReset: minutes_until_reset($w)
                }
            else null end;
        def extra_window_state($extra):
            (($extra.usageKnown != false) and ($extra.window != null) and (($extra.window.usedPercent | type) == "number")) as $known
            | (if $known then window_state($extra.window) else {
                usedPercent: null,
                remainingPercent: null,
                resetsAt: null,
                resetDescription: null,
                windowMinutes: null,
                minutesUntilReset: null
            } end) as $window
            | {
                title: string_or_null($extra.title),
                usageKnown: $known,
                usedPercent: $window.usedPercent,
                remainingPercent: $window.remainingPercent,
                resetsAt: $window.resetsAt,
                resetDescription: $window.resetDescription,
                windowMinutes: $window.windowMinutes,
                minutesUntilReset: $window.minutesUntilReset
            };
        [
            .[]
            | {
                provider: .provider,
                windows: {
                    primary: window_state(.usage.primary),
                    secondary: window_state(.usage.secondary),
                    tertiary: window_state(.usage.tertiary)
                },
                extraRateWindows: ((.usage.extraRateWindows // []) | if type == "array" then map(extra_window_state(.)) else [] end)
            }
        ]
    ')
else
    filtered_json='[]'
    provider_ids_json='[]'
    provider_metrics_json='[]'
fi

cache_age="null"
cache_source="unknown"
if [[ -f "${SHOWY_QUOTA_USAGE_FILE}" ]]; then
    cache_age=$(showy_quota_age_seconds "${SHOWY_QUOTA_USAGE_FILE}")
fi
if [[ -r "${SHOWY_QUOTA_SOURCE_FILE}" ]]; then
    IFS= read -r cache_source < "${SHOWY_QUOTA_SOURCE_FILE}" || cache_source="unknown"
fi
case "${cache_source}" in
    serve|cli) ;;
    *) cache_source="unknown" ;;
esac
if [[ "${cache_source}" == "cli" ]]; then
    degraded_flag=true
else
    degraded_flag=false
fi
stale_after=$(showy_quota_stale_after_seconds)
if [[ "${cache_age}" != "null" ]] && (( cache_age > stale_after )); then
    stale_flag=true
else
    stale_flag=false
fi

case "${mode}" in
    count)
        printf '%s\n' "${provider_ids_json}" | jq 'length'
        ;;
    providers)
        printf '%s\n' "${provider_ids_json}" | jq -r '.[]'
        ;;
    json)
        jq -n \
            --argjson providers "${provider_ids_json}" \
            --argjson providerMetrics "${provider_metrics_json}" \
            --argjson available "${available}" \
            --argjson stale "${stale_flag}" \
            --argjson degraded "${degraded_flag}" \
            --arg cache_age "${cache_age}" \
            --arg stale_after "${stale_after}" \
            --arg cache_source "${cache_source}" \
            --arg compact_threshold "${threshold}" \
            '($compact_threshold | tonumber) as $compact_threshold_num
            | {
                available: $available,
                stale: $stale,
                cache: {
                    source: $cache_source,
                    degraded: $degraded
                },
                cacheAgeSeconds: (if $cache_age == "null" then null else ($cache_age | tonumber) end),
                staleAfterSeconds: ($stale_after | tonumber),
                providers: $providers,
                providerMetrics: $providerMetrics,
                providerCount: ($providers | length),
                sketchybar: {
                    itemPrefix: "showy_quota",
                    bracket: "showy_quota_bracket",
                    compactProviderThreshold: $compact_threshold_num,
                    compactRecommended: (($providers | length) >= $compact_threshold_num)
                }
            }'
        ;;
esac
