#!/usr/bin/env bash
# showy-quota — stable state surface for layout managers and adapters.
#
# Reads the shared CodexBar cache through showy-quota-fetch, applies the same
# renderable-provider filtering as every bar renderer, and emits compact JSON
# that external coordinators can consume without knowing CodexBar's schema.
#
# Flags:
#   --json       Default. Print the full state JSON.
#   --count      Print only the filtered provider count.
#   --providers  Print filtered provider ids, one per line.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/strip.sh"

mode="json"
while (($#)); do
    case "$1" in
        --json)      mode="json" ;;
        --count)     mode="count" ;;
        --providers) mode="providers" ;;
        -h|--help)
            printf '%s\n' \
                'Usage: showy-quota-state [--json|--count|--providers]' \
                '' \
                'Emits filtered CodexBar provider state for external layout managers.'
            exit 0
            ;;
        *) showy_quota_die "unknown argument: $1" ;;
    esac
    shift
done

showy_quota_have jq || showy_quota_die "jq is required"

FETCH="${SHOWY_QUOTA_FETCH_BIN:-${SCRIPT_DIR}/showy-quota-fetch}"
FETCH="$(showy_quota_valid_bin "${FETCH}")" || FETCH="${SCRIPT_DIR}/showy-quota-fetch"
threshold="${SHOWY_QUOTA_SKETCHYBAR_COMPACT_PROVIDER_COUNT:-5}"
if [[ ! "${threshold}" =~ ^[0-9]+$ ]]; then
    threshold=5
fi

data=""
available=false
if data=$("${FETCH}" 2>/dev/null) && [[ -n "${data}" ]]; then
    available=true
fi

if [[ "${available}" == true ]]; then
    providers_json=$(printf '%s' "${data}" | showy_quota_filter_renderable | jq -c '[ .[].provider ]')
else
    providers_json='[]'
fi

cache_age="null"
cache_source="unknown"
if [[ -f "${SHOWY_QUOTA_USAGE_FILE}" ]]; then
    cache_age=$(showy_quota_age_seconds "${SHOWY_QUOTA_USAGE_FILE}")
fi
if [[ -r "${SHOWY_QUOTA_SOURCE_FILE}" ]]; then
    IFS= read -r cache_source < "${SHOWY_QUOTA_SOURCE_FILE}" || cache_source="unknown"
fi
case "${cache_source}" in
    serve|cli) ;;
    *) cache_source="unknown" ;;
esac
if [[ "${cache_source}" == "cli" ]]; then
    degraded_flag=true
else
    degraded_flag=false
fi
stale_after=$(showy_quota_stale_after_seconds)
if [[ "${cache_age}" != "null" ]] && (( cache_age > stale_after )); then
    stale_flag=true
else
    stale_flag=false
fi

case "${mode}" in
    count)
        printf '%s\n' "${providers_json}" | jq 'length'
        ;;
    providers)
        printf '%s\n' "${providers_json}" | jq -r '.[]'
        ;;
    json)
        jq -n \
            --argjson providers "${providers_json}" \
            --argjson available "${available}" \
            --argjson stale "${stale_flag}" \
            --argjson degraded "${degraded_flag}" \
            --arg cache_age "${cache_age}" \
            --arg stale_after "${stale_after}" \
            --arg cache_source "${cache_source}" \
            --arg compact_threshold "${threshold}" \
            '($compact_threshold | tonumber) as $compact_threshold_num
            | {
                available: $available,
                stale: $stale,
                cache: {
                    source: $cache_source,
                    degraded: $degraded
                },
                cacheAgeSeconds: (if $cache_age == "null" then null else ($cache_age | tonumber) end),
                staleAfterSeconds: ($stale_after | tonumber),
                providers: $providers,
                providerCount: ($providers | length),
                sketchybar: {
                    itemPrefix: "showy_quota",
                    bracket: "showy_quota_bracket",
                    compactProviderThreshold: $compact_threshold_num,
                    compactRecommended: (($providers | length) >= $compact_threshold_num)
                }
            }'
        ;;
esac
