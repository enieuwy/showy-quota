#!/usr/bin/env bash
# showy-bar вЂ” tmux status-line markup renderer.
#
# Designed for use in `set -ag status-right ' #(showy-bar-tmux-bar)'`. Prints
# tmux-format markup with the same visible provider chunks as the Zellij strip.
# Multiple providers are separated by a styled single-cell gap.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/strip.sh"

showy_bar_have jq || showy_bar_die "jq is required"

FETCH="${SHOWY_BAR_FETCH_BIN:-${SCRIPT_DIR}/showy-bar-fetch}"

CAP_LEFT="${SHOWY_BAR_CAP_LEFT-о‚¶}"
CAP_RIGHT="${SHOWY_BAR_CAP_RIGHT-о‚ґ}"

tmux_reset() { printf '#[default]'; }
tmux_dim() { printf '#[dim]'; }

tmux_style_text() {
    local text="$1" fg_hex="${2:-}" bg_hex="${3:-}" weight="${4:-}"
    local sep=""

    printf '#['
    if [[ -n "${fg_hex}" ]]; then
        printf 'fg=#%s' "${fg_hex}"
        sep=","
    fi
    if [[ -n "${bg_hex}" ]]; then
        printf '%sbg=#%s' "${sep}" "${bg_hex}"
        sep=","
    fi
    if [[ -n "${weight}" ]]; then
        printf '%s%s' "${sep}" "${weight}"
    fi
    printf ']%s' "${text}"
    tmux_reset
}

tmux_dual_metric_bar() {
    local p_remaining="$1" s_remaining="$2" s_reset="$3" s_window="$4"
    local primary_override="${5:-}" secondary_override="${6:-}"
    local width="${SHOWY_BAR_TMUX_BAR_WIDTH:-${SHOWY_BAR_ZELLIJ_BAR_WIDTH:-12}}"
    [[ "${width}" =~ ^[0-9]+$ ]] || width=12
    (( width < 8 )) && width=8

    local primary_color secondary_color bg_color surface_color elapsed_color
    primary_color="${primary_override:-$(showy_bar_role_color primary "${p_remaining}")}"
    secondary_color="${secondary_override:-$(showy_bar_role_color secondary "${s_remaining}")}"
    bg_color=$(showy_bar_palette bg)
    surface_color=$(showy_bar_palette surface)
    elapsed_color=$(showy_bar_palette elapsed)

    local p_fill s_fill marker i top_color bottom_color
    p_fill=$(showy_bar_filled_cells "${p_remaining}" "${width}")
    s_fill=$(showy_bar_filled_cells "${s_remaining}" "${width}")
    marker=$(showy_bar_elapsed_marker_cell "${s_reset}" "${s_window}" "${width}" || true)

    for (( i=0; i<width; i++ )); do
        if (( i < p_fill )); then top_color="${primary_color}"
        else top_color="${surface_color}"; fi

        if (( i < s_fill )); then bottom_color="${secondary_color}"
        else bottom_color="${surface_color}"; fi

        if [[ "${marker}" =~ ^[0-9]+$ && "${i}" == "${marker}" ]]; then
            tmux_style_text 'в–Ђ' "${top_color}" "${elapsed_color}"
        else
            tmux_style_text 'в–Ђ' "${top_color}" "${bottom_color}"
        fi
    done
    tmux_style_text 'в–Џ' "${bg_color}" "${surface_color}"
}

# в”Ђв”Ђ data load в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

if ! data=$("${FETCH}" 2>/dev/null) || [[ -z "${data}" ]]; then
    tmux_style_text 'AI ?' "$(showy_bar_role_palette primary unknown)"
    exit 0
fi

filtered=$(printf '%s' "${data}" | showy_bar_filter_renderable)
count=$(printf '%s' "${filtered}" | jq 'length')

if (( count == 0 )); then
    printf '%s' "$(tmux_dim)"; tmux_style_text 'AI idle' "$(showy_bar_role_palette primary unknown)"
    exit 0
fi

stale=0
if showy_bar_cache_stale_for "${SHOWY_BAR_USAGE_FILE}"; then
    stale=1
fi

rows=$(printf '%s' "${filtered}" | jq -r '
    def pct(x): if x == null then -1 else ([0, ([100, (x|tonumber|floor)] | min)] | max) end;
    .[]
    | select((.provider | type == "string" and length > 0) and (.usage.primary.usedPercent | type == "number"))
    | [
        .provider,
        pct(.usage.primary.usedPercent),
        (.usage.primary.resetsAt // .usage.primary.resetDescription // ""),
        (.usage.primary.windowMinutes // ""),
        pct(.usage.secondary.usedPercent),
        (.usage.secondary.resetsAt // .usage.secondary.resetDescription // ""),
        (.usage.secondary.windowMinutes // "")
    ] | map(tostring) | join("\u001f")')

first_chunk=1
chunk_bg=$(showy_bar_palette bg)
stale_color=$(showy_bar_palette stale)
countdown_warn=$(showy_bar_palette countdown_warn)
while IFS=$'\x1f' read -r provider p_used p_reset _p_window s_used s_reset s_window; do
    [[ -n "${provider}" ]] || continue

    p_remaining=$((100 - p_used))
    s_remaining=0
    if (( s_used >= 0 )); then
        s_remaining=$((100 - s_used))
    fi

    sigil=$(showy_bar_provider_sigil "${provider}")

    minutes=""
    if [[ -n "${p_reset}" ]]; then
        minutes=$(showy_bar_minutes_until "${p_reset}" || true)
        if (( stale )) && [[ "${minutes}" == "0" ]]; then
            reset_epoch=$(showy_bar_reset_epoch "${p_reset}" || true)
            now_epoch=$(showy_bar_now_epoch)
            if [[ -n "${reset_epoch}" ]] && (( reset_epoch <= now_epoch )); then
                minutes=""
            fi
        fi
    fi
    countdown=$(showy_bar_primary_label "${minutes}" "${p_remaining}" "${p_reset}")

    time_color=$(showy_bar_palette countdown)
    if (( stale )); then
        time_color="${stale_color}"
    elif [[ -n "${minutes}" && "${minutes}" -lt "${SHOWY_BAR_TIME_WARN_MINUTES}" ]]; then
        time_color=$(showy_bar_palette countdown_warn)
    fi

    if (( first_chunk )); then first_chunk=0
    else tmux_style_text ' ' "$(showy_bar_palette bg)" "$(showy_bar_palette bg)"; fi

    marker_reset="${s_reset}"
    marker_window="${s_window}"
    if (( stale )); then
        marker_reset=""
        marker_window=""
    fi

    surface_color=$(showy_bar_palette surface)
    primary_color=$(showy_bar_role_color primary "${p_remaining}")
    secondary_color=$(showy_bar_role_color secondary "${s_remaining}")
    if (( stale )); then
        primary_color="${stale_color}"
        secondary_color="${stale_color}"
    fi
    separator_fg="${chunk_bg}"
    separator_bg="${primary_color}"
    tmux_style_text "${CAP_LEFT}" "${primary_color}" "${chunk_bg}"
    tmux_style_text "${sigil}" "${chunk_bg}" "${primary_color}" bold
    tmux_style_text 'в–•' "${separator_fg}" "${separator_bg}"
    tmux_dual_metric_bar "${p_remaining}" "${s_remaining}" "${marker_reset}" "${marker_window}" "${primary_color}" "${secondary_color}"
    tmux_style_text "${countdown}" "${time_color}" "${surface_color}" bold
    tmux_style_text "${CAP_RIGHT}" "${surface_color}" "${chunk_bg}"
done <<< "${rows}"
if (( stale )); then
    tmux_style_text ' ' "$(showy_bar_palette bg)" "$(showy_bar_palette bg)"
    tmux_style_text "${SHOWY_BAR_STALE_GLYPH}" "${countdown_warn}" "${chunk_bg}" bold
fi
