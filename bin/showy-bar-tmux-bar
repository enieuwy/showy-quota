#!/usr/bin/env bash
# showy-bar — tmux status-line markup renderer.
#
# Designed for use in `set -ag status-right ' #(showy-bar-tmux-bar)'`. Prints
# tmux-format markup to stdout. Strips per-provider blocks are separated by
# a thin space.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/strip.sh"

showy_bar_have jq || showy_bar_die "jq is required"

FETCH="${SHOWY_BAR_FETCH_BIN:-${SCRIPT_DIR}/showy-bar-fetch}"

# tmux color literals are accepted as #RRGGBB. Wrap a payload with fg.
tmux_fg() { printf '#[fg=#%s]' "$1"; }
tmux_reset() { printf '#[default]'; }
tmux_dim() { printf '#[dim]'; }
tmux_bold() { printf '#[bold]'; }
tmux_nobold() { printf '#[nobold]'; }

# ── data load ──────────────────────────────────────────────────────

if ! data=$("${FETCH}" 2>/dev/null) || [[ -z "${data}" ]]; then
    printf '%sAI ?%s' "$(tmux_fg "$(showy_bar_role_palette primary unknown)")" "$(tmux_reset)"
    exit 0
fi

filtered=$(printf '%s' "${data}" | showy_bar_filter_renderable)
count=$(printf '%s' "${filtered}" | jq 'length')

if (( count == 0 )); then
    printf '%s%sAI idle%s' "$(tmux_dim)" "$(tmux_fg "$(showy_bar_role_palette primary unknown)")" "$(tmux_reset)"
    exit 0
fi

age=$(showy_bar_age_seconds "${SHOWY_BAR_USAGE_FILE}")
stale=0
(( age > SHOWY_BAR_REFRESH_SECONDS * 2 )) && stale=1

rows=$(printf '%s' "${filtered}" | jq -r '
    def pct(x): if x == null then -1 else ([0, ([100, (x|tonumber|floor)] | min)] | max) end;
    .[]
    | select((.provider | type == "string" and length > 0) and (.usage.primary.usedPercent | type == "number"))
    | [
        .provider,
        pct(.usage.primary.usedPercent),
        (.usage.primary.resetsAt // .usage.primary.resetDescription // ""),
        pct(.usage.secondary.usedPercent)
    ] | map(tostring) | join("\u001f")')

first_chunk=1
while IFS=$'\x1f' read -r provider p_used p_reset s_used; do
    [[ -n "${provider}" ]] || continue

    p_remaining=$((100 - p_used))
    color_hex=$(showy_bar_role_color primary "${p_remaining}")

    sigil=$(showy_bar_provider_sigil "${provider}")
    bar=$(showy_bar_block_bar "${p_remaining}")

    minutes=""
    if (( ! stale )) && [[ -n "${p_reset}" ]]; then
        minutes=$(showy_bar_minutes_until "${p_reset}" || true)
    fi
    countdown=$(showy_bar_primary_label "${minutes}" "${p_remaining}" "${p_reset}" "${stale}")

    weekly_hint=""
    if (( ! stale && s_used >= 0 )); then
        s_remaining=$((100 - s_used))
        if (( s_remaining < p_remaining )); then
            weekly_hint=" $(tmux_fg "$(showy_bar_role_color secondary "${s_remaining}")")w$(tmux_reset)"
        fi
    fi

    if (( first_chunk )); then first_chunk=0
    else printf ' '; fi

    tmux_bold; printf '%s' "${sigil}"; tmux_nobold
    printf ' '
    tmux_fg "${color_hex}"; printf '%s' "${bar}"; tmux_reset
    printf ' '
    time_color=$(showy_bar_palette countdown)
    if (( stale )); then
        time_color=$(showy_bar_palette countdown_warn)
    elif [[ -n "${minutes}" && "${minutes}" -lt "${SHOWY_BAR_TIME_WARN_MINUTES}" ]]; then
        time_color=$(showy_bar_palette countdown_warn)
    fi
    tmux_fg "${time_color}"; printf '%s' "${countdown}"; tmux_reset
    [[ -n "${weekly_hint}" ]] && printf '%s' "${weekly_hint}"
    tmux_reset
done <<< "${rows}"
