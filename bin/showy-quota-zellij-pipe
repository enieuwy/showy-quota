#!/usr/bin/env bash
# showy-quota — long-running zjstatus pipe loop.
#
# Pipes the rendered ANSI strip into zjstatus on a fixed cadence. We use
# the pipe widget instead of zjstatus's command widget because the command
# widget crashes under WASMI with std::sync::Mutex initialization errors
# (single-threaded WASM).

set -euo pipefail

child=""
trap 'kill "${child:-}" 2>/dev/null; wait "${child:-}" 2>/dev/null; exit' INT TERM EXIT

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"

BAR="${SCRIPT_DIR}/showy-quota-zellij-bar"
[[ -x "${BAR}" ]] || showy_quota_die "missing renderer: ${BAR}"
export SHOWY_QUOTA_FORCE_COLOR=1

showy_quota_have "${SHOWY_QUOTA_ZELLIJ_BIN}" || showy_quota_die "zellij is required for pipe mode: ${SHOWY_QUOTA_ZELLIJ_BIN}"

interval="${SHOWY_QUOTA_ZELLIJ_PIPE_INTERVAL}"
[[ "${interval}" =~ ^[0-9]+([.][0-9]+)?$ ]] || interval=10
widget="${SHOWY_QUOTA_ZELLIJ_WIDGET}"
pipe_name="${SHOWY_QUOTA_ZELLIJ_PIPE_NAME}"
plugin="${SHOWY_QUOTA_ZELLIJ_PLUGIN}"
pipe_timeout_tenths="${SHOWY_QUOTA_ZELLIJ_PIPE_TIMEOUT_TENTHS}"
[[ "${pipe_timeout_tenths}" =~ ^[0-9]+$ ]] || pipe_timeout_tenths=20
zellij_args=()
if [[ -n "${ZELLIJ_SESSION_NAME:-}" ]]; then
    zellij_args+=(--session "${ZELLIJ_SESSION_NAME}")
fi


reap_timed_out_pipe() {
    local child="$1" waited=0
    kill "${child}" 2>/dev/null || true
    while kill -0 "${child}" 2>/dev/null; do
        if (( waited >= 5 )); then
            kill -KILL "${child}" 2>/dev/null || true
            break
        fi
        sleep 0.1
        waited=$((waited + 1))
    done
    wait "${child}" >/dev/null 2>&1 || true
}

ansi_suffix_complete() {
    local suffix="$1" esc=$'\033' csi_re=$'^\033\\[[0-?]*[ -/]*[@-~]'
    case "${suffix}" in
        "${esc}") return 1 ;;
        "${esc}["*) [[ "${suffix}" =~ ${csi_re} ]] ;;
        "${esc}]"*) [[ "${suffix}" == *$'\a'* ]] ;;
        "${esc}P"*|"${esc}^"*|"${esc}_"*|"${esc}X"*) return 1 ;;
        *) ((${#suffix} >= 2)) ;;
    esac
}

drop_trailing_partial_ansi() {
    local value="$1" esc=$'\033' prefix suffix
    while [[ "${value}" == *"${esc}"* ]]; do
        prefix="${value%"${esc}"*}"
        suffix="${value:${#prefix}}"
        ansi_suffix_complete "${suffix}" && break
        value="${prefix}"
    done
    printf '%s' "${value}"
}

drop_trailing_non_ascii_bytes() {
    local value="$1" last byte
    while [[ -n "${value}" ]]; do
        last="${value: -1}"
        LC_ALL=C printf -v byte '%d' "'${last}"
        (( byte >= 128 )) || break
        value="${value:0:${#value}-1}"
    done
    printf '%s' "${value}"
}


truncate_pipe_output() {
    local value="${1:0:4096}"
    if command -v iconv >/dev/null 2>&1; then
        value=$(printf '%s' "${value}" | iconv -f UTF-8 -t UTF-8 -c 2>/dev/null || :)
    else
        value="$(drop_trailing_non_ascii_bytes "${value}")"
    fi
    value="$(drop_trailing_partial_ansi "${value}")"
    printf '%s\033[0m' "${value}"
}


send_pipe() {
    local payload="$1" waited=0 requested_plugin="${plugin}"
    local args=(pipe --name "${pipe_name}")
    if [[ ! "${requested_plugin}" =~ ^[A-Za-z0-9_.-]+$ ]] ||
        ((${#requested_plugin} > 128)) ||
        [[ "${requested_plugin}" == -* ]] ||
        [[ "${requested_plugin}" == *::* ]]; then
        requested_plugin=""
    fi
    if [[ -n "${requested_plugin}" ]]; then
        args+=(--plugin "${requested_plugin}")
    fi
    args+=(-- "${payload}")

    "${SHOWY_QUOTA_ZELLIJ_BIN}" "${zellij_args[@]}" "${args[@]}" </dev/null >/dev/null 2>&1 &
    child=$!
    while kill -0 "${child}" 2>/dev/null; do
        if (( waited >= pipe_timeout_tenths )); then
            reap_timed_out_pipe "${child}"
            child=""
            return 1
        fi
        sleep 0.1
        waited=$((waited + 1))
    done
    if wait "${child}" >/dev/null 2>&1; then
        child=""
        return 0
    fi
    child=""
    return 1
}

# zjstatus consumes the protocol from the payload itself:
#   zjstatus::pipe::<widget>::<output>
# Broadcast by default because zjstatus pipe widgets are configured per plugin
# instance. Bound each helper so another plugin's CLI-pipe backpressure cannot
# pin this feeder after an early or unlucky update.
consecutive_failures=0
while :; do
    sleep_delay="${interval}"
    if output=$("${BAR}" 2>/dev/null) && [[ -n "${output}" ]]; then
        # Cap the payload well under OS ARG_MAX so a pathologically long render
        # (e.g. a giant cache) cannot make the `zellij pipe` call fail silently.
        ((${#output} <= 4096)) || output="$(truncate_pipe_output "${output}")"
        if send_pipe "zjstatus::pipe::${widget}::${output}"; then
            consecutive_failures=0
        else
            consecutive_failures=$((consecutive_failures + 1))
            if (( consecutive_failures < 5 )); then
                backoff_multiplier=$((1 << consecutive_failures))
            else
                backoff_multiplier=30
            fi
            jitter=$((RANDOM % 21 - 10))
            sleep_delay="$(awk -v interval="${interval}" -v multiplier="${backoff_multiplier}" -v jitter="${jitter}" 'BEGIN {
                delay = interval * multiplier * (1 + jitter / 100)
                ceiling = interval * 30
                if (delay > ceiling) delay = ceiling
                printf "%.3f", delay
            }')"
        fi
    fi
    sleep "${sleep_delay}"
done
