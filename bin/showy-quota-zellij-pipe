#!/usr/bin/env bash
# showy-quota — long-running zjstatus pipe loop.
#
# Pipes the rendered ANSI strip into zjstatus on a fixed cadence. We use
# the pipe widget instead of zjstatus's command widget because the command
# widget crashes under WASMI with std::sync::Mutex initialization errors
# (single-threaded WASM).

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"

BAR="${SCRIPT_DIR}/showy-quota-zellij-bar"
[[ -x "${BAR}" ]] || showy_quota_die "missing renderer: ${BAR}"
export SHOWY_QUOTA_FORCE_COLOR=1

showy_quota_have "${SHOWY_QUOTA_ZELLIJ_BIN}" || showy_quota_die "zellij is required for pipe mode: ${SHOWY_QUOTA_ZELLIJ_BIN}"

interval="${SHOWY_QUOTA_ZELLIJ_PIPE_INTERVAL}"
[[ "${interval}" =~ ^[0-9]+([.][0-9]+)?$ ]] || interval=10
widget="${SHOWY_QUOTA_ZELLIJ_WIDGET}"
pipe_name="${SHOWY_QUOTA_ZELLIJ_PIPE_NAME}"
plugin="${SHOWY_QUOTA_ZELLIJ_PLUGIN}"
pipe_timeout_tenths="${SHOWY_QUOTA_ZELLIJ_PIPE_TIMEOUT_TENTHS}"
[[ "${pipe_timeout_tenths}" =~ ^[0-9]+$ ]] || pipe_timeout_tenths=20
zellij_args=()
if [[ -n "${ZELLIJ_SESSION_NAME:-}" ]]; then
    zellij_args+=(--session "${ZELLIJ_SESSION_NAME}")
fi


reap_timed_out_pipe() {
    local child="$1" waited=0
    kill "${child}" 2>/dev/null || true
    while kill -0 "${child}" 2>/dev/null; do
        if (( waited >= 5 )); then
            kill -KILL "${child}" 2>/dev/null || true
            break
        fi
        sleep 0.1
        waited=$((waited + 1))
    done
    wait "${child}" >/dev/null 2>&1 || true
}

send_pipe() {
    local payload="$1" child waited=0
    local args=(pipe --name "${pipe_name}")
    if [[ -n "${plugin}" ]]; then
        args+=(--plugin "${plugin}")
    fi
    args+=(-- "${payload}")

    "${SHOWY_QUOTA_ZELLIJ_BIN}" "${zellij_args[@]}" "${args[@]}" </dev/null >/dev/null 2>&1 &
    child=$!
    while kill -0 "${child}" 2>/dev/null; do
        if (( waited >= pipe_timeout_tenths )); then
            reap_timed_out_pipe "${child}"
            return 1
        fi
        sleep 0.1
        waited=$((waited + 1))
    done
    wait "${child}" >/dev/null 2>&1
}

# zjstatus consumes the protocol from the payload itself:
#   zjstatus::pipe::<widget>::<output>
# Broadcast by default because zjstatus pipe widgets are configured per plugin
# instance. Bound each helper so another plugin's CLI-pipe backpressure cannot
# pin this feeder after an early or unlucky update.
while :; do
    if output=$("${BAR}" 2>/dev/null) && [[ -n "${output}" ]]; then
        # Cap the payload well under OS ARG_MAX so a pathologically long render
        # (e.g. a giant cache) cannot make the `zellij pipe` call fail silently.
        (( ${#output} <= 4096 )) || output="${output:0:4096}"
        send_pipe "zjstatus::pipe::${widget}::${output}" || true
    fi
    sleep "${interval}"
done
