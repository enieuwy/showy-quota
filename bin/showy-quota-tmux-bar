#!/usr/bin/env bash
# showy-quota — tmux status-line strip driver.
#
# Reads cached CodexBar JSON via showy-quota-fetch and delegates terminal-strip
# rendering to showy-quota-render. Pass `--json <path|->` to render supplied JSON
# without fetching, stale markers, or degraded-source markers.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd -P)"
# shellcheck disable=SC1091
. "${REPO_ROOT}/lib/common.sh"

FETCH="${SHOWY_QUOTA_FETCH_BIN:-${SCRIPT_DIR}/showy-quota-fetch}"
FETCH="$(showy_quota_valid_bin "${FETCH}")" || FETCH="${SCRIPT_DIR}/showy-quota-fetch"

json_input=""
while (($#)); do
    case "$1" in
        --json)
            shift
            [[ $# -gt 0 ]] || showy_quota_die "--json requires path or -"
            json_input="$1"
            ;;
        -h|--help)
            printf '%s\n' \
                'Usage: showy-quota-tmux-bar [--json <path|->]' \
                '' \
                'Prints a tmux status-line usage strip.'
            exit 0
            ;;
        *) showy_quota_die "unknown argument: $1" ;;
    esac
    shift
done

tmux_fg() {
    printf '#[fg=#%s]' "$1"
}

print_ai_fallback() {
    tmux_fg "$(showy_quota_primary_palette unknown)"
    printf 'AI ?#[default]'
}

resolve_render_bin() {
    local candidate resolved repo_candidate
    if [[ -n "${SHOWY_QUOTA_RENDER_BIN:-}" ]]; then
        if candidate="$(showy_quota_valid_bin "${SHOWY_QUOTA_RENDER_BIN}")"; then
            if [[ "${candidate}" == */* ]]; then
                if [[ -x "${candidate}" ]]; then
                    printf '%s\n' "${candidate}"
                    return 0
                fi
            elif resolved="$(command -v "${candidate}" 2>/dev/null)"; then
                printf '%s\n' "${resolved}"
                return 0
            fi
        fi
    fi

    # Sibling binary: copied installs and release tarballs ship
    # showy-quota-render next to this driver, so the installed tree works
    # without PATH or a checkout.
    if [[ -x "${SCRIPT_DIR}/showy-quota-render" ]]; then
        printf '%s\n' "${SCRIPT_DIR}/showy-quota-render"
        return 0
    fi

    if resolved="$(command -v showy-quota-render 2>/dev/null)"; then
        printf '%s\n' "${resolved}"
        return 0
    fi

    repo_candidate="${REPO_ROOT}/target/release/showy-quota-render"
    if [[ -x "${repo_candidate}" ]]; then
        printf '%s\n' "${repo_candidate}"
        return 0
    fi

    return 1
}

export_showy_quota_config() {
    local name decl
    for name in ${!SHOWY_QUOTA_@}; do
        decl="$(declare -p "${name}" 2>/dev/null || true)"
        case "${decl}" in
            declare\ -a*|declare\ -A*) continue ;;
        esac
        export "${name?}"
    done
}

if ! RENDER_BIN="$(resolve_render_bin)"; then
    print_ai_fallback
    printf 'showy-quota-render not found; run make render-bin\n' >&2
    exit 0
fi

if [[ -n "${json_input}" ]]; then
    if [[ "${json_input}" == "-" ]]; then
        data=$(</dev/stdin)
    else
        [[ -f "${json_input}" ]] || showy_quota_die "JSON input is not a regular file: ${json_input}"
        showy_quota_json_valid "${json_input}" || showy_quota_die "JSON input is not valid quota data: ${json_input}"
        data=$(< "${json_input}")
    fi
elif ! data=$("${FETCH}" 2>/dev/null) || [[ -z "${data}" ]]; then
    print_ai_fallback
    exit 0
fi

if [[ -z "${data}" ]]; then
    print_ai_fallback
    exit 0
fi

args=("${RENDER_BIN}" --format tmux --json -)
if [[ -z "${json_input}" ]] && showy_quota_cache_stale_for "${SHOWY_QUOTA_USAGE_FILE}"; then
    args+=(--stale)
fi
if [[ -z "${json_input}" ]] && { [[ "${SHOWY_QUOTA_DEGRADED_CLI:-}" == "1" ]] || { [[ -z "${SHOWY_QUOTA_DEGRADED_CLI:-}" ]] && showy_quota_cache_degraded_cli; }; }; then
    args+=(--degraded-cli)
fi

export_showy_quota_config

exec "${args[@]}" < <(printf '%s' "${data}")
