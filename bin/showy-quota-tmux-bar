#!/usr/bin/env bash
# showy-quota — tmux status-line markup renderer.
#
# Designed for use in `set -ag status-right ' #(showy-quota-tmux-bar)'`. Prints
# tmux-format markup with the same visible provider chunks as the Zellij strip.
# Multiple providers are separated by a styled single-cell gap.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/strip.sh"

showy_quota_have jq || showy_quota_die "jq is required"

FETCH="${SHOWY_QUOTA_FETCH_BIN:-${SCRIPT_DIR}/showy-quota-fetch}"

CAP_LEFT="${SHOWY_QUOTA_CAP_LEFT-}"
CAP_RIGHT="${SHOWY_QUOTA_CAP_RIGHT-}"

tmux_reset() { printf '#[default]'; }
tmux_dim() { printf '#[dim]'; }

tmux_style_text() {
    local text="$1" fg_hex="${2:-}" bg_hex="${3:-}" weight="${4:-}"
    local sep=""

    printf '#['
    if [[ -n "${fg_hex}" ]]; then
        printf 'fg=#%s' "${fg_hex}"
        sep=","
    fi
    if [[ -n "${bg_hex}" ]]; then
        printf '%sbg=#%s' "${sep}" "${bg_hex}"
        sep=","
    fi
    if [[ -n "${weight}" ]]; then
        printf '%s%s' "${sep}" "${weight}"
    fi
    printf ']%s' "${text}"
    tmux_reset
}

tmux_dual_metric_bar() {
    local p_remaining="$1" s_remaining="$2"
    local p_reset="$3" p_window="$4" s_reset="$5" s_window="$6"
    local primary_override="${7:-}" secondary_override="${8:-}"
    local width="${SHOWY_QUOTA_TMUX_BAR_WIDTH:-${SHOWY_QUOTA_ZELLIJ_BAR_WIDTH:-12}}"
    [[ "${width}" =~ ^[0-9]+$ ]] || width=12
    (( width < 8 )) && width=8

    local primary_color secondary_color bg_color surface_color elapsed_color
    primary_color="${primary_override:-$(showy_quota_window_color "${p_remaining}" "$(showy_quota_is_long_window "${p_window}")")}"
    secondary_color="${secondary_override:-$(showy_quota_window_color "${s_remaining}" "$(showy_quota_is_long_window "${s_window}")")}"
    bg_color=$(showy_quota_palette bg)
    surface_color=$(showy_quota_palette surface)
    elapsed_color=$(showy_quota_palette elapsed)

    local p_fill s_fill p_marker s_marker i top_color bottom_color
    p_fill=$(showy_quota_filled_cells "${p_remaining}" "${width}")
    s_fill=$(showy_quota_filled_cells "${s_remaining}" "${width}")
    p_marker=$(showy_quota_elapsed_marker_cell "${p_reset}" "${p_window}" "${width}" || true)
    s_marker=$(showy_quota_elapsed_marker_cell "${s_reset}" "${s_window}" "${width}" || true)

    for (( i=0; i<width; i++ )); do
        # Top half = primary window, bottom half = secondary window; each row
        # shows its own pacing marker via the elapsed color.
        if [[ "${p_marker}" =~ ^[0-9]+$ && "${i}" == "${p_marker}" ]]; then top_color="${elapsed_color}"
        elif (( i < p_fill )); then top_color="${primary_color}"
        else top_color="${surface_color}"; fi

        if [[ "${s_marker}" =~ ^[0-9]+$ && "${i}" == "${s_marker}" ]]; then bottom_color="${elapsed_color}"
        elif (( i < s_fill )); then bottom_color="${secondary_color}"
        else bottom_color="${surface_color}"; fi

        tmux_style_text '▀' "${top_color}" "${bottom_color}"
    done
    tmux_style_text '▏' "${bg_color}" "${surface_color}"
}



# ── data load ──────────────────────────────────────────────────────

if ! data=$("${FETCH}" 2>/dev/null) || [[ -z "${data}" ]]; then
    tmux_style_text 'AI ?' "$(showy_quota_primary_palette unknown)"
    exit 0
fi

filtered=$(printf '%s' "${data}" | showy_quota_filter_renderable)
count=$(printf '%s' "${filtered}" | jq 'length')

if (( count == 0 )); then
    printf '%s' "$(tmux_dim)"; tmux_style_text 'AI idle' "$(showy_quota_primary_palette unknown)"
    exit 0
fi

stale=0
if showy_quota_cache_stale_for "${SHOWY_QUOTA_USAGE_FILE}"; then
    stale=1
fi
degraded_cli=0
if [[ "${SHOWY_QUOTA_DEGRADED_CLI:-}" == "1" ]] || { [[ -z "${SHOWY_QUOTA_DEGRADED_CLI:-}" ]] && showy_quota_cache_degraded_cli; }; then
    degraded_cli=1
fi

# Slots are semantic: primary/secondary/tertiary map to fixed rows and
# roles. A slot only counts when that exact window has a numeric
# usedPercent; missing slots stay -1/empty instead of shifting up.
rows=$(printf '%s' "${filtered}" | jq -r '
    def pct(x): if x == null then -1 else ([0, ([100, (x|tonumber|floor)] | min)] | max) end;
    def slot(w): if (w != null and (w.usedPercent | type == "number")) then w else null end;
    def wmin(w): (w.windowMinutes // null) | (if (type == "number" and . >= 0) then . else null end);
    def wkey(w): [ wmin(w), (w.resetsAt // null) ];
    def rval: (.resetsAt // .resetDescription // "");
    .[]
    | (slot(.usage.primary)) as $p
    | (slot(.usage.secondary)) as $s
    | (slot(.usage.tertiary)) as $t
    | select((.provider | type == "string" and length > 0)
        and ($p != null or $s != null or $t != null))
    | ([ $p, $s, $t ] | map(select(. != null))) as $slots
    | ((.usage.extraRateWindows // [])
        | map(select(.window != null and (.window.usedPercent | type == "number") and (.usageKnown != false)) | .window)) as $extras
    | (reduce ($slots + $extras)[] as $w ([];
        if (length >= 4) then . elif (any(.[]; wkey(.) == wkey($w))) then . else . + [$w] end)) as $rw
    | ((.usage.extraRateWindows // [])
        | map(select(.window != null and (.window.usedPercent | type == "number")))) as $ex
    | ([range(0; ([($ex | length), 4] | min); 2)] | map({t: $ex[.], b: $ex[(. + 1)]})) as $fams
    | [
        .provider,
        pct($p.usedPercent), ($p.resetsAt // $p.resetDescription // ""), ($p.windowMinutes // ""),
        pct($s.usedPercent), ($s.resetsAt // $s.resetDescription // ""), ($s.windowMinutes // ""),
        pct($t.usedPercent), ($t.resetsAt // $t.resetDescription // ""), ($t.windowMinutes // ""),
        ($rw | length),
        pct($rw[0].usedPercent), ($rw[0] | rval), ($rw[0].windowMinutes // ""),
        pct($rw[1].usedPercent), ($rw[1] | rval), ($rw[1].windowMinutes // ""),
        pct($rw[2].usedPercent), ($rw[2] | rval), ($rw[2].windowMinutes // ""),
        pct($rw[3].usedPercent), ($rw[3] | rval), ($rw[3].windowMinutes // ""),
        ($fams | length),
        (($fams[0].t.title // "") | [scan("[A-Za-z0-9]")] | (.[0] // "?") | ascii_upcase),
        (if ($fams[0].t.usageKnown == false) then -1 else pct($fams[0].t.window.usedPercent) end),
        ($fams[0].t.window | rval), ($fams[0].t.window.windowMinutes // ""),
        (if ($fams[0].b.usageKnown == false) then -1 else pct($fams[0].b.window.usedPercent) end),
        ($fams[0].b.window | rval), ($fams[0].b.window.windowMinutes // ""),
        (($fams[1].t.title // "") | [scan("[A-Za-z0-9]")] | (.[0] // "?") | ascii_upcase),
        (if ($fams[1].t.usageKnown == false) then -1 else pct($fams[1].t.window.usedPercent) end),
        ($fams[1].t.window | rval), ($fams[1].t.window.windowMinutes // ""),
        (if ($fams[1].b.usageKnown == false) then -1 else pct($fams[1].b.window.usedPercent) end),
        ($fams[1].b.window | rval), ($fams[1].b.window.windowMinutes // "")
    ] | map(tostring) | join("\u001f")')

first_chunk=1
chunk_bg=$(showy_quota_palette bg)
stale_color=$(showy_quota_palette stale)
countdown_warn=$(showy_quota_palette countdown_warn)
while IFS=$'\x1f' read -r provider p_used p_reset p_window s_used s_reset s_window t_used t_reset t_window \
    rw_count \
    rw1_used rw1_reset rw1_window rw2_used rw2_reset rw2_window \
    rw3_used rw3_reset rw3_window rw4_used rw4_reset rw4_window \
    d2_count \
    f1_label f1t_used f1t_reset f1t_window f1b_used f1b_reset f1b_window \
    f2_label f2t_used f2t_reset f2t_window f2b_used f2b_reset f2b_window; do
    [[ -n "${provider}" ]] || continue

    p_remaining=0
    if (( p_used >= 0 )); then
        p_remaining=$((100 - p_used))
    fi
    s_remaining=0
    if (( s_used >= 0 )); then
        s_remaining=$((100 - s_used))
    fi
    t_remaining=0
    if (( t_used >= 0 )); then
        t_remaining=$((100 - t_used))
    fi

    sigil=$(showy_quota_provider_sigil "${provider}")

    minutes=""
    if [[ -n "${p_reset}" ]]; then
        minutes=$(showy_quota_minutes_until "${p_reset}" || true)
        if (( stale )) && [[ "${minutes}" == "0" ]]; then
            reset_epoch=$(showy_quota_reset_epoch "${p_reset}" || true)
            now_epoch=$(showy_quota_now_epoch)
            if [[ -n "${reset_epoch}" ]] && (( reset_epoch <= now_epoch )); then
                minutes=""
            fi
        fi
    fi
    if (( p_used >= 0 )); then
        countdown=$(showy_quota_primary_label "${minutes}" "${p_remaining}" "${p_reset}")
    else
        # No primary window at all: nothing consumed, nothing to count down.
        countdown='idle'
    fi

    time_color=$(showy_quota_palette countdown)
    if (( stale )); then
        time_color="${stale_color}"
    elif [[ -n "${minutes}" && "${minutes}" -lt "${SHOWY_QUOTA_TIME_WARN_MINUTES}" ]]; then
        time_color=$(showy_quota_palette countdown_warn)
    fi

    if (( first_chunk )); then first_chunk=0
    else tmux_style_text ' ' "$(showy_quota_palette bg)" "$(showy_quota_palette bg)"; fi

    marker_p_reset="${p_reset}"; marker_p_window="${p_window}"
    marker_s_reset="${s_reset}"; marker_s_window="${s_window}"
    marker_t_reset="${t_reset}"; marker_t_window="${t_window}"
    if (( stale )); then
        marker_p_reset=""; marker_p_window=""
        marker_s_reset=""; marker_s_window=""
        marker_t_reset=""; marker_t_window=""
    fi
    surface_color=$(showy_quota_palette surface)
    p_long=$(showy_quota_is_long_window "${p_window}")
    s_long=$(showy_quota_is_long_window "${s_window}")
    primary_color=$(showy_quota_window_color "${p_remaining}" "${p_long}")
    secondary_color=$(showy_quota_window_color "${s_remaining}" "${s_long}")

    has_tertiary=0
    [[ "${t_used}" =~ ^[0-9]+$ ]] && has_tertiary=1
    bar_mode=$(showy_quota_terminal_mode_for_provider "${provider}" "${rw_count:-0}" "${has_tertiary}")

    mono_color=""; mono_rem=""; mono_reset=""; mono_win=""; mono_present=""
    if [[ "${bar_mode}" == "mono4" ]]; then
        r1=0; [[ "${rw1_used}" =~ ^[0-9]+$ ]] && r1=$((100 - rw1_used))
        r2=0; [[ "${rw2_used}" =~ ^[0-9]+$ ]] && r2=$((100 - rw2_used))
        r3=0; [[ "${rw3_used}" =~ ^[0-9]+$ ]] && r3=$((100 - rw3_used))
        r4=0; [[ "${rw4_used}" =~ ^[0-9]+$ ]] && r4=$((100 - rw4_used))
        x1="${rw1_reset}"; w1="${rw1_window}"; x2="${rw2_reset}"; w2="${rw2_window}"
        x3="${rw3_reset}"; w3="${rw3_window}"; x4="${rw4_reset}"; w4="${rw4_window}"
        if (( stale )); then x1=""; w1=""; x2=""; w2=""; x3=""; w3=""; x4=""; w4=""; fi
        p1=0; [[ "${rw1_used}" =~ ^[0-9]+$ ]] && p1=1
        p2=0; [[ "${rw2_used}" =~ ^[0-9]+$ ]] && p2=1
        p3=0; [[ "${rw3_used}" =~ ^[0-9]+$ ]] && p3=1
        p4=0; [[ "${rw4_used}" =~ ^[0-9]+$ ]] && p4=1
        mono_rem=$(printf '%s\x1f%s\x1f%s\x1f%s' "${r1}" "${r2}" "${r3}" "${r4}")
        mono_reset=$(printf '%s\x1f%s\x1f%s\x1f%s' "${x1}" "${x2}" "${x3}" "${x4}")
        mono_win=$(printf '%s\x1f%s\x1f%s\x1f%s' "${w1}" "${w2}" "${w3}" "${w4}")
        mono_present=$(printf '%s\x1f%s\x1f%s\x1f%s' "${p1}" "${p2}" "${p3}" "${p4}")
    elif [[ "${bar_mode}" == "mono3" ]]; then
        p1=0; [[ "${p_used}" =~ ^[0-9]+$ ]] && p1=1
        p2=0; [[ "${s_used}" =~ ^[0-9]+$ ]] && p2=1
        p3=0; [[ "${t_used}" =~ ^[0-9]+$ ]] && p3=1
        mono_rem=$(printf '%s\x1f%s\x1f%s' "${p_remaining}" "${s_remaining}" "${t_remaining}")
        mono_reset=$(printf '%s\x1f%s\x1f%s' "${marker_p_reset}" "${marker_s_reset}" "${marker_t_reset}")
        mono_win=$(printf '%s\x1f%s\x1f%s' "${marker_p_window}" "${marker_s_window}" "${marker_t_window}")
        mono_present=$(printf '%s\x1f%s\x1f%s' "${p1}" "${p2}" "${p3}")
    fi
    if [[ -n "${mono_rem}" ]]; then
        mono_color=$(showy_quota_mono_chunk_color "${mono_rem}" "${mono_win}" "${mono_present}")
        primary_color="${mono_color}"
    fi
    if (( stale )); then
        primary_color="${stale_color}"; secondary_color="${stale_color}"; mono_color="${stale_color}"
    fi
    separator_fg="${chunk_bg}"
    separator_bg="${primary_color}"
    tmux_style_text "${CAP_LEFT}" "${primary_color}" "${chunk_bg}"
    tmux_style_text "${sigil}" "${chunk_bg}" "${primary_color}" bold
    tmux_style_text '▕' "${separator_fg}" "${separator_bg}"
    case "${bar_mode}" in
        mono3|mono4)
            showy_quota_mono_lane_bar tmux_style_text "${SHOWY_QUOTA_TMUX_BAR_WIDTH:-${SHOWY_QUOTA_ZELLIJ_BAR_WIDTH:-12}}" "${mono_color}" "${mono_rem}" "${mono_reset}" "${mono_win}" "${mono_present}"
            ;;
        dual2)
            f1tp=0; [[ "${f1t_used}" =~ ^[0-9]+$ ]] && f1tp=1
            f1bp=0; [[ "${f1b_used}" =~ ^[0-9]+$ ]] && f1bp=1
            f1tr=0; (( f1tp )) && f1tr=$((100 - f1t_used))
            f1br=0; (( f1bp )) && f1br=$((100 - f1b_used))
            f1tx="${f1t_reset}"; f1tw="${f1t_window}"; f1bx="${f1b_reset}"; f1bw="${f1b_window}"
            (( stale )) && { f1tx=""; f1tw=""; f1bx=""; f1bw=""; }
            fam1=$(printf '%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s' "${f1_label}" "${f1tr}" "${f1tx}" "${f1tw}" "${f1tp}" "${f1br}" "${f1bx}" "${f1bw}" "${f1bp}")
            if (( ${d2_count:-0} >= 2 )); then
                f2tp=0; [[ "${f2t_used}" =~ ^[0-9]+$ ]] && f2tp=1
                f2bp=0; [[ "${f2b_used}" =~ ^[0-9]+$ ]] && f2bp=1
                f2tr=0; (( f2tp )) && f2tr=$((100 - f2t_used))
                f2br=0; (( f2bp )) && f2br=$((100 - f2b_used))
                f2tx="${f2t_reset}"; f2tw="${f2t_window}"; f2bx="${f2b_reset}"; f2bw="${f2b_window}"
                (( stale )) && { f2tx=""; f2tw=""; f2bx=""; f2bw=""; }
                fam2=$(printf '%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s' "${f2_label}" "${f2tr}" "${f2tx}" "${f2tw}" "${f2tp}" "${f2br}" "${f2bx}" "${f2bw}" "${f2bp}")
                showy_quota_dual2_bar tmux_style_text "${SHOWY_QUOTA_TMUX_BAR_WIDTH:-${SHOWY_QUOTA_ZELLIJ_BAR_WIDTH:-12}}" "${fam1}" "${fam2}"
            elif (( ${d2_count:-0} >= 1 )); then
                showy_quota_dual2_bar tmux_style_text "${SHOWY_QUOTA_TMUX_BAR_WIDTH:-${SHOWY_QUOTA_ZELLIJ_BAR_WIDTH:-12}}" "${fam1}"
            else
                tmux_dual_metric_bar "${p_remaining}" "${s_remaining}" "${marker_p_reset}" "${marker_p_window}" "${marker_s_reset}" "${marker_s_window}" "${primary_color}" "${secondary_color}"
            fi
            ;;
        *)
            tmux_dual_metric_bar "${p_remaining}" "${s_remaining}" "${marker_p_reset}" "${marker_p_window}" "${marker_s_reset}" "${marker_s_window}" "${primary_color}" "${secondary_color}"
            ;;
    esac
    tmux_style_text "${countdown}" "${time_color}" "${surface_color}" bold
    tmux_style_text "${CAP_RIGHT}" "${surface_color}" "${chunk_bg}"
done <<< "${rows}"
if (( stale )); then
    tmux_style_text ' ' "$(showy_quota_palette bg)" "$(showy_quota_palette bg)"
    tmux_style_text "${SHOWY_QUOTA_STALE_GLYPH}" "${countdown_warn}" "${chunk_bg}" bold
fi
if (( degraded_cli )); then
    tmux_style_text ' ' "$(showy_quota_palette bg)" "$(showy_quota_palette bg)"
    tmux_style_text "${SHOWY_QUOTA_DEGRADED_CLI_GLYPH}" "${countdown_warn}" "${chunk_bg}" bold
fi
