#!/usr/bin/env bash
# showy-quota — tmux status-line strip driver.
#
# Reads cached CodexBar JSON via showy-quota-fetch and delegates terminal-strip
# rendering to showy-quota-render. Pass `--json <path|->` to render supplied JSON
# without fetching, stale markers, or degraded-source markers.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd -P)"
# shellcheck disable=SC1091
. "${REPO_ROOT}/lib/common.sh"

FETCH="${SHOWY_QUOTA_FETCH_BIN:-${SCRIPT_DIR}/showy-quota-fetch}"
FETCH="$(showy_quota_valid_bin "${FETCH}")" || FETCH="${SCRIPT_DIR}/showy-quota-fetch"

json_input=""
while (($#)); do
    case "$1" in
        --json)
            shift
            [[ $# -gt 0 ]] || showy_quota_die "--json requires path or -"
            json_input="$1"
            ;;
        -h|--help)
            printf '%s\n' \
                'Usage: showy-quota-tmux-bar [--json <path|->]' \
                '' \
                'Prints a tmux status-line usage strip.'
            exit 0
            ;;
        *) showy_quota_die "unknown argument: $1" ;;
    esac
    shift
done

tmux_fg() {
    printf '#[fg=#%s]' "$1"
}

print_ai_fallback() {
    tmux_fg "$(showy_quota_primary_palette unknown)"
    printf 'AI ?#[default]'
}


if ! RENDER_BIN="$(showy_quota_resolve_render_bin "${SCRIPT_DIR}" "${REPO_ROOT}")"; then
    print_ai_fallback
    printf 'showy-quota-render not found; run make render-bin\n' >&2
    exit 0
fi

showy_quota_export_config

if [[ -n "${json_input}" ]]; then
    json_source="${json_input}"
    if [[ "${json_input}" == "-" ]]; then
        json_input="$(mktemp "${TMPDIR:-/tmp}/showy-quota-json.XXXXXX")"
        trap 'rm -f -- "${json_input}"' EXIT
        cat > "${json_input}"
    fi
    [[ -f "${json_input}" ]] || showy_quota_die "JSON input is not a regular file: ${json_source}"
    showy_quota_json_valid "${json_input}" || showy_quota_die "JSON input is not valid quota data: ${json_source}"
    "${RENDER_BIN}" --format tmux --json "${json_input}"
    exit 0
fi

"${FETCH}" >/dev/null 2>&1 || true

if ! out=$("${RENDER_BIN}" --format tmux --from-cache 2>/dev/null); then
    out="$(print_ai_fallback)"
fi
printf '%s' "${out}"
