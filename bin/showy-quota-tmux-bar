#!/usr/bin/env bash
# showy-quota — tmux status-line markup renderer.
#
# Designed for use in `set -ag status-right ' #(showy-quota-tmux-bar)'`. Prints
# tmux-format markup with the same visible provider chunks as the Zellij strip.
# Multiple providers are separated by a styled single-cell gap.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/strip.sh"

showy_quota_have jq || showy_quota_die "jq is required"

FETCH="${SHOWY_QUOTA_FETCH_BIN:-${SCRIPT_DIR}/showy-quota-fetch}"
FETCH="$(showy_quota_valid_bin "${FETCH}")" || FETCH="${SCRIPT_DIR}/showy-quota-fetch"

# Default powerline caps: U+E0B6 (left half-circle) and U+E0B4 (right).
CAP_LEFT_DEFAULT=$'\ue0b6'
CAP_RIGHT_DEFAULT=$'\ue0b4'
CAP_LEFT="${SHOWY_QUOTA_CAP_LEFT-${CAP_LEFT_DEFAULT}}"
CAP_RIGHT="${SHOWY_QUOTA_CAP_RIGHT-${CAP_RIGHT_DEFAULT}}"
# tmux parses '#' as its format escape ('#[', '#{', '#(' ...). Double any '#'
# in the (user-supplied) caps so they render literally rather than as a
# style/expansion directive.
CAP_LEFT="${CAP_LEFT//#/##}"
CAP_RIGHT="${CAP_RIGHT//#/##}"

tmux_reset() { printf '#[default]'; }
tmux_dim() { printf '#[dim]'; }

tmux_style_text() {
    local text="$1" fg_hex="${2:-}" bg_hex="${3:-}" weight="${4:-}"
    local sep=""

    printf '#['
    if [[ -n "${fg_hex}" ]]; then
        printf 'fg=#%s' "${fg_hex}"
        sep=","
    fi
    if [[ -n "${bg_hex}" ]]; then
        printf '%sbg=#%s' "${sep}" "${bg_hex}"
        sep=","
    fi
    if [[ -n "${weight}" ]]; then
        printf '%s%s' "${sep}" "${weight}"
    fi
    printf ']%s' "${text}"
    tmux_reset
}

tmux_dual_metric_bar() {
    local p_remaining="$1" s_remaining="$2"
    local p_reset="$3" p_window="$4" s_reset="$5" s_window="$6"
    local primary_override="${7:-}" secondary_override="${8:-}"
    local width="${SHOWY_QUOTA_TMUX_BAR_WIDTH:-${SHOWY_QUOTA_ZELLIJ_BAR_WIDTH:-12}}"
    [[ "${width}" =~ ^[0-9]+$ ]] || width=12
    (( width < 8 )) && width=8
    (( width > 400 )) && width=400

    local primary_color secondary_color bg_color surface_color elapsed_color
    primary_color="${primary_override:-$(showy_quota_window_color "${p_remaining}" "$(showy_quota_is_long_window "${p_window}")")}"
    secondary_color="${secondary_override:-$(showy_quota_window_color "${s_remaining}" "$(showy_quota_is_long_window "${s_window}")")}"
    bg_color=$(showy_quota_palette bg)
    surface_color=$(showy_quota_palette surface)
    elapsed_color=$(showy_quota_palette elapsed)

    local p_fill s_fill p_marker s_marker i top_color bottom_color
    p_fill=$(showy_quota_filled_cells "${p_remaining}" "${width}")
    s_fill=$(showy_quota_filled_cells "${s_remaining}" "${width}")
    p_marker=$(showy_quota_elapsed_marker_cell "${p_reset}" "${p_window}" "${width}" || true)
    s_marker=$(showy_quota_elapsed_marker_cell "${s_reset}" "${s_window}" "${width}" || true)

    for (( i=0; i<width; i++ )); do
        # Top half = primary window, bottom half = secondary window; each row
        # shows its own pacing marker via the elapsed color.
        if [[ "${p_marker}" =~ ^[0-9]+$ && "${i}" == "${p_marker}" ]]; then top_color="${elapsed_color}"
        elif (( i < p_fill )); then top_color="${primary_color}"
        else top_color="${surface_color}"; fi

        if [[ "${s_marker}" =~ ^[0-9]+$ && "${i}" == "${s_marker}" ]]; then bottom_color="${elapsed_color}"
        elif (( i < s_fill )); then bottom_color="${secondary_color}"
        else bottom_color="${surface_color}"; fi

        tmux_style_text '▀' "${top_color}" "${bottom_color}"
    done
    tmux_style_text '▏' "${bg_color}" "${surface_color}"
}



# ── data load ──────────────────────────────────────────────────────

if ! data=$("${FETCH}" 2>/dev/null) || [[ -z "${data}" ]]; then
    tmux_style_text 'AI ?' "$(showy_quota_primary_palette unknown)"
    exit 0
fi

filtered=$(printf '%s' "${data}" | showy_quota_filter_renderable)
count=$(printf '%s' "${filtered}" | jq 'length')

if (( count == 0 )); then
    printf '%s' "$(tmux_dim)"; tmux_style_text 'AI idle' "$(showy_quota_primary_palette unknown)"
    exit 0
fi

stale=0
if showy_quota_cache_stale_for "${SHOWY_QUOTA_USAGE_FILE}"; then
    stale=1
fi
degraded_cli=0
if [[ "${SHOWY_QUOTA_DEGRADED_CLI:-}" == "1" ]] || { [[ -z "${SHOWY_QUOTA_DEGRADED_CLI:-}" ]] && showy_quota_cache_degraded_cli; }; then
    degraded_cli=1
fi

# Slots are semantic: primary/secondary/tertiary map to fixed rows and
# roles. A slot only counts when that exact window has a numeric
# usedPercent; missing slots stay -1/empty instead of shifting up.
rows=$(printf '%s' "${filtered}" | jq -r '
    def pct(x): if x == null then -1 else ([0, ([100, (x|tonumber|floor)] | min)] | max) end;
    def slot(w): if (w != null and (w.usedPercent | type == "number")) then w else null end;
    def wmin(w): (w.windowMinutes // null) | (if (type == "number" and . >= 0) then . else null end);
    def rval: (.resetsAt // .resetDescription // "");
    def flabel(t): ((t // "") | [scan("[A-Za-z0-9]")] | (.[0] // "?") | ascii_upcase);
    .[]
    | (slot(.usage.primary)) as $p
    | (slot(.usage.secondary)) as $s
    | (slot(.usage.tertiary)) as $t
    | select((.provider | type == "string" and length > 0)
        and ($p != null or $s != null or $t != null))
    | ([ $p, $s, $t ] | map(select(. != null))) as $slots
    | ((.usage.extraRateWindows // [])
        | map(select(.window != null and (.window.usedPercent | type == "number")))) as $ex
    | ([ $ex[] | [ wmin(.window), (.window.resetsAt // null) ] ]) as $exkeys
    | ([ $slots[] | select( [wmin(.), (.resetsAt // null)] as $k | (any($exkeys[]; . == $k) | not) ) ]) as $unmatched
    | (($ex | length) > 0 and ($unmatched | length) == 0) as $pooled
    | ($slots + [ $ex[] | select(.usageKnown != false) | .window ]) as $all
    | ([ range(0; ($all | length)) as $i
         | $all[$i] as $w
         | [wmin($w), ($w.resetsAt // null)] as $k
         | select(([ range(0; $i) as $j | [wmin($all[$j]), ($all[$j].resetsAt // null)] ] | index($k) | not))
         | $w ][0:4]) as $rw
    | ($unmatched | sort_by(wmin(.) // 1.0e18)) as $um
    | (if ($um | length) > 0 then
         [ { lbl: flabel(.provider),
             tu: pct($um[0].usedPercent), tr: ($um[0] | rval), tw: ($um[0].windowMinutes // ""),
             bu: (if ($um|length) > 1 then pct($um[-1].usedPercent) else -1 end),
             br: (if ($um|length) > 1 then ($um[-1] | rval) else "" end),
             bw: (if ($um|length) > 1 then ($um[-1].windowMinutes // "") else "" end) } ]
       else [] end) as $mainfam
    | ([range(0; ($ex | length); 2)]
       | map( . as $i | $ex[$i] as $tn | (if ($i + 1) < ($ex|length) then $ex[$i+1] else null end) as $bn
            | { lbl: flabel($tn.title),
                tu: (if ($tn.usageKnown == false) then -1 else pct($tn.window.usedPercent) end),
                tr: (if ($tn.usageKnown == false) then "" else ($tn.window | rval) end),
                tw: (if ($tn.usageKnown == false) then "" else ($tn.window.windowMinutes // "") end),
                bu: (if ($bn == null or $bn.usageKnown == false) then -1 else pct($bn.window.usedPercent) end),
                br: (if ($bn == null or $bn.usageKnown == false) then "" else ($bn.window | rval) end),
                bw: (if ($bn == null or $bn.usageKnown == false) then "" else ($bn.window.windowMinutes // "") end) } )) as $exfams
    | ($mainfam + $exfams) as $fams
    | [
        .provider,
        pct($p.usedPercent), ($p.resetsAt // $p.resetDescription // ""), ($p.windowMinutes // ""),
        pct($s.usedPercent), ($s.resetsAt // $s.resetDescription // ""), ($s.windowMinutes // ""),
        pct($t.usedPercent), ($t.resetsAt // $t.resetDescription // ""), ($t.windowMinutes // ""),
        (if $pooled then 1 else 0 end),
        ($fams | length),
        ($rw | length),
        pct($rw[0].usedPercent), ($rw[0].resetsAt // $rw[0].resetDescription // ""), ($rw[0].windowMinutes // ""),
        pct($rw[1].usedPercent), ($rw[1].resetsAt // $rw[1].resetDescription // ""), ($rw[1].windowMinutes // ""),
        pct($rw[2].usedPercent), ($rw[2].resetsAt // $rw[2].resetDescription // ""), ($rw[2].windowMinutes // ""),
        pct($rw[3].usedPercent), ($rw[3].resetsAt // $rw[3].resetDescription // ""), ($rw[3].windowMinutes // ""),
        ($fams[0].lbl // "?"), ($fams[0].tu // -1), ($fams[0].tr // ""), ($fams[0].tw // ""), ($fams[0].bu // -1), ($fams[0].br // ""), ($fams[0].bw // ""),
        ($fams[1].lbl // "?"), ($fams[1].tu // -1), ($fams[1].tr // ""), ($fams[1].tw // ""), ($fams[1].bu // -1), ($fams[1].br // ""), ($fams[1].bw // "")
    ] | map(tostring) | join("\u001f")')

first_chunk=1
chunk_bg=$(showy_quota_palette bg)
stale_color=$(showy_quota_palette stale)
countdown_warn=$(showy_quota_palette countdown_warn)
tmux_width="${SHOWY_QUOTA_TMUX_BAR_WIDTH:-${SHOWY_QUOTA_ZELLIJ_BAR_WIDTH:-12}}"

# Render one provider widget from the current row globals. Reused for normal
# providers and for each synthetic per-family dual when a pooled provider splits.
emit_chunk() {
    local p_remaining=0 s_remaining=0 t_remaining=0
    if (( p_used >= 0 )); then p_remaining=$((100 - p_used)); fi
    if (( s_used >= 0 )); then s_remaining=$((100 - s_used)); fi
    if (( t_used >= 0 )); then t_remaining=$((100 - t_used)); fi

    local minutes=""
    if [[ -n "${p_reset}" ]]; then
        minutes=$(showy_quota_minutes_until "${p_reset}" || true)
        if (( stale )) && [[ "${minutes}" == "0" ]]; then
            local r_epoch n_epoch
            r_epoch=$(showy_quota_reset_epoch "${p_reset}" || true)
            n_epoch=$(showy_quota_now_epoch)
            if [[ -n "${r_epoch}" ]] && (( r_epoch <= n_epoch )); then minutes=""; fi
        fi
    fi
    local countdown
    if (( p_used >= 0 )); then
        countdown=$(showy_quota_primary_label "${minutes}" "${p_remaining}" "${p_reset}")
    else
        countdown='idle'
    fi
    local time_color
    time_color=$(showy_quota_palette countdown)
    if (( stale )); then
        time_color="${stale_color}"
    elif [[ -n "${minutes}" && "${minutes}" -lt "${SHOWY_QUOTA_TIME_WARN_MINUTES}" ]]; then
        time_color=$(showy_quota_palette countdown_warn)
    fi

    local marker_p_reset="${p_reset}" marker_p_window="${p_window}"
    local marker_s_reset="${s_reset}" marker_s_window="${s_window}"
    local marker_t_reset="${t_reset}" marker_t_window="${t_window}"
    if (( stale )); then
        marker_p_reset=""; marker_p_window=""
        marker_s_reset=""; marker_s_window=""
        marker_t_reset=""; marker_t_window=""
    fi
    local surface_color; surface_color=$(showy_quota_palette surface)
    local p_present=0 s_present=0 t_present=0
    [[ "${p_used}" =~ ^[0-9]+$ ]] && p_present=1
    [[ "${s_used}" =~ ^[0-9]+$ ]] && s_present=1
    [[ "${t_used}" =~ ^[0-9]+$ ]] && t_present=1
    local shared_cycle=0
    if showy_quota_shared_cycle \
        "${p_present}" "${p_reset}" "${p_window}" \
        "${s_present}" "${s_reset}" "${s_window}" \
        "${t_present}" "${t_reset}" "${t_window}"; then
        shared_cycle=1
        marker_s_reset=""; marker_s_window=""
    fi
    local p_long s_long
    p_long=$(showy_quota_is_long_window "${p_window}")
    s_long=$(showy_quota_is_long_window "${s_window}")
    if (( shared_cycle )); then p_long=0; s_long=0; fi
    local primary_color secondary_color
    primary_color=$(showy_quota_window_color "${p_remaining}" "${p_long}")
    secondary_color=$(showy_quota_window_color "${s_remaining}" "${s_long}")

    local has_tertiary=0
    [[ "${t_used}" =~ ^[0-9]+$ ]] && has_tertiary=1
    local bar_mode
    bar_mode=$(showy_quota_terminal_mode_for_provider "${provider}" "${has_tertiary}" "${pooled:-0}" "${rw_count:-0}")

    local mono_color="" mono_rem="" mono_reset="" mono_win="" mono_present=""
    if [[ "${bar_mode}" == "mono4" ]] && (( ${rw_count:-0} >= 4 )); then
        local a1=0 pa1=0 a2=0 pa2=0 a3=0 pa3=0 a4=0 pa4=0
        local family_lane_count=0
        [[ "${f1t_used}" =~ ^[0-9]+$ ]] && family_lane_count=$((family_lane_count + 1))
        [[ "${f1b_used}" =~ ^[0-9]+$ ]] && family_lane_count=$((family_lane_count + 1))
        [[ "${f2t_used}" =~ ^[0-9]+$ ]] && family_lane_count=$((family_lane_count + 1))
        [[ "${f2b_used}" =~ ^[0-9]+$ ]] && family_lane_count=$((family_lane_count + 1))
        local bx1 bx2 bx3 bx4 bw1 bw2 bw3 bw4
        if (( family_lane_count >= 4 )); then
            [[ "${f1t_used}" =~ ^[0-9]+$ ]] && { a1=$((100 - f1t_used)); pa1=1; }
            [[ "${f1b_used}" =~ ^[0-9]+$ ]] && { a2=$((100 - f1b_used)); pa2=1; }
            [[ "${f2t_used}" =~ ^[0-9]+$ ]] && { a3=$((100 - f2t_used)); pa3=1; }
            [[ "${f2b_used}" =~ ^[0-9]+$ ]] && { a4=$((100 - f2b_used)); pa4=1; }
            bx1="${f1t_reset}"; bw1="${f1t_window}"; bx2="${f1b_reset}"; bw2="${f1b_window}"
            bx3="${f2t_reset}"; bw3="${f2t_window}"; bx4="${f2b_reset}"; bw4="${f2b_window}"
        else
            [[ "${rw1_used}" =~ ^[0-9]+$ ]] && { a1=$((100 - rw1_used)); pa1=1; }
            [[ "${rw2_used}" =~ ^[0-9]+$ ]] && { a2=$((100 - rw2_used)); pa2=1; }
            [[ "${rw3_used}" =~ ^[0-9]+$ ]] && { a3=$((100 - rw3_used)); pa3=1; }
            [[ "${rw4_used}" =~ ^[0-9]+$ ]] && { a4=$((100 - rw4_used)); pa4=1; }
            bx1="${rw1_reset}"; bw1="${rw1_window}"; bx2="${rw2_reset}"; bw2="${rw2_window}"
            bx3="${rw3_reset}"; bw3="${rw3_window}"; bx4="${rw4_reset}"; bw4="${rw4_window}"
        fi
        (( stale )) && { bx1=""; bw1=""; bx2=""; bw2=""; bx3=""; bw3=""; bx4=""; bw4=""; }
        mono_rem=$(printf '%s\x1f%s\x1f%s\x1f%s' "${a1}" "${a2}" "${a3}" "${a4}")
        mono_reset=$(printf '%s\x1f%s\x1f%s\x1f%s' "${bx1}" "${bx2}" "${bx3}" "${bx4}")
        mono_win=$(printf '%s\x1f%s\x1f%s\x1f%s' "${bw1}" "${bw2}" "${bw3}" "${bw4}")
        mono_present=$(printf '%s\x1f%s\x1f%s\x1f%s' "${pa1}" "${pa2}" "${pa3}" "${pa4}")
    elif [[ "${bar_mode}" == "mono3" ]]; then
        local p1=0 p2=0 p3=0 m1="${p_remaining}" m2="${s_remaining}" m3="${t_remaining}"
        local x1="${marker_p_reset}" w1="${marker_p_window}" x2="${marker_s_reset}" w2="${marker_s_window}" x3="${marker_t_reset}" w3="${marker_t_window}"
        if (( ! has_tertiary )) && (( ${rw_count:-0} >= 3 )); then
            [[ "${rw1_used}" =~ ^[0-9]+$ ]] && { m1=$((100 - rw1_used)); p1=1; }
            [[ "${rw2_used}" =~ ^[0-9]+$ ]] && { m2=$((100 - rw2_used)); p2=1; }
            [[ "${rw3_used}" =~ ^[0-9]+$ ]] && { m3=$((100 - rw3_used)); p3=1; }
            x1="${rw1_reset}"; w1="${rw1_window}"; x2="${rw2_reset}"; w2="${rw2_window}"; x3="${rw3_reset}"; w3="${rw3_window}"
        else
            [[ "${p_used}" =~ ^[0-9]+$ ]] && p1=1
            [[ "${s_used}" =~ ^[0-9]+$ ]] && p2=1
            [[ "${t_used}" =~ ^[0-9]+$ ]] && p3=1
        fi
        mono_rem=$(printf '%s\x1f%s\x1f%s' "${m1}" "${m2}" "${m3}")
        mono_reset=$(printf '%s\x1f%s\x1f%s' "${x1}" "${x2}" "${x3}")
        mono_win=$(printf '%s\x1f%s\x1f%s' "${w1}" "${w2}" "${w3}")
        mono_present=$(printf '%s\x1f%s\x1f%s' "${p1}" "${p2}" "${p3}")
    fi
    if [[ -n "${mono_rem}" ]]; then
        mono_color=$(showy_quota_mono_chunk_color "${mono_rem}" "${mono_win}" "${mono_present}" "${shared_cycle}")
        primary_color="${mono_color}"
    fi
    if (( stale )); then
        primary_color="${stale_color}"; secondary_color="${stale_color}"; mono_color="${stale_color}"
    fi
    tmux_style_text "${CAP_LEFT}" "${primary_color}" "${chunk_bg}"
    tmux_style_text "${sigil}" "${chunk_bg}" "${primary_color}" bold
    tmux_style_text '▕' "${chunk_bg}" "${primary_color}"
    if [[ -n "${mono_rem}" ]]; then
        showy_quota_mono_lane_bar tmux_style_text "${tmux_width}" "${mono_color}" "${mono_rem}" "${mono_reset}" "${mono_win}" "${mono_present}"
    else
        tmux_dual_metric_bar "${p_remaining}" "${s_remaining}" "${marker_p_reset}" "${marker_p_window}" "${marker_s_reset}" "${marker_s_window}" "${primary_color}" "${secondary_color}"
    fi
    tmux_style_text "${countdown}" "${time_color}" "${surface_color}" bold
    tmux_style_text "${CAP_RIGHT}" "${surface_color}" "${chunk_bg}"
}

space_chunk() {
    if (( first_chunk )); then first_chunk=0
    else tmux_style_text ' ' "${chunk_bg}" "${chunk_bg}"; fi
}

while IFS=$'\x1f' read -r provider p_used p_reset p_window s_used s_reset s_window t_used t_reset t_window \
    pooled d2_count rw_count \
    rw1_used rw1_reset rw1_window rw2_used rw2_reset rw2_window rw3_used rw3_reset rw3_window rw4_used rw4_reset rw4_window \
    f1_label f1t_used f1t_reset f1t_window f1b_used f1b_reset f1b_window \
    f2_label f2t_used f2t_reset f2t_window f2b_used f2b_reset f2b_window; do
    [[ -n "${provider}" ]] || continue
    row_has_tertiary=0
    [[ "${t_used}" =~ ^[0-9]+$ ]] && row_has_tertiary=1
    row_mode=$(showy_quota_terminal_mode_for_provider "${provider}" "${row_has_tertiary}" "${pooled:-0}" "${rw_count:-0}")
    if [[ "${row_mode}" == "dual2" ]] && (( ${d2_count:-0} >= 2 )); then
        # Split a model-pooled provider into one standalone dual per family.
        base_sigil=$(showy_quota_provider_sigil "${provider}")
        sigil="${base_sigil}$(showy_quota_superscript "${f1_label}")"
        p_used="${f1t_used}"; p_reset="${f1t_reset}"; p_window="${f1t_window}"
        s_used="${f1b_used}"; s_reset="${f1b_reset}"; s_window="${f1b_window}"
        t_used="-1"; t_reset=""; t_window=""; pooled=0; d2_count=0
        space_chunk; emit_chunk
        sigil="${base_sigil}$(showy_quota_superscript "${f2_label}")"
        p_used="${f2t_used}"; p_reset="${f2t_reset}"; p_window="${f2t_window}"
        s_used="${f2b_used}"; s_reset="${f2b_reset}"; s_window="${f2b_window}"
        t_used="-1"; t_reset=""; t_window=""; pooled=0; d2_count=0
        space_chunk; emit_chunk
    else
        sigil=$(showy_quota_provider_sigil "${provider}")
        space_chunk; emit_chunk
    fi
done < <(printf '%s\n' "${rows}")
if (( stale )); then
    tmux_style_text ' ' "$(showy_quota_palette bg)" "$(showy_quota_palette bg)"
    tmux_style_text "${SHOWY_QUOTA_STALE_GLYPH}" "${countdown_warn}" "${chunk_bg}" bold
fi
if (( degraded_cli )); then
    tmux_style_text ' ' "$(showy_quota_palette bg)" "$(showy_quota_palette bg)"
    tmux_style_text "${SHOWY_QUOTA_DEGRADED_CLI_GLYPH}" "${countdown_warn}" "${chunk_bg}" bold
fi
