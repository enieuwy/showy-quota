#!/usr/bin/env bash
# showy-quota — tmux status-line markup renderer.
#
# Designed for use in `set -ag status-right ' #(showy-quota-tmux-bar)'`. Prints
# tmux-format markup with the same visible provider chunks as the Zellij strip.
# Multiple providers are separated by a styled single-cell gap.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/strip.sh"

showy_quota_have jq || showy_quota_die "jq is required"

FETCH="${SHOWY_QUOTA_FETCH_BIN:-${SCRIPT_DIR}/showy-quota-fetch}"

CAP_LEFT="${SHOWY_QUOTA_CAP_LEFT-}"
CAP_RIGHT="${SHOWY_QUOTA_CAP_RIGHT-}"

tmux_reset() { printf '#[default]'; }
tmux_dim() { printf '#[dim]'; }

tmux_style_text() {
    local text="$1" fg_hex="${2:-}" bg_hex="${3:-}" weight="${4:-}"
    local sep=""

    printf '#['
    if [[ -n "${fg_hex}" ]]; then
        printf 'fg=#%s' "${fg_hex}"
        sep=","
    fi
    if [[ -n "${bg_hex}" ]]; then
        printf '%sbg=#%s' "${sep}" "${bg_hex}"
        sep=","
    fi
    if [[ -n "${weight}" ]]; then
        printf '%s%s' "${sep}" "${weight}"
    fi
    printf ']%s' "${text}"
    tmux_reset
}

tmux_dual_metric_bar() {
    local p_remaining="$1" s_remaining="$2" s_reset="$3" s_window="$4"
    local primary_override="${5:-}" secondary_override="${6:-}"
    local width="${SHOWY_QUOTA_TMUX_BAR_WIDTH:-${SHOWY_QUOTA_ZELLIJ_BAR_WIDTH:-12}}"
    [[ "${width}" =~ ^[0-9]+$ ]] || width=12
    (( width < 8 )) && width=8

    local primary_color secondary_color bg_color surface_color elapsed_color
    primary_color="${primary_override:-$(showy_quota_role_color primary "${p_remaining}")}"
    secondary_color="${secondary_override:-$(showy_quota_role_color secondary "${s_remaining}")}"
    bg_color=$(showy_quota_palette bg)
    surface_color=$(showy_quota_palette surface)
    elapsed_color=$(showy_quota_palette elapsed)

    local p_fill s_fill marker i top_color bottom_color
    p_fill=$(showy_quota_filled_cells "${p_remaining}" "${width}")
    s_fill=$(showy_quota_filled_cells "${s_remaining}" "${width}")
    marker=$(showy_quota_elapsed_marker_cell "${s_reset}" "${s_window}" "${width}" || true)

    for (( i=0; i<width; i++ )); do
        if (( i < p_fill )); then top_color="${primary_color}"
        else top_color="${surface_color}"; fi

        if (( i < s_fill )); then bottom_color="${secondary_color}"
        else bottom_color="${surface_color}"; fi

        if [[ "${marker}" =~ ^[0-9]+$ && "${i}" == "${marker}" ]]; then
            tmux_style_text '▀' "${top_color}" "${elapsed_color}"
        else
            tmux_style_text '▀' "${top_color}" "${bottom_color}"
        fi
    done
    tmux_style_text '▏' "${bg_color}" "${surface_color}"
}

tmux_tri_metric_bar() {
    local p_remaining="$1" s_remaining="$2" t_remaining="$3"
    local primary_override="${4:-}" secondary_override="${5:-}" tertiary_override="${6:-}"
    local width="${SHOWY_QUOTA_TMUX_BAR_WIDTH:-${SHOWY_QUOTA_ZELLIJ_BAR_WIDTH:-12}}"
    [[ "${width}" =~ ^[0-9]+$ ]] || width=12
    (( width < 8 )) && width=8

    local primary_color secondary_color tertiary_color bg_color surface_color
    primary_color="${primary_override:-$(showy_quota_role_color primary "${p_remaining}")}"
    secondary_color="${secondary_override:-$(showy_quota_role_color secondary "${s_remaining}")}"
    tertiary_color="${tertiary_override:-$(showy_quota_role_color tertiary "${t_remaining}")}"
    bg_color=$(showy_quota_palette bg)
    surface_color=$(showy_quota_palette surface)

    local p_fill s_fill t_fill i mask char cell_color
    p_fill=$(showy_quota_filled_cells "${p_remaining}" "${width}")
    s_fill=$(showy_quota_filled_cells "${s_remaining}" "${width}")
    t_fill=$(showy_quota_filled_cells "${t_remaining}" "${width}")

    for (( i=0; i<width; i++ )); do
        mask=0
        (( i < p_fill )) && mask=$((mask | 1))
        (( i < s_fill )) && mask=$((mask | 2))
        (( i < t_fill )) && mask=$((mask | 4))
        char=$(showy_quota_sextant_mask_char "${mask}")

        if (( mask & 4 )); then cell_color="${tertiary_color}"
        elif (( mask & 2 )); then cell_color="${secondary_color}"
        elif (( mask & 1 )); then cell_color="${primary_color}"
        else cell_color="${surface_color}"; fi

        tmux_style_text "${char}" "${cell_color}" "${surface_color}"
    done
    tmux_style_text '▏' "${bg_color}" "${surface_color}"
}

tmux_tri_metric_bar_mono() {
    local p_remaining="$1" s_remaining="$2" t_remaining="$3"
    local p_used="$4" p_reset="$5" p_window="$6"
    local s_used="$7" s_reset="$8" s_window="$9"
    local t_used="${10}" t_reset="${11}" t_window="${12}"
    local mono_override="${13:-}"
    local width="${SHOWY_QUOTA_TMUX_BAR_WIDTH:-${SHOWY_QUOTA_ZELLIJ_BAR_WIDTH:-12}}"
    [[ "${width}" =~ ^[0-9]+$ ]] || width=12
    (( width < 8 )) && width=8

    local mono_color bg_color surface_color elapsed_color
    mono_color="${mono_override:-$(showy_quota_mono3_color "${p_remaining}" "${s_remaining}" "${t_remaining}" "${p_used}" "${s_used}" "${t_used}")}"
    bg_color=$(showy_quota_palette bg)
    surface_color=$(showy_quota_palette surface)
    elapsed_color=$(showy_quota_palette elapsed)

    local p_fill s_fill t_fill marker i mask char cell_color
    p_fill=$(showy_quota_filled_cells "${p_remaining}" "${width}")
    s_fill=$(showy_quota_filled_cells "${s_remaining}" "${width}")
    t_fill=$(showy_quota_filled_cells "${t_remaining}" "${width}")
    marker=$(showy_quota_mono3_marker_boundary "${width}" \
        "${p_used}" "${p_reset}" "${p_window}" \
        "${s_used}" "${s_reset}" "${s_window}" \
        "${t_used}" "${t_reset}" "${t_window}" || true)

    if [[ "${SHOWY_QUOTA_MONO3_MARKER_STYLE:-replace}" == "replace" && "${marker}" == "${width}" ]]; then
        marker=$((width - 1))
    fi

    for (( i=0; i<width; i++ )); do
        if [[ "${marker}" =~ ^[0-9]+$ && "${i}" == "${marker}" ]]; then
            tmux_style_text '│' "${elapsed_color}" "${surface_color}"
            if [[ "${SHOWY_QUOTA_MONO3_MARKER_STYLE:-replace}" == "replace" ]]; then
                continue
            fi
        fi

        mask=0
        (( i < p_fill )) && mask=$((mask | 1))
        (( i < s_fill )) && mask=$((mask | 2))
        (( i < t_fill )) && mask=$((mask | 4))
        char=$(showy_quota_sextant_mask_char "${mask}")

        if (( mask == 0 )); then cell_color="${surface_color}"
        else cell_color="${mono_color}"; fi

        tmux_style_text "${char}" "${cell_color}" "${surface_color}"
    done
    if [[ "${SHOWY_QUOTA_MONO3_MARKER_STYLE:-replace}" != "replace" && "${marker}" =~ ^[0-9]+$ && "${marker}" == "${width}" ]]; then
        tmux_style_text '│' "${elapsed_color}" "${surface_color}"
    fi
    tmux_style_text '▏' "${bg_color}" "${surface_color}"
}


# ── data load ──────────────────────────────────────────────────────

if ! data=$("${FETCH}" 2>/dev/null) || [[ -z "${data}" ]]; then
    tmux_style_text 'AI ?' "$(showy_quota_role_palette primary unknown)"
    exit 0
fi

filtered=$(printf '%s' "${data}" | showy_quota_filter_renderable)
count=$(printf '%s' "${filtered}" | jq 'length')

if (( count == 0 )); then
    printf '%s' "$(tmux_dim)"; tmux_style_text 'AI idle' "$(showy_quota_role_palette primary unknown)"
    exit 0
fi

stale=0
if showy_quota_cache_stale_for "${SHOWY_QUOTA_USAGE_FILE}"; then
    stale=1
fi
degraded_cli=0
if [[ "${SHOWY_QUOTA_DEGRADED_CLI:-}" == "1" ]] || { [[ -z "${SHOWY_QUOTA_DEGRADED_CLI:-}" ]] && showy_quota_cache_degraded_cli; }; then
    degraded_cli=1
fi

# Slots are semantic: primary/secondary/tertiary map to fixed rows and
# roles. A slot only counts when that exact window has a numeric
# usedPercent; missing slots stay -1/empty instead of shifting up.
rows=$(printf '%s' "${filtered}" | jq -r '
    def pct(x): if x == null then -1 else ([0, ([100, (x|tonumber|floor)] | min)] | max) end;
    def slot(w): if (w != null and (w.usedPercent | type == "number")) then w else null end;
    .[]
    | (slot(.usage.primary)) as $p
    | (slot(.usage.secondary)) as $s
    | (slot(.usage.tertiary)) as $t
    | select((.provider | type == "string" and length > 0)
        and ($p != null or $s != null or $t != null))
    | [
        .provider,
        pct($p.usedPercent),
        ($p.resetsAt // $p.resetDescription // ""),
        ($p.windowMinutes // ""),
        pct($s.usedPercent),
        ($s.resetsAt // $s.resetDescription // ""),
        ($s.windowMinutes // ""),
        pct($t.usedPercent),
        ($t.resetsAt // $t.resetDescription // ""),
        ($t.windowMinutes // "")
    ] | map(tostring) | join("\u001f")')

first_chunk=1
chunk_bg=$(showy_quota_palette bg)
stale_color=$(showy_quota_palette stale)
countdown_warn=$(showy_quota_palette countdown_warn)
while IFS=$'\x1f' read -r provider p_used p_reset p_window s_used s_reset s_window t_used t_reset t_window; do
    [[ -n "${provider}" ]] || continue

    p_remaining=0
    if (( p_used >= 0 )); then
        p_remaining=$((100 - p_used))
    fi
    s_remaining=0
    if (( s_used >= 0 )); then
        s_remaining=$((100 - s_used))
    fi
    t_remaining=0
    if (( t_used >= 0 )); then
        t_remaining=$((100 - t_used))
    fi

    sigil=$(showy_quota_provider_sigil "${provider}")

    minutes=""
    if [[ -n "${p_reset}" ]]; then
        minutes=$(showy_quota_minutes_until "${p_reset}" || true)
        if (( stale )) && [[ "${minutes}" == "0" ]]; then
            reset_epoch=$(showy_quota_reset_epoch "${p_reset}" || true)
            now_epoch=$(showy_quota_now_epoch)
            if [[ -n "${reset_epoch}" ]] && (( reset_epoch <= now_epoch )); then
                minutes=""
            fi
        fi
    fi
    if (( p_used >= 0 )); then
        countdown=$(showy_quota_primary_label "${minutes}" "${p_remaining}" "${p_reset}")
    else
        # No primary window at all: nothing consumed, nothing to count down.
        countdown='idle'
    fi

    time_color=$(showy_quota_palette countdown)
    if (( stale )); then
        time_color="${stale_color}"
    elif [[ -n "${minutes}" && "${minutes}" -lt "${SHOWY_QUOTA_TIME_WARN_MINUTES}" ]]; then
        time_color=$(showy_quota_palette countdown_warn)
    fi

    if (( first_chunk )); then first_chunk=0
    else tmux_style_text ' ' "$(showy_quota_palette bg)" "$(showy_quota_palette bg)"; fi

    marker_p_reset="${p_reset}"
    marker_p_window="${p_window}"
    marker_s_reset="${s_reset}"
    marker_s_window="${s_window}"
    marker_t_reset="${t_reset}"
    marker_t_window="${t_window}"
    if (( stale )); then
        marker_p_reset=""
        marker_p_window=""
        marker_s_reset=""
        marker_s_window=""
        marker_t_reset=""
        marker_t_window=""
    fi

    surface_color=$(showy_quota_palette surface)
    primary_color=$(showy_quota_role_color primary "${p_remaining}")
    secondary_color=$(showy_quota_role_color secondary "${s_remaining}")
    tertiary_color=$(showy_quota_role_color tertiary "${t_remaining}")
    bar_mode=$(showy_quota_terminal_mode_for_provider "${provider}" \
        "${p_used}" "${p_reset}" "${p_window}" \
        "${s_used}" "${s_reset}" "${s_window}" \
        "${t_used}" "${t_reset}" "${t_window}")
    mono_color=""
    if [[ "${bar_mode}" == "mono3" ]]; then
        mono_color=$(showy_quota_mono3_color "${p_remaining}" "${s_remaining}" "${t_remaining}" "${p_used}" "${s_used}" "${t_used}")
        primary_color="${mono_color}"
    fi
    if (( stale )); then
        primary_color="${stale_color}"
        secondary_color="${stale_color}"
        tertiary_color="${stale_color}"
        mono_color="${stale_color}"
    fi
    separator_fg="${chunk_bg}"
    separator_bg="${primary_color}"
    tmux_style_text "${CAP_LEFT}" "${primary_color}" "${chunk_bg}"
    tmux_style_text "${sigil}" "${chunk_bg}" "${primary_color}" bold
    tmux_style_text '▕' "${separator_fg}" "${separator_bg}"
    case "${bar_mode}" in
        sextant3)
            tmux_tri_metric_bar "${p_remaining}" "${s_remaining}" "${t_remaining}" "${primary_color}" "${secondary_color}" "${tertiary_color}"
            ;;
        mono3)
            tmux_tri_metric_bar_mono "${p_remaining}" "${s_remaining}" "${t_remaining}" \
                "${p_used}" "${marker_p_reset}" "${marker_p_window}" \
                "${s_used}" "${marker_s_reset}" "${marker_s_window}" \
                "${t_used}" "${marker_t_reset}" "${marker_t_window}" \
                "${mono_color}"
            ;;
        *)
            tmux_dual_metric_bar "${p_remaining}" "${s_remaining}" "${marker_s_reset}" "${marker_s_window}" "${primary_color}" "${secondary_color}"
            ;;
    esac
    tmux_style_text "${countdown}" "${time_color}" "${surface_color}" bold
    tmux_style_text "${CAP_RIGHT}" "${surface_color}" "${chunk_bg}"
done <<< "${rows}"
if (( stale )); then
    tmux_style_text ' ' "$(showy_quota_palette bg)" "$(showy_quota_palette bg)"
    tmux_style_text "${SHOWY_QUOTA_STALE_GLYPH}" "${countdown_warn}" "${chunk_bg}" bold
fi
if (( degraded_cli )); then
    tmux_style_text ' ' "$(showy_quota_palette bg)" "$(showy_quota_palette bg)"
    tmux_style_text "${SHOWY_QUOTA_DEGRADED_CLI_GLYPH}" "${countdown_warn}" "${chunk_bg}" bold
fi
