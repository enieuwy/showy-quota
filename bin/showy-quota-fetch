#!/usr/bin/env bash
# showy-quota — shared CodexBar JSON fetcher.
#
# Returns cached CodexBar usage JSON.
# Refreshes the cache when older than SHOWY_QUOTA_REFRESH_SECONDS, atomically.
# Refreshes read /usage from the default localhost `codexbar serve` endpoint
# first; set SHOWY_QUOTA_CODEXBAR_SERVE_URL= to skip the HTTP probe.
# Always prints the most recent good cache when refresh fails.
#
# Exit 0 whenever any cache content was emitted (fresh or stale).
# Exit 1 only when no cache exists and the first fetch fails.
#
# Flags:
#   --refresh   Force a refresh regardless of cache age.
#   --json      Default. Print the cached JSON.
#   --cache-only Print existing valid cache without refreshing.
#   --age       Print cache age in seconds and exit.
#   --path      Print the cache file path and exit.
#   --stop-serve Stop the managed codexbar serve process and exit.
# This script is intentionally narrow: every renderer (zellij, tmux,
# sketchybar) reads from the same cache file so we never fan out N parallel
# `codexbar` invocations.

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../lib/common.sh"

mode="json"
force_refresh=0
stop_serve=0
while (($#)); do
    case "$1" in
        --refresh) force_refresh=1 ;;
        --json)    mode="json" ;;
        --cache-only) mode="cache-only" ;;
        --age)     mode="age" ;;
        --path)    mode="path" ;;
        --stop-serve) stop_serve=1 ;;
        -h|--help)
            sed -n '2,19p' "$0"
            exit 0
            ;;
        *) showy_quota_die "unknown argument: $1" ;;
    esac
    shift
done

(umask 077 && mkdir -p "${SHOWY_QUOTA_CACHE_DIR}")
chmod 700 "${SHOWY_QUOTA_CACHE_DIR}" 2>/dev/null || true
# Refuse to publish into a cache dir another user could tamper with: a
# world/group-writable or foreign-owned dir lets a local attacker inject
# usage.json/status.url that drive SketchyBar clicks and automation consumers.
if ! showy_quota_dir_is_private "${SHOWY_QUOTA_CACHE_DIR}"; then
    showy_quota_die "refusing to use unsafe cache dir: ${SHOWY_QUOTA_CACHE_DIR} (must be owned by you and not group/other-writable)"
fi
SHOWY_QUOTA_MANAGED_SERVE_RESTART_ATTEMPTED=0

stop_managed_serve() {
    local pid="" start_epoch="" basename_rec=""
    if ! managed_serve_valid_pidfile pid start_epoch basename_rec; then
        rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}"
        return 0
    fi
    if ! terminate_managed_serve_pid "${pid}" "${start_epoch}" "${basename_rec}"; then
        showy_quota_log "managed codexbar serve pid ${pid} did not exit; retaining pidfile"
        return 1
    fi
    rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}"
    showy_quota_log "stopped managed codexbar serve pid ${pid}"
    return 0
}

if [[ "${mode}" == "path" ]]; then
    printf '%s\n' "${SHOWY_QUOTA_USAGE_FILE}"
    exit 0
fi

if [[ "${mode}" == "age" ]]; then
    showy_quota_age_seconds "${SHOWY_QUOTA_USAGE_FILE}"
    exit 0
fi

# ── locking primitives ────────────────────────────────────────────────

# The mkdir lease is authoritative on every host. It serializes fetchers even
# when one has flock installed and another does not. The lease owner updates a
# heartbeat during long refresh work; live owners are not reclaimed merely
# because a refresh exceeds its normal cadence.
#
# Returns:
#   0 = lock was held and the callee ran;
#   2 = lock was held by another worker; caller may wait for cache;
#   3 = mkdir lock owner is ambiguous; caller should wait then retry recovery.
SHOWY_QUOTA_HELD_LOCK_DIR=""
SHOWY_QUOTA_CACHE_TMP_FILES=()

showy_quota_touch_mkdir_lock_heartbeat() {
    local lock_dir="${SHOWY_QUOTA_HELD_LOCK_DIR:-}"
    local owner_file="" heartbeat_file="" owner_pid=""
    [[ -n "${lock_dir}" ]] || return 0
    owner_file="${lock_dir}/owner.pid"
    heartbeat_file="${lock_dir}/owner.heartbeat"
    if [[ -r "${owner_file}" ]] \
        && IFS= read -r owner_pid < "${owner_file}" \
        && [[ "${owner_pid}" == "$$" ]]
    then
        : > "${heartbeat_file}" 2>/dev/null || true
    fi
}

# Publication fence: a holder whose mkdir lease was reclaimed (stale
# heartbeat after the long absolute bound) must not publish a cache
# generation over the new owner's work. With no held lease (direct callers
# outside the refresh lock) publication is permitted unchanged.
showy_quota_refresh_lease_still_owned() {
    local lock_dir="${SHOWY_QUOTA_HELD_LOCK_DIR:-}" owner_pid=""
    [[ -n "${lock_dir}" ]] || return 0
    if [[ -r "${lock_dir}/owner.pid" ]] \
        && IFS= read -r owner_pid < "${lock_dir}/owner.pid" \
        && [[ "${owner_pid}" == "$$" ]]
    then
        return 0
    fi
    showy_quota_log "refresh lease lost (now owned by pid ${owner_pid:-unknown}); skipping publication"
    return 1
}
showy_quota_release_mkdir_lock() {
    if [[ -n "${SHOWY_QUOTA_HELD_LOCK_DIR:-}" ]]; then
        local owner_file="${SHOWY_QUOTA_HELD_LOCK_DIR}/owner.pid"
        local heartbeat_file="${SHOWY_QUOTA_HELD_LOCK_DIR}/owner.heartbeat"
        local owner_pid=""
        if [[ ! -e "${owner_file}" ]]; then
            showy_quota_log "not releasing mkdir lock without owner.pid"
        elif [[ -r "${owner_file}" ]] && IFS= read -r owner_pid < "${owner_file}" && [[ "${owner_pid}" == "$$" ]]; then
            rm -f -- "${owner_file}" "${heartbeat_file}"
            rmdir -- "${SHOWY_QUOTA_HELD_LOCK_DIR}" 2>/dev/null || true
        else
            showy_quota_log "not releasing mkdir lock now owned by pid ${owner_pid:-unknown}"
        fi
        SHOWY_QUOTA_HELD_LOCK_DIR=""
    fi
}

showy_quota_cleanup_cache_temps() {
    local tmp_file
    for tmp_file in "${SHOWY_QUOTA_CACHE_TMP_FILES[@]}"; do
        if [[ -n "${tmp_file}" ]]; then
            rm -f -- "${tmp_file}" 2>/dev/null || true
        fi
    done
    SHOWY_QUOTA_CACHE_TMP_FILES=()
}

showy_quota_exit_cleanup() {
    showy_quota_cleanup_cache_temps
    showy_quota_release_mkdir_lock
}

trap showy_quota_exit_cleanup EXIT
trap 'showy_quota_exit_cleanup; exit 130' INT
trap 'showy_quota_exit_cleanup; exit 143' TERM

showy_quota_process_state() {
    local pid="$1"
    local state=""
    if state=$(ps -o state= -p "${pid}" 2>/dev/null) \
        || state=$(ps -o stat= -p "${pid}" 2>/dev/null); then
        state="${state#"${state%%[![:space:]]*}"}"
        state="${state%%[[:space:]]*}"
        printf '%s\n' "${state}"
        return 0
    fi
    return 1
}

showy_quota_lock_age_seconds() {
    local lock_dir="$1"
    local now mtime
    now=$(showy_quota_now_epoch)
    if mtime=$(stat -f %m "${lock_dir}" 2>/dev/null) \
        || mtime=$(stat -c %Y "${lock_dir}" 2>/dev/null); then
        printf '%s\n' $((now - mtime))
        return 0
    fi
    return 1
}

showy_quota_run_with_mkdir_lock() {
    local lock_dir="$1"
    shift
    if ! printf '%s\n' "$$" > "${lock_dir}/owner.pid"; then
        rmdir -- "${lock_dir}" 2>/dev/null || true
        return 1
    fi
    SHOWY_QUOTA_HELD_LOCK_DIR="${lock_dir}"
    showy_quota_touch_mkdir_lock_heartbeat
    local rc=0
    "$@" || rc=$?
    showy_quota_release_mkdir_lock
    return "${rc}"
}

showy_quota_recover_mkdir_lock() {
    local lock_dir="$1"
    local owner_file="${lock_dir}/owner.pid"
    local heartbeat_file="${lock_dir}/owner.heartbeat"
    local owner_pid=""
    local stale_reason="ownerless"
    local lock_age="" heartbeat_age=""
    # A live owner may perform one bounded CLI request per configured provider.
    # Only a stalled heartbeat beyond this much larger absolute lease can be
    # reclaimed; normal refresh cadence is never evidence of owner death.
    local hard_max_age=$((SHOWY_QUOTA_REFRESH_SECONDS * 10))
    local heartbeat_max_age=$((SHOWY_QUOTA_REFRESH_SECONDS * 2))
    (( hard_max_age < 1800 )) && hard_max_age=1800
    (( heartbeat_max_age < 240 )) && heartbeat_max_age=240

    if [[ -r "${owner_file}" ]]; then
        IFS= read -r owner_pid < "${owner_file}" || owner_pid=""
        if [[ "${owner_pid}" =~ ^[0-9]+$ ]]; then
            if ! kill -0 "${owner_pid}" 2>/dev/null; then
                rm -f -- "${owner_file}" "${heartbeat_file}"
                if rmdir -- "${lock_dir}" 2>/dev/null; then
                    showy_quota_log "recovered dead mkdir lock owned by pid ${owner_pid}"
                    return 0
                fi
            fi
            local owner_state=""
            owner_state=$(showy_quota_process_state "${owner_pid}" || true)
            # Stopped and zombie owners cannot renew their lease or publish a
            # cache generation. Treat them as non-running owners so renderers
            # recover promptly instead of waiting for the long live-owner
            # heartbeat ceiling.
            if [[ "${owner_state}" == [TZ]* ]]; then
                rm -f -- "${owner_file}" "${heartbeat_file}"
                if rmdir -- "${lock_dir}" 2>/dev/null; then
                    showy_quota_log "recovered non-running mkdir lock owned by pid ${owner_pid} (state ${owner_state})"
                    return 0
                fi
            fi


            if lock_age=$(showy_quota_lock_age_seconds "${lock_dir}") \
                && (( lock_age >= hard_max_age ))
            then
                heartbeat_age=$(showy_quota_lock_age_seconds "${heartbeat_file}" 2>/dev/null) \
                    || heartbeat_age="${lock_age}"
                if (( heartbeat_age >= heartbeat_max_age )); then
                    rm -f -- "${owner_file}" "${heartbeat_file}"
                    if rmdir -- "${lock_dir}" 2>/dev/null; then
                        showy_quota_log "recovered unresponsive mkdir lock owned by live pid ${owner_pid} (lock ${lock_age}s, heartbeat ${heartbeat_age}s)"
                        return 0
                    fi
                fi
            fi
            return 1
        fi
        stale_reason="malformed-owner"
    elif [[ -e "${owner_file}" ]]; then
        stale_reason="unreadable-owner"
    fi

    # Crash windows: mkdir succeeded but owner.pid was never written,
    # was truncated before the PID landed, or is not readable. Only steal
    # these ambiguous locks after the normal wait horizon has elapsed.
    local max_age
    max_age=$(( (SHOWY_QUOTA_LOCK_WAIT_TENTHS + 9) / 10 ))
    (( max_age < 1 )) && max_age=1
    if lock_age=$(showy_quota_lock_age_seconds "${lock_dir}") && (( lock_age >= max_age )); then
        rm -f -- "${owner_file}" "${heartbeat_file}"
        if rmdir -- "${lock_dir}" 2>/dev/null; then
            showy_quota_log "recovered ${stale_reason} mkdir lock"
            return 0
        fi
    fi
    [[ "${stale_reason}" == "ownerless" ]] && return 1
    return 3
}

showy_quota_with_lock() {
    local lock_dir="${SHOWY_QUOTA_USAGE_LOCK}.d"
    if mkdir -- "${lock_dir}" 2>/dev/null; then
        showy_quota_run_with_mkdir_lock "${lock_dir}" "$@"
        return $?
    fi

    local recover_rc=0
    if showy_quota_recover_mkdir_lock "${lock_dir}"; then
        if mkdir -- "${lock_dir}" 2>/dev/null; then
            showy_quota_run_with_mkdir_lock "${lock_dir}" "$@"
            return $?
        fi
    else
        recover_rc=$?
    fi

    if (( recover_rc == 3 )); then
        showy_quota_log "ambiguous mkdir lock owner; will wait"
        return 3
    fi

    showy_quota_log "another fetch in flight (mkdir); will wait"
    return 2
}

cache_payload_marker() {
    [[ -s "${SHOWY_QUOTA_USAGE_FILE}" ]] || { printf '\n'; return; }
    stat -f 'file:%i:%m:%z' "${SHOWY_QUOTA_USAGE_FILE}" 2>/dev/null \
        || stat -c 'file:%i:%Y:%s' "${SHOWY_QUOTA_USAGE_FILE}" 2>/dev/null \
        || printf 'file:unknown\n'
}

cache_token() {
    [[ -s "${SHOWY_QUOTA_USAGE_FILE}" ]] || { printf '\n'; return; }
    if [[ -s "${SHOWY_QUOTA_USAGE_STAMP}" ]]; then
        printf 'stamp:%s\n' "$(< "${SHOWY_QUOTA_USAGE_STAMP}")"
        return
    fi
    cache_payload_marker
}

quarantine_invalid_cache_if_present() {
    [[ -f "${SHOWY_QUOTA_USAGE_FILE}" && -s "${SHOWY_QUOTA_USAGE_FILE}" ]] || return 0
    showy_quota_json_valid "${SHOWY_QUOTA_USAGE_FILE}" && return 0

    local stamp quarantine_path
    stamp="$(showy_quota_now_epoch)"
    quarantine_path="${SHOWY_QUOTA_USAGE_FILE}.corrupt.${stamp}.$$"
    if mv -- "${SHOWY_QUOTA_USAGE_FILE}" "${quarantine_path}"; then
        showy_quota_log "quarantined invalid cache at ${quarantine_path}"
    elif [[ ! -e "${SHOWY_QUOTA_USAGE_FILE}" ]]; then
        showy_quota_log "invalid cache was already quarantined by another fetcher"
        return 0
    else
        showy_quota_log "invalid cache present but quarantine failed: ${SHOWY_QUOTA_USAGE_FILE}"
        return 1
    fi

    local -a corrupt_files=("${SHOWY_QUOTA_USAGE_FILE}".corrupt.*)
    [[ -e "${corrupt_files[0]}" ]] || return 0
    local keep=3 count remove_count i
    keep="${SHOWY_QUOTA_CORRUPT_CACHE_RETENTION:-3}"
    [[ "${keep}" =~ ^[0-9]+$ ]] || keep=3
    count="${#corrupt_files[@]}"
    (( count > keep )) || return 0
    remove_count=$((count - keep))
    for (( i=0; i<remove_count; i++ )); do
        rm -f -- "${corrupt_files[$i]}"
    done
}



if [[ "${mode}" == "cache-only" ]]; then
    if [[ -s "${SHOWY_QUOTA_USAGE_FILE}" ]] && showy_quota_json_valid "${SHOWY_QUOTA_USAGE_FILE}"; then
        cat "${SHOWY_QUOTA_USAGE_FILE}"
        exit 0
    fi
    exit 1
fi

# Block up to N tenths of a second for the cache file to appear or refresh.
# Used by callers that lost the lock; protects against the cold-start case
# where there is no cache yet. With require_fresh=1, a changed token is not
# enough: the cache file mtime must also satisfy cache_is_fresh. A fresh
# payload marker that changed since the contender began also proves the holder
# published, even if the contender sampled its final token before losing lock.
showy_quota_wait_for_cache() {
    local max_tenths="${1:-50}"   # 5.0 s
    local previous_token="${2:-}"
    local require_fresh="${3:-0}"
    local previous_payload_marker="${4:-}"
    local i token payload_marker
    for (( i=0; i<max_tenths; i++ )); do
        if [[ -s "${SHOWY_QUOTA_USAGE_FILE}" ]] && showy_quota_json_valid "${SHOWY_QUOTA_USAGE_FILE}"; then
            if [[ -z "${previous_token}" ]]; then
                return 0
            fi
            token=$(cache_token)
            if [[ "${token}" != "${previous_token}" ]]; then
                if [[ "${require_fresh}" != "1" ]] || cache_is_fresh; then
                    return 0
                fi
            elif [[ "${require_fresh}" == "1" ]] && cache_is_fresh; then
                payload_marker=$(cache_payload_marker)
                if [[ -n "${previous_payload_marker}" && "${payload_marker}" != "${previous_payload_marker}" ]]; then
                    return 0
                fi
            fi
        fi
        sleep 0.1
    done
    return 1
}

# ── core refresh ──────────────────────────────────────────────────────

serve_base_url() {
    [[ -n "${SHOWY_QUOTA_CODEXBAR_SERVE_URL}" ]] || return 1
    local base="${SHOWY_QUOTA_CODEXBAR_SERVE_URL%/}"
    if ! [[ "${base}" =~ ^http://(127[.]0[.]0[.]1|localhost|\[::1\])(:[0-9]+)?$ ]]; then
        showy_quota_log "ignoring non-local codexbar serve URL: ${SHOWY_QUOTA_CODEXBAR_SERVE_URL}"
        return 1
    fi
    printf '%s\n' "${base}"
}

serve_positive_timeout_or_default() {
    local timeout="$1" default="$2" whole
    if [[ "${timeout}" =~ ^[0-9]+([.][0-9]+)?$ && ! "${timeout}" =~ ^0+([.]0+)?$ ]]; then
        whole="${timeout%%.*}"
        # Clamp to a sane ceiling so a huge value cannot turn the serve HTTP
        # probe (curl --max-time) into an effectively unbounded wait.
        (( 10#${whole} > 60 )) && timeout=60
    else
        timeout="${default}"
    fi
    printf '%s\n' "${timeout}"
}

serve_timeout() {
    serve_positive_timeout_or_default "${SHOWY_QUOTA_CODEXBAR_SERVE_TIMEOUT_SECONDS}" 0.5
}

serve_usage_timeout() {
    # The /usage probe needs more headroom than the /health probe: a healthy
    # `codexbar serve` bounds collection per provider (~0.8x its request
    # deadline, ~24s by default) and still returns the healthy providers when a
    # slow one degrades to an error row. Using the short health timeout here
    # would abandon that usable partial response and fall back to degraded CLI
    # whenever any provider is briefly slow.
    serve_positive_timeout_or_default "${SHOWY_QUOTA_CODEXBAR_SERVE_USAGE_TIMEOUT_SECONDS}" 30
}

positive_integer_or_default() {
    local value="$1" default="$2" max="${3:-}"
    if [[ "${value}" =~ ^[0-9]+$ ]]; then
        value=$((10#${value}))
    else
        value="${default}"
    fi
    (( value > 0 )) || value="${default}"
    if [[ -n "${max}" ]] && (( value > max )); then
        value="${max}"
    fi
    printf '%s\n' "${value}"
}

codexbar_cli_timeout_seconds() {
    positive_integer_or_default "${SHOWY_QUOTA_CODEXBAR_CLI_TIMEOUT_SECONDS:-20}" 20 300
}

serve_failure_restart_threshold() {
    positive_integer_or_default "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURES_BEFORE_RESTART:-3}" 3
}

serve_failure_cli_threshold() {
    positive_integer_or_default "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURES_BEFORE_CLI:-3}" 3
}

serve_failure_count() {
    local count="0"
    if [[ -r "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_COUNT_FILE}" ]]; then
        IFS= read -r count < "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_COUNT_FILE}" || count="0"
    fi
    [[ "${count}" =~ ^[0-9]+$ ]] || count="0"
    printf '%s\n' "${count}"
}

serve_failure_cli_fallback_allowed() {
    local count threshold
    count=$(serve_failure_count)
    threshold=$(serve_failure_cli_threshold)
    (( count >= threshold ))
}


serve_failure_backoff_seconds() {
    positive_integer_or_default "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_BACKOFF_SECONDS:-60}" 60
}

serve_failure_backoff_active() {
    local seconds failed_at now age
    (( force_refresh == 0 )) || return 1
    seconds=$(serve_failure_backoff_seconds)
    (( seconds > 0 )) || return 1
    [[ -r "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_STAMP}" ]] || return 1
    IFS= read -r failed_at < "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_STAMP}" || return 1
    [[ "${failed_at}" =~ ^[0-9]+$ ]] || { rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_STAMP}"; return 1; }
    now=$(showy_quota_now_epoch)
    age=$((now - failed_at))
    if (( age >= 0 && age < seconds )); then
        showy_quota_log "skipping codexbar serve probe during failure backoff (${age}/${seconds}s)"
        return 0
    fi
    rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_STAMP}"
    return 1
}

record_serve_failure() {
    local count
    count=$(serve_failure_count)
    count=$((count + 1))
    printf '%s\n' "${count}" > "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_COUNT_FILE}" 2>/dev/null || true
    printf '%s\n' "$(showy_quota_now_epoch)" > "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_STAMP}" 2>/dev/null || true
}

clear_serve_failure() {
    rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_STAMP}" "${SHOWY_QUOTA_CODEXBAR_SERVE_FAILURE_COUNT_FILE}" 2>/dev/null || true
}

cli_failure_backoff_seconds() {
    positive_integer_or_default "${SHOWY_QUOTA_CODEXBAR_CLI_FAILURE_BACKOFF_SECONDS:-${SHOWY_QUOTA_REFRESH_SECONDS:-120}}" 120
}

cli_failure_backoff_active() {
    local seconds failed_at now age
    (( force_refresh == 0 )) || return 1
    seconds=$(cli_failure_backoff_seconds)
    (( seconds > 0 )) || return 1
    [[ -r "${SHOWY_QUOTA_CODEXBAR_CLI_FAILURE_STAMP}" ]] || return 1
    IFS= read -r failed_at < "${SHOWY_QUOTA_CODEXBAR_CLI_FAILURE_STAMP}" || return 1
    [[ "${failed_at}" =~ ^[0-9]+$ ]] || { rm -f -- "${SHOWY_QUOTA_CODEXBAR_CLI_FAILURE_STAMP}"; return 1; }
    now=$(showy_quota_now_epoch)
    age=$((now - failed_at))
    if (( age >= 0 && age < seconds )); then
        showy_quota_log "skipping codexbar CLI fallback during failure backoff (${age}/${seconds}s)"
        return 0
    fi
    rm -f -- "${SHOWY_QUOTA_CODEXBAR_CLI_FAILURE_STAMP}"
    return 1
}

record_cli_failure() {
    printf '%s\n' "$(showy_quota_now_epoch)" > "${SHOWY_QUOTA_CODEXBAR_CLI_FAILURE_STAMP}" 2>/dev/null || true
}

clear_cli_failure() {
    rm -f -- "${SHOWY_QUOTA_CODEXBAR_CLI_FAILURE_STAMP}" 2>/dev/null || true
}

# ── provider discovery & per-provider fallback ─────────────────────────

codexbar_config_providers_timeout_seconds() {
    positive_integer_or_default "${SHOWY_QUOTA_CODEXBAR_CONFIG_PROVIDERS_TIMEOUT_SECONDS:-5}" 5 300
}

config_providers_backoff_seconds() {
    positive_integer_or_default "${SHOWY_QUOTA_CODEXBAR_CONFIG_PROVIDERS_BACKOFF_SECONDS:-60}" 60
}

config_providers_backoff_active() {
    local seconds failed_at now age
    (( force_refresh == 0 )) || return 1
    seconds=$(config_providers_backoff_seconds)
    (( seconds > 0 )) || return 1
    [[ -r "${SHOWY_QUOTA_CODEXBAR_CONFIG_PROVIDERS_FAILURE_STAMP}" ]] || return 1
    IFS= read -r failed_at < "${SHOWY_QUOTA_CODEXBAR_CONFIG_PROVIDERS_FAILURE_STAMP}" || return 1
    [[ "${failed_at}" =~ ^[0-9]+$ ]] || { rm -f -- "${SHOWY_QUOTA_CODEXBAR_CONFIG_PROVIDERS_FAILURE_STAMP}"; return 1; }
    now=$(showy_quota_now_epoch)
    age=$((now - failed_at))
    if (( age >= 0 && age < seconds )); then
        return 0
    fi
    rm -f -- "${SHOWY_QUOTA_CODEXBAR_CONFIG_PROVIDERS_FAILURE_STAMP}"
    return 1
}

record_config_providers_failure() {
    printf '%s\n' "$(showy_quota_now_epoch)" > "${SHOWY_QUOTA_CODEXBAR_CONFIG_PROVIDERS_FAILURE_STAMP}" 2>/dev/null || true
}

clear_config_providers_failure() {
    rm -f -- "${SHOWY_QUOTA_CODEXBAR_CONFIG_PROVIDERS_FAILURE_STAMP}" 2>/dev/null || true
}

provider_failure_backoff_seconds() {
    positive_integer_or_default "${SHOWY_QUOTA_PROVIDER_FAILURE_BACKOFF_SECONDS:-${SHOWY_QUOTA_REFRESH_SECONDS:-120}}" 120
}

provider_failure_stamp_path() {
    local provider="$1"
    printf '%s/%s' "${SHOWY_QUOTA_PROVIDER_FAILURE_DIR}" "${provider}"
}

provider_failure_backoff_active() {
    local provider="$1" stamp seconds failed_at now age
    (( force_refresh == 0 )) || return 1
    seconds=$(provider_failure_backoff_seconds)
    (( seconds > 0 )) || return 1
    stamp=$(provider_failure_stamp_path "${provider}")
    [[ -r "${stamp}" ]] || return 1
    IFS= read -r failed_at < "${stamp}" || return 1
    [[ "${failed_at}" =~ ^[0-9]+$ ]] || { rm -f -- "${stamp}"; return 1; }
    now=$(showy_quota_now_epoch)
    age=$((now - failed_at))
    if (( age >= 0 && age < seconds )); then
        showy_quota_log "skipping codexbar CLI fallback for ${provider} during failure backoff (${age}/${seconds}s)"
        return 0
    fi
    rm -f -- "${stamp}"
    return 1
}

record_provider_failure() {
    local provider="$1" stamp
    mkdir -p "${SHOWY_QUOTA_PROVIDER_FAILURE_DIR}" 2>/dev/null || true
    stamp=$(provider_failure_stamp_path "${provider}")
    printf '%s\n' "$(showy_quota_now_epoch)" > "${stamp}" 2>/dev/null || true
}

clear_provider_failure() {
    local provider="$1"
    rm -f -- "$(provider_failure_stamp_path "${provider}")" 2>/dev/null || true
}

valid_provider_id() {
    local id="$1"
    [[ -n "${id}" ]] || return 1
    # '.', '..', and leading '-' match the charset below but are not safe ids:
    # path components can escape per-provider stamp directories, and leading
    # '-' can be interpreted as an argv flag by downstream CLIs.
    [[ "${id}" == "." || "${id}" == ".." || "${id}" == -* ]] && return 1
    [[ "${id}" =~ ^[A-Za-z0-9_.-]+$ ]]
}

# Run `codexbar config providers --format json [--pretty]` with a hard timeout
# and emit enabled provider ids (one per line) on stdout. Empty stdout +
# non-zero rc on failure. Honors a short failure backoff so a hanging
# CodexBar config call does not re-arm every refresh tick.
discover_providers() {
    if ! command -v "${SHOWY_QUOTA_CODEXBAR_BIN}" >/dev/null 2>&1; then
        return 127
    fi
    if config_providers_backoff_active; then
        return 1
    fi
    local LC_ALL=C
    local timeout_seconds discovery_max_bytes raw schema_check ids rc=0 enabled_count=0 valid_count=0 id_line
    timeout_seconds=$(codexbar_config_providers_timeout_seconds)
    # Provider configuration is metadata, not a usage payload. Bound it to a
    # small fraction of the existing payload ceiling while preserving one
    # source of truth for the maximum data-plane allocation.
    discovery_max_bytes=$((SHOWY_QUOTA_MAX_USAGE_JSON_BYTES / 80))
    (( discovery_max_bytes > 0 )) || discovery_max_bytes=1
    raw=$(run_with_hard_timeout "${timeout_seconds}" "${discovery_max_bytes}" "${SHOWY_QUOTA_CODEXBAR_BIN}" config providers --format json --pretty) || rc=$?
    if (( rc != 0 )) || [[ -z "${raw}" ]]; then
        record_config_providers_failure
        return 1
    fi
    if (( ${#raw} > discovery_max_bytes )); then
        showy_quota_log "codexbar config providers exceeded ${discovery_max_bytes}-byte cap"
        record_config_providers_failure
        return 1
    fi
    showy_quota_have jq || { record_config_providers_failure; return 1; }
    # Match Rust's ProviderConfigRecord deserialization: every entry must be
    # an object with a string provider; enabled is optional (default false)
    # but, when supplied, must be a JSON boolean.
    schema_check=$(printf '%s' "${raw}" | jq -r '
        if type == "array"
           and all(.[];
               if type == "object" then
                   (.provider | type == "string")
                   and (if has("enabled") then (.enabled | type == "boolean") else true end)
               else
                   false
               end)
        then "ok" else "no" end
    ' 2>/dev/null) || schema_check="no"
    if [[ "${schema_check}" != "ok" ]]; then
        showy_quota_log "codexbar config providers returned malformed records"
        record_config_providers_failure
        return 1
    fi
    # Two-pass: count enabled provider records independently from provider
    # strings, then keep only ids that pass `valid_provider_id`. Empty, null,
    # or missing ids in enabled records are invalid inventory, not canonical
    # empty inventory.
    enabled_count=$(printf '%s' "${raw}" | jq -r '
        [.[] | select(.enabled == true)] | length
    ' 2>/dev/null) || enabled_count=0
    [[ "${enabled_count}" =~ ^[0-9]+$ ]] || enabled_count=0
    ids=$(printf '%s' "${raw}" | jq -r '
        .[]
        | select(.enabled == true)
        | .provider
    ' 2>/dev/null) || ids=""
    # Keep only ids the shell predicate accepts: the jq regex alone would
    # still pass '.'/'..' and leading-dash ids; those escape the
    # per-provider failure-stamp directory or can be interpreted as CLI flags.
    # A record whose id fails the predicate drops valid_count below
    # enabled_count and is rejected as invalid inventory, not canonical-empty.
    local validated_ids=""
    if [[ -n "${ids}" ]]; then
        while IFS= read -r id_line; do
            [[ -n "${id_line}" ]] || continue
            valid_provider_id "${id_line}" || continue
            validated_ids+="${id_line}"$'\n'
            valid_count=$((valid_count + 1))
        done < <(printf '%s\n' "${ids}")
    fi
    if (( enabled_count != valid_count )); then
        showy_quota_log "codexbar config providers returned only invalid provider ids"
        record_config_providers_failure
        return 1
    fi
    clear_config_providers_failure
    [[ -n "${validated_ids}" ]] && printf '%s' "${validated_ids}"
    return 0
}
canonical_empty_inventory_payload() {
    local discovered=""
    if ! discovered=$(discover_providers 2>/dev/null | sort -u); then
        return 1
    fi
    [[ -z "${discovered}" ]] || return 1
    printf '[]'
}

# Newline-separated provider ids, deduplicated in first-seen order, after
# applying SHOWY_QUOTA_PROVIDERS allow-list, SHOWY_QUOTA_PROVIDERS_EXCLUDE,
# and SHOWY_QUOTA_PROVIDER_ORDER. Allow-list and exclude membership both treat
# their CSV values as a set; order is preserved deterministically.
apply_provider_filters() {
    local input="$1"
    local allow_csv="${SHOWY_QUOTA_PROVIDERS:-}"
    local exclude_csv="${SHOWY_QUOTA_PROVIDERS_EXCLUDE:-}"
    local order_csv="${SHOWY_QUOTA_PROVIDER_ORDER:-}"
    local -a allow=() exclude=() order=() raw=() filtered=() ordered=()
    local id token in_list raw_id

    IFS=$'\n' read -r -d '' -a raw < <(printf '%s\0' "${input}") || true

    if [[ -n "${allow_csv}" ]]; then
        IFS=',' read -r -a allow < <(printf '%s\n' "${allow_csv}")
    fi
    if [[ -n "${exclude_csv}" ]]; then
        IFS=',' read -r -a exclude < <(printf '%s\n' "${exclude_csv}")
    fi
    if [[ -n "${order_csv}" ]]; then
        IFS=',' read -r -a order < <(printf '%s\n' "${order_csv}")
    fi

    for id in "${raw[@]}"; do
        id="${id#"${id%%[![:space:]]*}"}"
        id="${id%"${id##*[![:space:]]}"}"
        [[ -n "${id}" ]] || continue
        valid_provider_id "${id}" || continue

        if (( ${#allow[@]} > 0 )); then
            in_list=0
            for token in "${allow[@]}"; do
                token="${token#"${token%%[![:space:]]*}"}"
                token="${token%"${token##*[![:space:]]}"}"
                [[ "${token}" == "${id}" ]] && { in_list=1; break; }
            done
            (( in_list )) || continue
        fi

        in_list=0
        for token in "${exclude[@]}"; do
            token="${token#"${token%%[![:space:]]*}"}"
            token="${token%"${token##*[![:space:]]}"}"
            [[ "${token}" == "${id}" ]] && { in_list=1; break; }
        done
        (( in_list )) && continue

        in_list=0
        for token in "${filtered[@]}"; do
            [[ "${token}" == "${id}" ]] && { in_list=1; break; }
        done
        (( in_list )) || filtered+=("${id}")
    done

    if (( ${#allow[@]} > 0 )); then
        # SHOWY_QUOTA_PROVIDERS is an ordered allow-list. When present, it
        # defines fallback query order; provider_order remains display-only
        # for the broader renderer path.
        for token in "${allow[@]}"; do
            token="${token#"${token%%[![:space:]]*}"}"
            token="${token%"${token##*[![:space:]]}"}"
            [[ -n "${token}" ]] || continue
            for id in "${filtered[@]}"; do
                if [[ "${id}" == "${token}" ]]; then
                    in_list=0
                    for raw_id in "${ordered[@]}"; do
                        [[ "${raw_id}" == "${id}" ]] && { in_list=1; break; }
                    done
                    (( in_list )) || ordered+=("${id}")
                    break
                fi
            done
        done
    else
        # First emit providers in SHOWY_QUOTA_PROVIDER_ORDER, then any
        # remaining in their original (filtered) order.
        for token in "${order[@]}"; do
            token="${token#"${token%%[![:space:]]*}"}"
            token="${token%"${token##*[![:space:]]}"}"
            [[ -n "${token}" ]] || continue
            for id in "${filtered[@]}"; do
                if [[ "${id}" == "${token}" ]]; then
                    in_list=0
                    for raw_id in "${ordered[@]}"; do
                        [[ "${raw_id}" == "${id}" ]] && { in_list=1; break; }
                    done
                    (( in_list )) || ordered+=("${id}")
                    break
                fi
            done
        done
        for id in "${filtered[@]}"; do
            in_list=0
            for raw_id in "${ordered[@]}"; do
                [[ "${raw_id}" == "${id}" ]] && { in_list=1; break; }
            done
            (( in_list )) || ordered+=("${id}")
        done
    fi

    (( ${#ordered[@]} > 0 )) || return 1
    printf '%s\n' "${ordered[@]}"
}

# Discover the provider list to drive per-provider CLI fallback. Order of
# preference: live CodexBar `config providers` → ids in the existing valid
# cache → explicit SHOWY_QUOTA_PROVIDERS allow-list. Returns 1 with no output
# when none of those yield a usable list. Returns 2 with empty output when a
# canonical empty inventory (CodexBar reports zero enabled providers) was
# observed — callers should publish an empty `[]` payload rather than treating
# this as a refresh failure.
provider_inventory_for_fallback() {
    local discovery_rc=0 discovery_raw="" ids="" selection=""
    discovery_raw=$(discover_providers) || discovery_rc=$?
    if (( discovery_rc == 0 )); then
        selection=""
        if [[ -n "${discovery_raw}" ]]; then
            selection=$(apply_provider_filters "${discovery_raw}") || selection=""
        fi
        if [[ -n "${selection}" ]]; then
            showy_quota_log "provider inventory from codexbar-config: $(printf '%s' "${selection}" | tr '\n' ' ')"
            printf '%s' "${selection}"
            return 0
        fi
        showy_quota_log "codexbar reports no enabled providers; publishing empty cache"
        return 2
    fi

    if [[ -s "${SHOWY_QUOTA_USAGE_FILE}" ]] \
        && showy_quota_json_valid "${SHOWY_QUOTA_USAGE_FILE}" \
        && ids=$(showy_quota_provider_ids_from_payload "${SHOWY_QUOTA_USAGE_FILE}") \
        && [[ -n "${ids}" ]]; then
        selection=$(apply_provider_filters "${ids}") || selection=""
        if [[ -n "${selection}" ]]; then
            showy_quota_log "provider inventory from cache: $(printf '%s' "${selection}" | tr '\n' ' ')"
            printf '%s' "${selection}"
            return 0
        fi
        showy_quota_log "provider inventory from cache filtered to empty list"
    fi

    if [[ -n "${SHOWY_QUOTA_PROVIDERS:-}" ]]; then
        ids=$(printf '%s' "${SHOWY_QUOTA_PROVIDERS}" | tr ',' '\n')
        selection=$(apply_provider_filters "${ids}") || selection=""
        if [[ -n "${selection}" ]]; then
            showy_quota_log "provider inventory from allow-list: $(printf '%s' "${selection}" | tr '\n' ' ')"
            printf '%s' "${selection}"
            return 0
        fi
        showy_quota_log "provider inventory from allow-list filtered to empty list"
    fi

    showy_quota_log "no provider inventory: codexbar config failed, cache empty, SHOWY_QUOTA_PROVIDERS unset"
    return 1
}

# Validate a per-provider usage payload: it must be a JSON array, every record
# must be an object whose `.provider` matches the requested id, and any
# embedded `.usage` object must have well-typed windows. We deliberately
# accept error-only records (the renderer surfaces them as idle/errored) and
# accept an empty array (CodexBar has no data for this provider right now);
# only a malformed shape or mismatched provider id fails the predicate.
provider_payload_is_publishable() {
    local provider="$1" payload="$2"
    [[ -n "${payload}" ]] || return 1
    printf '%s' "${payload}" | jq --arg p "${provider}" -e '
        type == "array"
        and all(.[]?;
            type == "object"
            and (.provider | type == "string")
            and (.provider == $p)
            and (
                (.usage // null) == null
                or (
                    (.usage | type) == "object"
                    and all([.usage.primary, .usage.secondary, .usage.tertiary][];
                        . == null
                        or (type == "object" and (.usedPercent | type) == "number")
                    )
                )
            )
        )
    ' >/dev/null 2>&1
}

# Run `codexbar usage --provider <id> --format json --pretty [--status]`
# bounded by a hard process-group timeout. Emits the payload on stdout when it
# validates as a single-provider record; returns 1 otherwise.
run_codexbar_cli_provider() {
    local provider="$1"
    local LC_ALL=C
    local timeout_seconds out rc=0
    valid_provider_id "${provider}" || return 1
    if ! command -v "${SHOWY_QUOTA_CODEXBAR_BIN}" >/dev/null 2>&1; then
        showy_quota_log "codexbar binary not found: ${SHOWY_QUOTA_CODEXBAR_BIN}"
        return 127
    fi
    local args=(usage --provider "${provider}" --format json --pretty)
    if [[ "${SHOWY_QUOTA_INCLUDE_STATUS}" == "1" ]]; then
        args+=(--status)
    fi
    timeout_seconds=$(codexbar_cli_timeout_seconds)
    out=$(run_with_hard_timeout "${timeout_seconds}" "${SHOWY_QUOTA_MAX_USAGE_JSON_BYTES}" "${SHOWY_QUOTA_CODEXBAR_BIN}" "${args[@]}") || rc=$?
    if (( rc != 0 )); then
        showy_quota_log "codexbar usage --provider ${provider} failed (rc=${rc})"
        return 1
    fi
    if (( ${#out} > SHOWY_QUOTA_MAX_USAGE_JSON_BYTES )); then
        showy_quota_log "codexbar usage --provider ${provider} exceeded ${SHOWY_QUOTA_MAX_USAGE_JSON_BYTES}-byte cap"
        return 1
    fi
    if ! provider_payload_is_publishable "${provider}" "${out}"; then
        showy_quota_log "codexbar usage --provider ${provider} returned no renderable record"
        return 1
    fi
    printf '%s' "${out}"
    return 0
}

# Emit the prior cache record(s) for a provider as a one-element JSON array, so a
# provider whose fresh CLI fetch is skipped (backoff) or fails keeps its
# last-known-good slice instead of vanishing from the merged payload. Returns 1
# when the cache is absent/invalid or has no record for the provider.
carry_forward_provider_record() {
    local provider="$1" record=""
    [[ -s "${SHOWY_QUOTA_USAGE_FILE}" ]] || return 1
    showy_quota_json_valid "${SHOWY_QUOTA_USAGE_FILE}" || return 1
    record=$(jq -c --arg p "${provider}" \
        '[.[] | select(type == "object" and .provider == $p)]' \
        "${SHOWY_QUOTA_USAGE_FILE}" 2>/dev/null) || return 1
    [[ -n "${record}" && "${record}" != "[]" ]] || return 1
    printf '%s' "${record}"
}

# Per-provider CLI fallback: discover providers, run one CLI invocation per
# provider with isolation, and merge successful records into one publishable
# array. Returns 0 with merged JSON on stdout when at least one provider
# succeeds (or the canonical inventory is empty, in which case `[]` is emitted
# so renderers can show an idle state instead of stale/blank output), and
# records per-provider backoff for failures so a single misbehaving provider
# does not poison every tick.
run_codexbar_cli_per_provider() {
    local providers=""
    local rc=0
    showy_quota_touch_mkdir_lock_heartbeat
    providers=$(provider_inventory_for_fallback) || rc=$?
    showy_quota_touch_mkdir_lock_heartbeat
    if (( rc == 2 )); then
        printf '[]'
        return 0
    fi
    if (( rc != 0 )); then
        return 1
    fi
    [[ -n "${providers}" ]] || return 1

    local -a accumulated=()
    local provider provider_rc fresh_count=0
    local out=""
    while IFS= read -r provider; do
        [[ -n "${provider}" ]] || continue
        showy_quota_touch_mkdir_lock_heartbeat
        if provider_failure_backoff_active "${provider}"; then
            if out=$(carry_forward_provider_record "${provider}"); then
                accumulated+=("${out}")
            fi
            showy_quota_touch_mkdir_lock_heartbeat
            continue
        fi
        provider_rc=0
        out=$(run_codexbar_cli_provider "${provider}") || provider_rc=$?
        showy_quota_touch_mkdir_lock_heartbeat
        if (( provider_rc == 127 )); then
            return 1
        fi
        if (( provider_rc != 0 )); then
            record_provider_failure "${provider}"
            if out=$(carry_forward_provider_record "${provider}"); then
                accumulated+=("${out}")
            fi
            showy_quota_touch_mkdir_lock_heartbeat
            continue
        fi
        clear_provider_failure "${provider}"
        accumulated+=("${out}")
        fresh_count=$((fresh_count + 1))
        showy_quota_touch_mkdir_lock_heartbeat
    done < <(printf '%s\n' "${providers}")

    (( fresh_count > 0 )) || return 1

    # Merge per-provider arrays into one publishable array. Validation in
    # `publish_cache_payload` runs again before we publish, so a degenerate
    # merge fails closed without overwriting the existing cache.
    local merged
    merged=$(printf '%s' "${accumulated[0]}")
    local i
    for (( i = 1; i < ${#accumulated[@]}; i++ )); do
        merged=$(printf '%s\n%s' "${merged}" "${accumulated[$i]}" | jq -s -c '
            map(select(type == "array")) | add // []
            | reduce .[] as $r ([];
                if ($r.provider | type == "string")
                   and (any(.[]; .provider == $r.provider) | not)
                then . + [$r]
                else . end
              )
        ' 2>/dev/null) || return 1
    done

    [[ -n "${merged}" && "${merged:0:1}" == '[' ]] || return 1
    printf '%s' "${merged}"
}



serve_port_from_base_url() {
    local base="" url_port="" configured_port="${SHOWY_QUOTA_CODEXBAR_SERVE_PORT:-}" scheme_default="8080"
    base=$(serve_base_url) || return 1
    if [[ "${base}" =~ ^http:// ]]; then
        scheme_default="80"
    fi
    if [[ "${base}" =~ :([0-9]+)$ ]]; then
        url_port="${BASH_REMATCH[1]}"
    fi
    if [[ -n "${configured_port}" ]]; then
        if [[ "${configured_port}" =~ ^[0-9]+$ ]]; then
            printf '%s\n' "${configured_port}"
            return 0
        fi
        showy_quota_log "ignoring invalid SHOWY_QUOTA_CODEXBAR_SERVE_PORT: ${configured_port}"
    fi
    printf '%s\n' "${url_port:-${scheme_default}}"
}

serve_health_ok() {
    showy_quota_have curl || return 2
    local base
    base=$(serve_base_url) || return 1
    curl --fail --silent --max-time "$(serve_timeout)" "${base}/health" >/dev/null 2>&1
}

# Extract a comparable CodexBar version token from a version string on stdin so
# /health's `.version` and `codexbar --version` are normalized identically
# (matching glean's stale-serve detector): the first whitespace field that looks
# like a version (optional leading `v` then a digit), with the `v` stripped. A
# string with no version-looking field (e.g. a transient bare `CodexBar`) yields
# empty, which makes the gate reuse the serve rather than recycle it.
codexbar_version_token() {
    awk 'NR==1 { for (i = 1; i <= NF; i++) if ($i ~ /^v?[0-9]/) { token = $i; sub(/^v/, "", token); print token; exit } }'
}

# Build version reported by a running codexbar serve via /health. Empty when
# unavailable, when curl/jq are missing, or for pre-#1703 builds whose /health
# omits the version field (so the version gate stays a no-op there).
serve_running_version() {
    local base
    base=$(serve_base_url) || return 1
    showy_quota_have curl || return 1
    showy_quota_have jq || return 1
    curl --fail --silent --max-time "$(serve_timeout)" "${base}/health" 2>/dev/null \
        | jq -r '.version // empty' 2>/dev/null \
        | codexbar_version_token
}

# Resolve the configured codexbar binary to an absolute path. CodexBar reads its
# version from the app bundle via argv[0]: invoked by a bare command name (no
# directory) it cannot locate the bundle, so `--version` and serve `/health`
# omit the version and the stale-serve gate stays inert. A value that already
# carries a path is trusted as-is; an unresolvable bare name falls back to
# itself (callers still guard with showy_quota_have).
codexbar_bin_abs() {
    local bin="${SHOWY_QUOTA_CODEXBAR_BIN}"
    if [[ "${bin}" == */* ]]; then
        printf '%s\n' "${bin}"
        return 0
    fi
    local resolved canon
    resolved=$(command -v "${bin}" 2>/dev/null) || { printf '%s\n' "${bin}"; return 0; }
    # Pin the real file so a PATH/symlink swap between resolution and the serve
    # spawn cannot substitute a different codexbar. Only adopt the canonical path
    # when it keeps the same basename, so the managed-serve ps basename match
    # (managed_serve_expected_basename) still holds.
    if canon=$(realpath "${resolved}" 2>/dev/null) || canon=$(readlink -f "${resolved}" 2>/dev/null); then
        if [[ -n "${canon}" && "${canon##*/}" == "${resolved##*/}" ]]; then
            printf '%s\n' "${canon}"
            return 0
        fi
    fi
    printf '%s\n' "${resolved}"
}

# Build version of the installed codexbar binary (cheap, bounded fresh process).
# Empty when the binary is missing or its --version output is unrecognized; an
# empty result makes the version gate reuse the running serve, never recycle.
serve_ondisk_version() {
    local bin
    bin=$(codexbar_bin_abs)
    showy_quota_have "${bin}" || return 1
    run_with_hard_timeout 5 1024 "${bin}" --version 2>/dev/null \
        | codexbar_version_token
}

# Free the configured serve port so ensure_serve_running can start a fresh
# serve. A serve we manage is terminated through its identity-checked record.
# Without a valid record, listeners are inspected and only verified codexbar
# serves are signaled. Foreign listeners are never touched.
wait_for_serve_port_release() {
    local port="$1" listeners="" i
    showy_quota_have lsof || return 1
    for (( i=0; i<30; i++ )); do
        listeners=$(lsof -ti "tcp:${port}" -sTCP:LISTEN 2>/dev/null) || listeners=""
        [[ -z "${listeners}" ]] && return 0
        sleep 0.1
    done
    return 1
}

terminate_verified_serve_listener() {
    local pid="$1" i
    serve_listener_is_codexbar "${pid}" || return 1
    if ! kill "${pid}" 2>/dev/null; then
        kill -0 "${pid}" 2>/dev/null || return 0
        return 1
    fi
    for (( i=0; i<10; i++ )); do
        kill -0 "${pid}" 2>/dev/null || return 0
        # Do not escalate after an exec/reuse we can no longer verify.
        serve_listener_is_codexbar "${pid}" || return 0
        sleep 0.1
    done
    serve_listener_is_codexbar "${pid}" || return 0
    kill -9 "${pid}" 2>/dev/null || return 1
    for (( i=0; i<10; i++ )); do
        kill -0 "${pid}" 2>/dev/null || return 0
        serve_listener_is_codexbar "${pid}" || return 0
        sleep 0.1
    done
    return 1
}

serve_recycle_stale() {
    local pid="" start_epoch="" basename_rec=""
    if managed_serve_valid_pidfile pid start_epoch basename_rec; then
        showy_quota_log "recycling stale managed codexbar serve pid ${pid}"
        if ! terminate_managed_serve_pid "${pid}" "${start_epoch}" "${basename_rec}"; then
            showy_quota_log "managed codexbar serve pid ${pid} did not exit; reusing"
            return 1
        fi
        rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}"
        return 0
    fi

    local port=""
    if ! port=$(serve_port_from_base_url); then
        showy_quota_log "cannot recycle foreign codexbar serve: no serve port; reusing"
        return 1
    fi
    if ! showy_quota_have lsof; then
        showy_quota_log "cannot recycle foreign codexbar serve on port ${port}: no lsof; reusing"
        return 1
    fi

    local listeners=""
    listeners=$(lsof -ti "tcp:${port}" -sTCP:LISTEN 2>/dev/null) || listeners=""
    if [[ -z "${listeners}" ]]; then
        showy_quota_log "cannot recycle foreign codexbar serve on port ${port}: no listeners; reusing"
        return 1
    fi

    local listener_pid="" killed=0 unverified=0
    while IFS= read -r listener_pid; do
        [[ -n "${listener_pid}" ]] || continue
        if terminate_verified_serve_listener "${listener_pid}"; then
            killed=$(( killed + 1 ))
        else
            showy_quota_log "refusing to recycle foreign listener pid ${listener_pid} on port ${port} (not a terminable codexbar serve)"
            unverified=1
        fi
    done <<<"${listeners}"

    if (( unverified || killed == 0 )); then
        showy_quota_log "cannot recycle foreign codexbar serve on port ${port}: no verified codexbar listener freed; reusing"
        return 1
    fi
    if ! wait_for_serve_port_release "${port}"; then
        showy_quota_log "foreign codexbar listeners did not release port ${port}; reusing"
        return 1
    fi
    showy_quota_log "recycled foreign codexbar serve on port ${port} (${listeners//$'\n'/ })"
    return 0
}

# Predicate: is the listening PID a codexbar serve we may recycle? The first
# word of its command line must have the configured codexbar bin basename AND a
# standalone `serve` argument must appear. Anything else (a foreign process that
# happens to hold our port) fails and is never signaled.
serve_listener_is_codexbar() {
    local pid="$1" expected="" command="" token=""
    local -a tokens=()
    expected=$(managed_serve_expected_basename)
    [[ -n "${expected}" ]] || return 1
    command=$(ps -p "${pid}" -o command= 2>/dev/null) || return 1
    command="${command#"${command%%[![:space:]]*}"}"
    [[ -n "${command}" ]] || return 1
    # Split on whitespace without pathname expansion: an unquoted ${command}
    # would glob ps output (e.g. a literal `*`) against the working directory.
    read -ra tokens <<<"${command}"
    (( ${#tokens[@]} > 0 )) || return 1
    [[ "${tokens[0]##*/}" == "${expected}" ]] || return 1
    for token in "${tokens[@]:1}"; do
        [[ "${token}" == "serve" ]] && return 0
    done
    return 1
}

wait_for_serve_health() {
    local max_tenths="${SHOWY_QUOTA_CODEXBAR_SERVE_START_WAIT_TENTHS:-30}"
    [[ "${max_tenths}" =~ ^[0-9]+$ ]] || max_tenths=30
    max_tenths=$((10#${max_tenths}))
    (( max_tenths > 0 )) || max_tenths=30
    (( max_tenths > 3000 )) && max_tenths=3000
    local i
    for (( i=0; i<max_tenths; i++ )); do
        if serve_health_ok; then
            showy_quota_touch_mkdir_lock_heartbeat
            return 0
        fi
        (( i % 10 == 0 )) && showy_quota_touch_mkdir_lock_heartbeat
        sleep 0.1
    done
    showy_quota_touch_mkdir_lock_heartbeat
    return 1
}

managed_serve_expected_basename() {
    printf '%s\n' "${SHOWY_QUOTA_CODEXBAR_BIN##*/}"
}

showy_quota_pid_start_epoch() {
    local pid="$1" lstart="" epoch=""
    lstart=$(ps -p "${pid}" -o lstart= 2>/dev/null) || return 1
    lstart="${lstart#"${lstart%%[![:space:]]*}"}"
    epoch=$(showy_quota_parse_local_epoch "%a %b %e %T %Y" "${lstart}" 2>/dev/null) \
        || epoch=$(showy_quota_parse_local_epoch "%a %e %b %T %Y" "${lstart}" 2>/dev/null) \
        || return 1
    printf '%s\n' "${epoch}"
}

showy_quota_pid_command_matches_managed_serve() {
    local pid="$1" expected_basename="$2" expected_port="$3" command="" token="" previous=""
    local -a tokens=()
    local saw_bin=0 saw_serve=0 saw_port=0
    command=$(ps -p "${pid}" -o command= 2>/dev/null) || return 1
    command="${command#"${command%%[![:space:]]*}"}"
    # Split on whitespace without pathname expansion: an unquoted ${command}
    # would glob ps output (e.g. a literal `*`) against the working directory.
    read -ra tokens <<<"${command}"
    for token in "${tokens[@]}"; do
        if [[ "${token##*/}" == "${expected_basename}" ]]; then
            saw_bin=1
        elif (( saw_bin )) && [[ "${token}" == "serve" ]]; then
            saw_serve=1
        fi

        if [[ "${previous}" == "--port" && "${token}" == "${expected_port}" ]] \
            || [[ "${token}" == "--port=${expected_port}" ]]
        then
            saw_port=1
        fi
        previous="${token}"
    done
    (( saw_bin && saw_serve && saw_port ))
}

managed_serve_pidfile_record() {
    local -n out_pid="$1" out_start_epoch="$2" out_basename="$3"
    out_pid=""
    out_start_epoch=""
    out_basename=""
    [[ -r "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}" ]] || return 1

    local raw=""
    IFS= read -r raw < "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}" || raw=""
    if [[ "${raw}" =~ ^([0-9]+):([0-9]+):([^:[:space:]]+)$ ]]; then
        out_pid="${BASH_REMATCH[1]}"
        out_start_epoch="${BASH_REMATCH[2]}"
        out_basename="${BASH_REMATCH[3]}"
        return 0
    fi
    if [[ "${raw}" =~ ^[0-9]+$ ]]; then
        showy_quota_log "discarding legacy managed serve pidfile"
    elif [[ -n "${raw}" ]]; then
        showy_quota_log "discarding malformed managed serve pidfile"
    fi
    rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}"
    return 1
}

managed_serve_pid_matches_record() {
    local pid="$1" recorded_start_epoch="$2" recorded_basename="$3"
    [[ "${recorded_basename}" == "$(managed_serve_expected_basename)" ]] || return 1
    kill -0 "${pid}" 2>/dev/null || return 1

    local actual_start_epoch="" expected_port="" delta=0
    actual_start_epoch=$(showy_quota_pid_start_epoch "${pid}" 2>/dev/null) || return 1
    expected_port=$(serve_port_from_base_url) || return 1
    showy_quota_pid_command_matches_managed_serve "${pid}" "${recorded_basename}" "${expected_port}" || return 1

    delta=$(( actual_start_epoch > recorded_start_epoch
        ? actual_start_epoch - recorded_start_epoch
        : recorded_start_epoch - actual_start_epoch ))
    (( delta <= 2 ))
}

managed_serve_valid_pidfile() {
    local pid_ref="$1" start_ref="$2" basename_ref="$3"
    local -n out_pid="${pid_ref}" out_start_epoch="${start_ref}" out_basename="${basename_ref}"
    if ! managed_serve_pidfile_record "${pid_ref}" "${start_ref}" "${basename_ref}"; then
        return 1
    fi
    if managed_serve_pid_matches_record "${out_pid}" "${out_start_epoch}" "${out_basename}"; then
        return 0
    fi
    showy_quota_log "discarding stale managed serve pidfile for pid ${out_pid:-unknown}"
    rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}"
    out_pid=""
    out_start_epoch=""
    out_basename=""
    return 1
}

managed_serve_pid_alive() {
    local pid="" start_epoch="" _basename=""
    managed_serve_valid_pidfile pid start_epoch _basename
}
showy_quota_pid_descends_from() {
    local ancestor="$2" current="$1" parent="" i
    for (( i=0; i<32; i++ )); do
        [[ "${current}" == "${ancestor}" ]] && return 0
        parent=$(ps -p "${current}" -o ppid= 2>/dev/null) || return 1
        parent="${parent#"${parent%%[![:space:]]*}"}"
        parent="${parent%%[[:space:]]*}"
        [[ "${parent}" =~ ^[0-9]+$ ]] || return 1
        (( parent > 1 )) || return 1
        [[ "${parent}" != "${current}" ]] || return 1
        current="${parent}"
    done
    return 1
}

managed_serve_owns_configured_port() {
    local pid="" start_epoch="" basename_rec="" port="" listeners="" listener_pid=""
    managed_serve_valid_pidfile pid start_epoch basename_rec || return 1
    showy_quota_have lsof || return 2
    port=$(serve_port_from_base_url) || return 1
    listeners=$(lsof -ti "tcp:${port}" -sTCP:LISTEN 2>/dev/null) || listeners=""
    while IFS= read -r listener_pid; do
        if [[ "${listener_pid}" == "${pid}" ]] \
            || showy_quota_pid_descends_from "${listener_pid}" "${pid}"
        then
            return 0
        fi
    done <<<"${listeners}"
    return 1
}


managed_serve_pid_start_epoch_for_record() {
    local pid="$1" start_epoch="" i
    for (( i=0; i<10; i++ )); do
        start_epoch=$(showy_quota_pid_start_epoch "${pid}" 2>/dev/null) && {
            printf '%s\n' "${start_epoch}"
            return 0
        }
        sleep 0.1
    done
    showy_quota_now_epoch
}

managed_serve_termination_complete() {
    local pid="$1" recorded_start_epoch="$2" recorded_basename="$3" state=""
    kill -0 "${pid}" 2>/dev/null || return 0
    state=$(showy_quota_process_state "${pid}" 2>/dev/null) || state=""
    [[ "${state}" == Z* ]] && return 0
    ! managed_serve_pid_matches_record "${pid}" "${recorded_start_epoch}" "${recorded_basename}"
}

terminate_managed_serve_pid() {
    local pid="$1" recorded_start_epoch="$2" recorded_basename="$3" i
    managed_serve_pid_matches_record "${pid}" "${recorded_start_epoch}" "${recorded_basename}" || return 1
    kill "${pid}" 2>/dev/null || true
    for (( i=0; i<10; i++ )); do
        managed_serve_termination_complete "${pid}" "${recorded_start_epoch}" "${recorded_basename}" && return 0
        sleep 0.1
    done
    # Only escalate while the exact managed process still owns this identity.
    managed_serve_pid_matches_record "${pid}" "${recorded_start_epoch}" "${recorded_basename}" || return 0
    kill -9 "${pid}" 2>/dev/null || true
    for (( i=0; i<10; i++ )); do
        managed_serve_termination_complete "${pid}" "${recorded_start_epoch}" "${recorded_basename}" && return 0
        sleep 0.1
    done
    return 1
}

start_managed_serve() {
    if serve_health_ok; then
        showy_quota_log "adopting healthy codexbar serve before managed startup"
        return 0
    fi
    local bin
    bin=$(codexbar_bin_abs)
    showy_quota_have "${bin}" || return 1

    local port="" refresh_interval="${SHOWY_QUOTA_CODEXBAR_SERVE_REFRESH_INTERVAL_SECONDS:-${SHOWY_QUOTA_REFRESH_SECONDS:-120}}"
    port=$(serve_port_from_base_url) || return 1
    [[ "${refresh_interval}" =~ ^[0-9]+$ ]] || refresh_interval=120

    if showy_quota_have setsid; then
        setsid "${bin}" serve --port "${port}" --refresh-interval "${refresh_interval}" </dev/null >/dev/null 2>&1 &
    else
        nohup "${bin}" serve --port "${port}" --refresh-interval "${refresh_interval}" </dev/null >/dev/null 2>&1 &
    fi
    local pid=$! start_epoch=""
    start_epoch=$(managed_serve_pid_start_epoch_for_record "${pid}")
    # Publish the pidfile as one atomic rename so a concurrent reader never sees
    # a torn/partial record. mktemp in the pidfile's own directory keeps the
    # rename on the same filesystem; fall back to a direct write if mktemp fails.
    local pid_record pid_dir pid_tmp
    pid_record=$(printf '%s:%s:%s' "${pid}" "${start_epoch}" "$(managed_serve_expected_basename)")
    pid_dir=$(dirname -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}")
    if pid_tmp=$(mktemp "${pid_dir}/codexbar-serve.pid.XXXXXX" 2>/dev/null); then
        (umask 077 && printf '%s\n' "${pid_record}" > "${pid_tmp}") \
            && chmod 600 "${pid_tmp}" 2>/dev/null
        if ! mv -f "${pid_tmp}" "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}" 2>/dev/null; then
            rm -f -- "${pid_tmp}"
            rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}"
            (umask 077 && printf '%s\n' "${pid_record}" > "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}")
            chmod 600 "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}" 2>/dev/null || true
        fi
    else
        rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}"
        (umask 077 && printf '%s\n' "${pid_record}" > "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}")
        chmod 600 "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}" 2>/dev/null || true
    fi
    disown "${pid}" 2>/dev/null || true
    showy_quota_log "started managed codexbar serve pid ${pid} on port ${port}"
}
adopt_healthy_serve_after_spawn() {
    local pid="" start_epoch="" basename_rec="" ownership_rc=0
    serve_health_ok || return 1
    if ! managed_serve_valid_pidfile pid start_epoch basename_rec; then
        showy_quota_log "adopting healthy codexbar serve after managed startup"
        return 0
    fi
    if managed_serve_owns_configured_port; then
        return 0
    else
        ownership_rc=$?
    fi
    if (( ownership_rc == 1 )); then
        showy_quota_log "managed codexbar serve pid ${pid} lost port race; adopting healthy responder"
        terminate_managed_serve_pid "${pid}" "${start_epoch}" "${basename_rec}" || return 1
        rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}"
    fi
    return 0
}


restart_managed_serve_once() {
    if (( SHOWY_QUOTA_MANAGED_SERVE_RESTART_ATTEMPTED )); then
        return 1
    fi
    SHOWY_QUOTA_MANAGED_SERVE_RESTART_ATTEMPTED=1

    local pid="" start_epoch="" _basename=""
    if managed_serve_valid_pidfile pid start_epoch _basename; then
        showy_quota_log "restarting unhealthy managed codexbar serve pid ${pid}"
        terminate_managed_serve_pid "${pid}" "${start_epoch}" "${_basename}" || return 1
        rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}"
    fi
    start_managed_serve
}

ensure_serve_running() {
    [[ -n "${SHOWY_QUOTA_CODEXBAR_SERVE_URL}" ]] || return 127
    showy_quota_have curl || return 127
    if serve_health_ok; then
        # Reuse a healthy serve unless it is a provably stale build: only when
        # we may manage serves, both versions are known, and they differ.
        # Pre-#1703 builds expose no /health version (running_version empty)
        # and short-circuit here with zero codexbar spawn.
        if [[ "${SHOWY_QUOTA_MANAGE_SERVE:-1}" != "1" ]]; then
            return 0
        fi
        local running_version=""
        running_version=$(serve_running_version) || running_version=""
        if [[ -z "${running_version}" ]]; then
            return 0
        fi
        local ondisk_version=""
        ondisk_version=$(serve_ondisk_version) || ondisk_version=""
        if [[ -z "${ondisk_version}" || "${running_version}" == "${ondisk_version}" ]]; then
            return 0
        fi
        showy_quota_log "codexbar serve stale: running ${running_version} but on-disk ${ondisk_version}; recycling"
        serve_recycle_stale || return 0
    fi
    [[ "${SHOWY_QUOTA_MANAGE_SERVE:-1}" == "1" ]] || return 1
    if managed_serve_pid_alive; then
        if wait_for_serve_health; then
            return 0
        fi
        restart_managed_serve_once || return 1
        if wait_for_serve_health && adopt_healthy_serve_after_spawn; then
            return 0
        fi
        return 1
    fi
    rm -f -- "${SHOWY_QUOTA_CODEXBAR_SERVE_PID_FILE}"
    start_managed_serve || return 1
    if wait_for_serve_health && adopt_healthy_serve_after_spawn; then
        return 0
    fi
    if managed_serve_pid_alive; then
        restart_managed_serve_once || return 1
        if wait_for_serve_health && adopt_healthy_serve_after_spawn; then
            return 0
        fi
    fi
    return 1
}
if (( stop_serve )); then
    if ! showy_quota_with_lock stop_managed_serve; then
        exit 1
    fi
    exit 0
fi

run_codexbar_serve() {
    local base
    base=$(serve_base_url) || return 127
    showy_quota_have curl || {
        showy_quota_log "curl not found for codexbar serve URL"
        return 127
    }

    curl --fail --silent --show-error --max-time "$(serve_usage_timeout)" --max-filesize "${SHOWY_QUOTA_MAX_USAGE_JSON_BYTES}" "${base}/usage" 2>/dev/null
}

serve_payload_is_publishable() {
    local payload="$1" ids="" id
    printf '%s' "${payload}" | jq -e '
        def valid_provider_id:
            type == "string"
            and (length <= 64)
            and test("^[A-Za-z0-9_.-]+$")
            and . != "."
            and . != ".."
            and (startswith("-") | not);
        def optional_string:
            . == null or type == "string";
        def optional_boolean:
            . == null or type == "boolean";
        def optional_number:
            . == null or type == "number";
        def optional_integer:
            . == null or (type == "number" and floor == .);
        def valid_usage_window:
            type == "object"
            and (.usedPercent | optional_number)
            and (.remainingPercent | optional_number)
            and (.resetsAt | optional_string)
            and (.resetDescription | optional_string)
            and (.windowMinutes | optional_integer);
        type == "array" and
        all(.[]; type == "object"
            and (.provider | valid_provider_id)
            and (
                .status == null
                or (
                    (.status | type) == "object"
                    and (.status.indicator | optional_string)
                    and (.status.url | optional_string)
                )
            )
            and (
                .usage == null
                or (
                    (.usage | type) == "object"
                    and all([.usage.primary, .usage.secondary, .usage.tertiary][];
                        . == null or valid_usage_window
                    )
                    and (
                        (.usage | has("extraRateWindows") | not)
                        or (
                            (.usage.extraRateWindows | type) == "array"
                            and all(.usage.extraRateWindows[];
                                type == "object"
                                and (.id | optional_string)
                                and (.title | optional_string)
                                and (.usageKnown | optional_boolean)
                                and (
                                    .window == null
                                    or (.window | valid_usage_window)
                                )
                            )
                        )
                    )
                )
            )
        )
        and any(.[]?;
            (.provider? | type == "string" and length > 0)
            and any([.usage?.primary, .usage?.secondary, .usage?.tertiary][];
                . != null and (.usedPercent? | type == "number")
            )
        )
    ' >/dev/null 2>&1 || return 1
    ids=$(printf '%s' "${payload}" | jq -r '.[] | .provider' 2>/dev/null) || return 1
    while IFS= read -r id; do
        [[ -n "${id}" ]] || continue
        valid_provider_id "${id}" || return 1
    done < <(printf '%s\n' "${ids}")
    return 0
}

serve_payload_inventory() {
    local ids="" id
    ids=$(printf '%s' "$1" | jq -r '
        if type == "array" then
            .[]
            | .provider?
            | select(type == "string")
            | select(test("^[A-Za-z0-9_.-]+$"))
        else
            error("not an array")
        end
    ' 2>/dev/null) || return 1
    while IFS= read -r id; do
        [[ -n "${id}" ]] || continue
        valid_provider_id "${id}" || continue
        printf '%s\n' "${id}"
    done < <(printf '%s\n' "${ids}") | sort -u
}

run_codexbar_serve_with_recovery() {
    local check_inventory="${1:-0}"
    local out attempt threshold max_attempts=1 inventory_check_available=0 inventory_drift=0 usage_timed_out=0 serve_cmd_rc=0
    threshold=$(serve_failure_restart_threshold)
    if [[ "${SHOWY_QUOTA_MANAGE_SERVE:-1}" == "1" ]] && managed_serve_pid_alive; then
        max_attempts="${threshold}"
    fi
    if ! { (( force_refresh == 0 )) && cache_is_valid && [[ "$(showy_quota_cache_source)" == "serve" ]]; }; then
        serve_failure_backoff_active && return 1
    fi

    local expected_inventory=""
    if (( check_inventory )); then
        if expected_inventory=$(discover_providers 2>/dev/null | sort -u); then
            inventory_check_available=1
        else
            expected_inventory=""
        fi
    fi
    if (( inventory_check_available )) && [[ -z "${expected_inventory}" ]]; then
        showy_quota_log "codexbar reports no enabled providers; skipping serve usage probe"
        return 2
    fi
    for (( attempt=1; attempt<=max_attempts; attempt++ )); do
        serve_cmd_rc=0
        out=$(run_codexbar_serve) || serve_cmd_rc=$?
        if (( serve_cmd_rc == 0 )); then
            if serve_payload_is_publishable "${out}"; then
                if (( inventory_check_available )); then
                    local actual_inventory
                    actual_inventory=$(serve_payload_inventory "${out}") || actual_inventory=""
                    if [[ "${expected_inventory}" != "${actual_inventory}" ]]; then
                        showy_quota_log "codexbar serve inventory is stale: expected [$(printf '%s' "${expected_inventory}" | tr '\n' ' ')] but got [$(printf '%s' "${actual_inventory}" | tr '\n' ' ')]"
                        inventory_drift=1
                        break
                    fi
                fi
                clear_serve_failure
                printf '%s' "${out}"
                return 0
            elif (( inventory_check_available )); then
                local actual_inventory
                if actual_inventory=$(serve_payload_inventory "${out}"); then
                    if [[ -z "${expected_inventory}" ]] || [[ "${expected_inventory}" != "${actual_inventory}" ]]; then
                        showy_quota_log "codexbar serve inventory is stale or empty: expected [$(printf '%s' "${expected_inventory}" | tr '\n' ' ')] but got [$(printf '%s' "${actual_inventory}" | tr '\n' ' ')]"
                        inventory_drift=1
                        break
                    fi
                elif [[ -z "${expected_inventory}" ]]; then
                    showy_quota_log "codexbar serve inventory is empty; rejecting invalid serve payload"
                    inventory_drift=1
                    break
                fi
            fi
        elif (( serve_cmd_rc == 28 )); then
            usage_timed_out=1
            showy_quota_log "codexbar serve /usage timed out; serve is alive but blocking on collection, not restarting"
            break
        fi
    done

    if [[ "${SHOWY_QUOTA_MANAGE_SERVE:-1}" == "1" ]] \
        && (( usage_timed_out == 0 )) \
        && managed_serve_pid_alive \
        && serve_health_ok
    then
        showy_quota_log "codexbar serve /usage failed ${max_attempts} time(s) while /health was OK; restarting managed serve"
        if restart_managed_serve_once && wait_for_serve_health; then
            if out=$(run_codexbar_serve); then
                if serve_payload_is_publishable "${out}"; then
                    if (( inventory_check_available )); then
                        local actual_inventory
                        actual_inventory=$(serve_payload_inventory "${out}") || actual_inventory=""
                        if [[ "${expected_inventory}" != "${actual_inventory}" ]]; then
                            showy_quota_log "codexbar serve inventory still stale after restart: expected [$(printf '%s' "${expected_inventory}" | tr '\n' ' ')] but got [$(printf '%s' "${actual_inventory}" | tr '\n' ' ')]"
                            inventory_drift=1
                            record_serve_failure
                            return 2
                        fi
                    fi
                    clear_serve_failure
                    printf '%s' "${out}"
                    return 0
                elif (( inventory_check_available )); then
                    local actual_inventory
                    if actual_inventory=$(serve_payload_inventory "${out}"); then
                        if [[ -z "${expected_inventory}" ]] || [[ "${expected_inventory}" != "${actual_inventory}" ]]; then
                            showy_quota_log "codexbar serve inventory still stale or empty after restart: expected [$(printf '%s' "${expected_inventory}" | tr '\n' ' ')] but got [$(printf '%s' "${actual_inventory}" | tr '\n' ' ')]"
                            inventory_drift=1
                            record_serve_failure
                            return 2
                        fi
                    elif [[ -z "${expected_inventory}" ]]; then
                        showy_quota_log "codexbar serve inventory still empty after restart; rejecting invalid serve payload"
                        inventory_drift=1
                        record_serve_failure
                        return 2
                    fi
                fi
            fi
        fi
    fi

    record_serve_failure
    (( inventory_drift )) && return 2
    return 1
}

# Run a command in its own process group with a deadline while streaming no
# more than MAX_BYTES + 1 bytes to the caller. The extra byte makes overflow a
# failure before a command substitution can retain an unbounded response.
run_with_hard_timeout() {
    local timeout_seconds="$1"
    local max_bytes="$2"
    shift 2
    [[ "${max_bytes}" =~ ^[0-9]+$ ]] || return 2
    local capture_bytes=$((max_bytes + 1))

    if showy_quota_have python3; then
        python3 -c '
import os
import select
import signal
import subprocess
import sys
import time

timeout = float(sys.argv[1])
max_bytes = int(sys.argv[2])
argv = sys.argv[3:]
capture_bytes = max_bytes + 1

try:
    proc = subprocess.Popen(
        argv,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        stdin=subprocess.DEVNULL,
        start_new_session=True,
    )
except OSError:
    sys.exit(127)

def terminate_process():
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        pass
    try:
        proc.wait(timeout=1)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait()

deadline = time.monotonic() + timeout
written = 0
fd = proc.stdout.fileno()
while True:
    remaining = deadline - time.monotonic()
    if remaining <= 0:
        terminate_process()
        sys.exit(124)
    readable, _, _ = select.select([fd], [], [], remaining)
    if not readable:
        if proc.poll() is not None:
            continue
        terminate_process()
        sys.exit(124)
    chunk = os.read(fd, min(65536, capture_bytes - written))
    if not chunk:
        break
    os.write(sys.stdout.fileno(), chunk)
    written += len(chunk)
    if written == capture_bytes:
        terminate_process()
        sys.exit(125)

try:
    sys.exit(proc.wait(timeout=max(0, deadline - time.monotonic())))
except subprocess.TimeoutExpired:
    terminate_process()
    sys.exit(124)
' "${timeout_seconds}" "${max_bytes}" "$@"
        return $?
    fi

    if showy_quota_have timeout && showy_quota_have head; then
        timeout --kill-after=5s "${timeout_seconds}" "$@" 2>/dev/null | head -c "${capture_bytes}"
        local producer_rc="${PIPESTATUS[0]}"
        return "${producer_rc}"
    fi

    showy_quota_log "python3 or timeout/head not found; refusing uncapped command"
    return 127
}

run_codexbar() {
    local out cache_source="" probe_serve=1 serve_rc=0
    if [[ -n "${SHOWY_QUOTA_CODEXBAR_SERVE_URL}" ]] || cli_failure_backoff_active; then
        if out=$(canonical_empty_inventory_payload); then
            clear_serve_failure
            clear_cli_failure
            printf '%s\n' "cli" > "${SHOWY_QUOTA_REFRESH_SOURCE_FILE}"
            printf '%s' "${out}"
            return 0
        fi
    fi

    if [[ -n "${SHOWY_QUOTA_CODEXBAR_SERVE_URL}" ]]; then
        cache_source="$(showy_quota_cache_source)"
        if (( force_refresh == 0 )) && cache_is_valid && [[ "${cache_source}" != "serve" ]] && serve_failure_backoff_active; then
            probe_serve=0
        fi
        if (( probe_serve )); then
            ensure_serve_running || true
            serve_rc=0
            if out=$(run_codexbar_serve_with_recovery 1); then
                printf '%s\n' "serve" > "${SHOWY_QUOTA_REFRESH_SOURCE_FILE}"
                printf '%s' "${out}"
                return 0
            else
                serve_rc=$?
            fi
        fi
        if (( force_refresh == 0 )) && cache_is_valid && (( serve_rc != 2 )) && ! serve_failure_cli_fallback_allowed; then
            showy_quota_log "preserving valid cache after codexbar serve failure ($(serve_failure_count)/$(serve_failure_cli_threshold)); skipping CLI fallback"
            return 1
        fi
        showy_quota_log "codexbar serve fetch failed or returned no renderable usage; falling back to CLI"
    fi

    if (( serve_rc != 2 )) && cli_failure_backoff_active; then
        return 1
    fi

    if out=$(run_codexbar_cli_per_provider); then
        printf '%s\n' "cli" > "${SHOWY_QUOTA_REFRESH_SOURCE_FILE}"
        printf '%s' "${out}"
        return 0
    fi
    record_cli_failure
    return 1
}

publish_cache_payload() {
    local out="$1" source="${2:-unknown}" tmp stamp_tmp source_tmp payload_marker=""
    SHOWY_QUOTA_CACHE_TMP_FILES=()
    trap showy_quota_exit_cleanup EXIT
    trap 'showy_quota_exit_cleanup; exit 130' INT
    trap 'showy_quota_exit_cleanup; exit 143' TERM
    if ! tmp=$(mktemp "${SHOWY_QUOTA_CACHE_DIR}/usage.XXXXXX"); then
        showy_quota_log "could not create temporary cache file"
        return 1
    fi
    SHOWY_QUOTA_CACHE_TMP_FILES=("${tmp}")

    if [[ -z "${out}" || "${out:0:1}" != '[' ]]; then
        rm -f -- "${tmp}"
        showy_quota_log "codexbar produced no usable output"
        return 1
    fi

    printf '%s' "${out}" > "${tmp}"
    if ! showy_quota_json_valid "${tmp}"; then
        rm -f -- "${tmp}"
        showy_quota_log "codexbar JSON failed validation"
        return 1
    fi
    if ! source_tmp=$(mktemp "${SHOWY_QUOTA_CACHE_DIR}/source.XXXXXX"); then
        rm -f -- "${tmp}"
        showy_quota_log "could not create temporary source file"
        return 1
    fi
    SHOWY_QUOTA_CACHE_TMP_FILES+=("${source_tmp}")
    if ! printf '%s\n' "${source}" > "${source_tmp}"; then
        rm -f -- "${tmp}" "${source_tmp}"
        showy_quota_log "could not write temporary source file"
        return 1
    fi

    if ! showy_quota_refresh_lease_still_owned; then
        rm -f -- "${tmp}" "${source_tmp}"
        return 1
    fi

    # Commit order is payload, source, then generation token. In particular,
    # a failed payload rename cannot expose any new metadata, and a token is
    # minted only after the visible payload has a stable filesystem identity.
    if ! mv -- "${tmp}" "${SHOWY_QUOTA_USAGE_FILE}"; then
        rm -f -- "${tmp}" "${source_tmp}"
        showy_quota_log "could not publish cache file"
        return 1
    fi
    if ! mv -- "${source_tmp}" "${SHOWY_QUOTA_SOURCE_FILE}"; then
        rm -f -- "${source_tmp}"
        showy_quota_log "could not publish source file"
        return 1
    fi
    payload_marker=$(cache_payload_marker)
    if [[ -z "${payload_marker}" ]]; then
        showy_quota_log "could not derive published cache generation"
        return 1
    fi
    if ! stamp_tmp=$(mktemp "${SHOWY_QUOTA_CACHE_DIR}/usage-stamp.XXXXXX"); then
        showy_quota_log "could not create temporary stamp file"
        return 1
    fi
    SHOWY_QUOTA_CACHE_TMP_FILES+=("${stamp_tmp}")
    if ! printf '%s.%s.%s.%s\n' "${payload_marker}" "$(showy_quota_now_epoch)" "$$" "${RANDOM}" > "${stamp_tmp}"; then
        rm -f -- "${stamp_tmp}"
        showy_quota_log "could not write temporary stamp file"
        return 1
    fi
    if ! mv -- "${stamp_tmp}" "${SHOWY_QUOTA_USAGE_STAMP}"; then
        rm -f -- "${stamp_tmp}"
        showy_quota_log "could not publish stamp file"
        return 1
    fi
    chmod 600 "${SHOWY_QUOTA_USAGE_FILE}" "${SHOWY_QUOTA_USAGE_STAMP}" "${SHOWY_QUOTA_SOURCE_FILE}" 2>/dev/null || true
    SHOWY_QUOTA_CACHE_TMP_FILES=()
    showy_quota_log "cache refreshed from ${source} (${#out} bytes)"
    return 0
}

refresh_cache_from_serve() {
    local out serve_rc=0
    [[ -n "${SHOWY_QUOTA_CODEXBAR_SERVE_URL}" ]] || return 127
    if out=$(canonical_empty_inventory_payload); then
        clear_serve_failure
        clear_cli_failure
        publish_cache_payload "${out}" "cli"
        return $?
    fi
    serve_failure_backoff_active && return 1
    ensure_serve_running || true
    serve_rc=0
    if out=$(run_codexbar_serve_with_recovery 1); then
        publish_cache_payload "${out}" "serve"
        return $?
    else
        serve_rc=$?
    fi
    if (( serve_rc == 2 )); then
        showy_quota_log "codexbar serve inventory drift; falling back to CLI"
        if out=$(run_codexbar_cli_per_provider); then
            clear_cli_failure
            publish_cache_payload "${out}" "cli"
            return $?
        fi
        record_cli_failure
    fi
    showy_quota_log "codexbar serve fetch failed or returned no renderable usage"
    return 1
}

refresh_cache() {
    local out rc source

    rc=0
    SHOWY_QUOTA_REFRESH_SOURCE_FILE="${SHOWY_QUOTA_CACHE_DIR}/refresh-source.$$"
    rm -f -- "${SHOWY_QUOTA_REFRESH_SOURCE_FILE}"
    out=$(run_codexbar) || rc=$?
    source="unknown"
    if [[ -r "${SHOWY_QUOTA_REFRESH_SOURCE_FILE}" ]]; then
        IFS= read -r source < "${SHOWY_QUOTA_REFRESH_SOURCE_FILE}" || source="unknown"
    fi
    rm -f -- "${SHOWY_QUOTA_REFRESH_SOURCE_FILE}"
    if [[ -z "${out}" || "${out:0:1}" != '[' ]]; then
        [[ "${source}" == "cli" ]] && record_cli_failure
        showy_quota_log "codexbar produced no usable output (rc=${rc})"
        return 1
    fi

    if publish_cache_payload "${out}" "${source}"; then
        [[ "${source}" == "cli" ]] && clear_cli_failure
        return 0
    fi
    [[ "${source}" == "cli" ]] && record_cli_failure
    return 1
}
refresh_cache_with_quarantine() {
    showy_quota_touch_mkdir_lock_heartbeat
    quarantine_invalid_cache_if_present || return 1
    refresh_cache
}

refresh_cache_from_serve_with_quarantine() {
    showy_quota_touch_mkdir_lock_heartbeat
    quarantine_invalid_cache_if_present || return 1
    refresh_cache_from_serve
}


cache_is_valid() {
    [[ -s "${SHOWY_QUOTA_USAGE_FILE}" ]] || return 1
    showy_quota_json_valid "${SHOWY_QUOTA_USAGE_FILE}"
}


cache_is_fresh() {
    cache_is_valid || return 1
    local age
    age=$(showy_quota_age_seconds "${SHOWY_QUOTA_USAGE_FILE}")
    (( age < SHOWY_QUOTA_REFRESH_SECONDS ))
}

serve_cache_is_fresh() {
    [[ -n "${SHOWY_QUOTA_CODEXBAR_SERVE_URL}" ]] || return 1
    cache_is_valid || return 1
    local seconds="${SHOWY_QUOTA_CODEXBAR_SERVE_REFRESH_SECONDS}" age
    [[ "${seconds}" =~ ^[0-9]+$ ]] || seconds=60
    seconds=$((10#${seconds}))
    (( seconds > 0 )) || return 1
    age=$(showy_quota_age_seconds "${SHOWY_QUOTA_USAGE_FILE}")
    (( age < seconds ))
}

retry_refresh_after_lock_wait() {
    lock_rc=0
    showy_quota_log "retrying refresh after lock wait"
    showy_quota_with_lock refresh_cache_with_quarantine || lock_rc=$?
    if (( lock_rc == 2 || lock_rc == 3 )); then
        showy_quota_wait_for_cache "${SHOWY_QUOTA_LOCK_WAIT_TENTHS}" || true
    fi
}

lock_rc=0
pre_refresh_token=$(cache_token)
pre_refresh_payload_marker=$(cache_payload_marker)
if (( force_refresh )); then
    showy_quota_with_lock refresh_cache_with_quarantine || lock_rc=$?
elif ! cache_is_fresh; then
    showy_quota_with_lock refresh_cache_with_quarantine || lock_rc=$?
elif [[ -n "${SHOWY_QUOTA_CODEXBAR_SERVE_URL}" ]] && ! serve_cache_is_fresh; then
    showy_quota_with_lock refresh_cache_from_serve_with_quarantine || lock_rc=$?
fi

# Lost the lock contest? Forced callers wait for the holder and retry once
# before falling back to the existing cache. Normal cache-first callers may
# keep rendering an existing valid snapshot immediately; only cold/invalid
# cache paths wait for the holder or retry recovery.
if (( lock_rc == 2 || lock_rc == 3 )); then
    if (( force_refresh )); then
        if ! showy_quota_wait_for_cache "${SHOWY_QUOTA_LOCK_WAIT_TENTHS}" "${pre_refresh_token}" "${force_refresh}" "${pre_refresh_payload_marker}"; then
            retry_refresh_after_lock_wait
            if cache_is_valid; then
                if [[ "$(cache_token)" == "${pre_refresh_token}" ]]; then
                    showy_quota_log "refresh timed out; using existing cache"
                fi
            elif (( force_refresh )); then
                showy_quota_die "forced refresh did not publish a valid cache"
            fi
        fi
    elif ! cache_is_valid; then
        showy_quota_wait_for_cache "${SHOWY_QUOTA_LOCK_WAIT_TENTHS}" || true
        cache_is_valid || retry_refresh_after_lock_wait
    fi
fi

# Always emit the most recent valid cache. Bars must never see malformed
# payloads as successful output.
if cache_is_valid; then
    cat "${SHOWY_QUOTA_USAGE_FILE}"
    exit 0
fi

showy_quota_die "no codexbar JSON available and no cache present"
