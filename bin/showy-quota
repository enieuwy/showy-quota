#!/usr/bin/env bash
# showy-quota — browse, preview, and persist palette themes.

if [ "${BASH_VERSINFO[0]:-0}" -lt 4 ]; then
    printf 'showy-quota: bash 4+ required (running %s). On macOS, install Homebrew bash and ensure it precedes /bin/bash on PATH.\n' "${BASH_VERSION:-unknown}" >&2
    exit 1
fi

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd -P)"
CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/showy-quota"
CONFIG_FILE="${CONFIG_DIR}/config.env"
RENDERER="${SCRIPT_DIR}/showy-quota-zellij-bar"
THEME_NAME_RE='^[A-Za-z0-9._-]+$'

usage() {
    printf '%s\n' \
        'Usage: showy-quota [--set <name>|--unset|--current|--list|--preview <name>|--diagnose [--json]|--grant-zellij [path]]' \
        '' \
        'With no flags, opens an interactive theme selector when fzf and a TTY are available.' \
        'Without fzf or a TTY, prints a deterministic theme list and exact set/unset commands.' \
        '' \
        'Flags:' \
        '  --set <name>      Persist SHOWY_QUOTA_THEME=<name> in config.env' \
        '  --unset           Remove the active SHOWY_QUOTA_THEME= line from config.env' \
        '  --current         Print the persisted theme name, or (none)' \
        '  --list            Print available theme names, one per line' \
        '  --preview <name>  Print one ANSI preview strip for a theme' \
        '  --diagnose        Print runtime state useful for bug reports (--json for machines)' \
        '  --grant-zellij [p] Pre-grant Zellij plugin permissions (writes permissions.kdl)' \
        '  -h, --help        Show this help'
}

usage_error() {
    printf 'showy-quota: %s\n\n' "$1" >&2
    usage >&2
    exit 2
}

die() {
    printf 'showy-quota: %s\n' "$1" >&2
    exit 1
}

list_theme_names() {
    local dir path name
    local -a names=()
    declare -A seen=()

    for dir in "${CONFIG_DIR}/themes" "${REPO_ROOT}/share/themes"; do
        [[ -d "${dir}" ]] || continue
        for path in "${dir}"/*.env; do
            [[ -e "${path}" ]] || continue
            name="${path##*/}"
            name="${name%.env}"
            if [[ -z "${seen["${name}"]+x}" ]]; then
                seen["${name}"]=1
                names+=("${name}")
            fi
        done
    done

    ((${#names[@]} > 0)) || return 0
    printf '%s\n' "${names[@]}" | LC_ALL=C sort
}

find_theme_path() {
    local name="$1" path
    [[ "${name}" =~ ${THEME_NAME_RE} ]] || return 1
    for path in \
        "${CONFIG_DIR}/themes/${name}.env" \
        "${REPO_ROOT}/share/themes/${name}.env"
    do
        if [[ -r "${path}" ]]; then
            printf '%s\n' "${path}"
            return 0
        fi
    done
    return 1
}

print_available_themes() {
    local name any=0
    while IFS= read -r name; do
        if (( ! any )); then
            printf 'available themes:\n'
            any=1
        fi
        printf '  %s\n' "${name}"
    done < <(list_theme_names)
    (( any )) || printf 'available themes: (none)\n'
}

validate_theme_or_die() {
    local name="$1"
    if [[ -z "${name}" ]]; then
        die 'theme name is required'
    fi
    if [[ ! "${name}" =~ ${THEME_NAME_RE} ]]; then
        printf 'showy-quota: invalid theme name: %s\n' "${name}" >&2
        printf 'showy-quota: names may contain only A-Z, a-z, 0-9, dot, underscore, and dash\n' >&2
        print_available_themes >&2
        exit 1
    fi
    if ! find_theme_path "${name}" >/dev/null; then
        printf 'showy-quota: unknown theme: %s\n' "${name}" >&2
        print_available_themes >&2
        exit 1
    fi
}

strip_matching_quotes() {
    local value="$1"
    if (( ${#value} >= 2 )) && [[ "${value}" == \"*\" && "${value}" == *\" ]]; then
        value="${value:1:${#value}-2}"
    elif (( ${#value} >= 2 )) && [[ "${value}" == \'*\' && "${value}" == *\' ]]; then
        value="${value:1:${#value}-2}"
    fi
    printf '%s' "${value}"
}

current_theme_value() {
    local line value current=""
    [[ -r "${CONFIG_FILE}" ]] || return 0

    while IFS= read -r line || [[ -n "${line}" ]]; do
        if [[ "${line}" =~ ^[[:space:]]*(export[[:space:]]+)?SHOWY_QUOTA_THEME= ]]; then
            value="${line#*=}"
            value="${value%%[[:space:]]*}"
            value=$(strip_matching_quotes "${value}")
            current="${value}"
        fi
    done < "${CONFIG_FILE}"

    [[ -n "${current}" ]] && printf '%s\n' "${current}"

    return 0
}

print_current_theme() {
    local current
    current=$(current_theme_value)
    printf '%s\n' "${current:-(none)}"
}

write_config_lines() {
    local mode="$1" theme="${2:-}"
    local tmp line last_index
    local -a lines=()
    local matched=0
    local wrote=0
    local i

    if [[ -f "${CONFIG_FILE}" ]]; then
        while IFS= read -r line || [[ -n "${line}" ]]; do
            lines+=("${line}")
        done < "${CONFIG_FILE}"
    fi

    for line in "${lines[@]}"; do
        if [[ "${line}" =~ ^[[:space:]]*(export[[:space:]]+)?SHOWY_QUOTA_THEME= ]]; then
            matched=1
            break
        fi
    done

    if [[ "${mode}" == "unset" && "${matched}" == 0 ]]; then
        return 0
    fi

    tmp=$(mktemp "${CONFIG_FILE}.tmp.XXXXXX") || die "cannot create temporary config next to ${CONFIG_FILE}"
    if ! {
        for i in "${!lines[@]}"; do
            line="${lines[$i]}"
            if [[ "${line}" =~ ^([[:space:]]*)(export[[:space:]]+)?SHOWY_QUOTA_THEME= ]]; then
                if [[ "${mode}" == "set" && "${wrote}" == 0 ]]; then
                    printf '%s%sSHOWY_QUOTA_THEME=%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]:-}" "${theme}"
                    wrote=1
                fi
                continue
            fi
            printf '%s\n' "${line}"
        done

        if [[ "${mode}" == "set" && "${matched}" == 0 ]]; then
            if ((${#lines[@]} > 0)); then
                last_index=$((${#lines[@]} - 1))
                [[ -z "${lines[$last_index]}" ]] || printf '\n'
            fi
            printf 'SHOWY_QUOTA_THEME=%s\n' "${theme}"
        fi
    } > "${tmp}"; then
        rm -f -- "${tmp}"
        die "cannot write temporary config next to ${CONFIG_FILE}"
    fi

    if ! mv -f -- "${tmp}" "${CONFIG_FILE}"; then
        die "cannot replace ${CONFIG_FILE}; temporary file left at ${tmp}"
    fi
}

set_theme() {
    local name="$1"
    validate_theme_or_die "${name}"
    mkdir -p -- "${CONFIG_DIR}" || die "cannot create ${CONFIG_DIR}"
    write_config_lines set "${name}"
}

unset_theme() {
    [[ -e "${CONFIG_FILE}" ]] || return 0
    write_config_lines unset
}

ordered_theme_names() {
    local current="${1:-}" name
    local printed_current=0

    if [[ -n "${current}" ]] && find_theme_path "${current}" >/dev/null; then
        printf '%s\n' "${current}"
        printed_current=1
    fi

    while IFS= read -r name; do
        if (( printed_current )) && [[ "${name}" == "${current}" ]]; then
            continue
        fi
        printf '%s\n' "${name}"
    done < <(list_theme_names)
}

print_fallback_selector() {
    local current="$1" name any=0
    printf 'Current theme: %s\n' "${current:-(none)}"
    printf '\nAvailable themes:\n'
    while IFS= read -r name; do
        any=1
        printf '  %s\n' "${name}"
    done < <(ordered_theme_names "${current}")
    (( any )) || printf '  (none)\n'
    printf '\nSet a theme:\n  showy-quota --set <name>\n'
    printf 'Unset persisted theme:\n  showy-quota --unset\n'
}

run_fzf_selector() {
    local current="$1" selection preview_cmd unset_cmd
    printf -v preview_cmd '%q --preview {}' "${SCRIPT_PATH}"
    printf -v unset_cmd '%q --unset' "${SCRIPT_PATH}"

    if selection=$(ordered_theme_names "${current}" | fzf \
        --prompt='theme> ' \
        --header='enter: save  esc: cancel  ctrl-x: clear theme  arrows/hjkl: browse' \
        --preview="${preview_cmd}" \
        --preview-window='right,60%,wrap' \
        --bind='h:up,j:down,k:up,l:down,up:up,down:down' \
        --bind="ctrl-x:execute(${unset_cmd})+abort"); then
        [[ -n "${selection}" ]] && set_theme "${selection}"
    fi
}

run_selector() {
    local current
    current=$(current_theme_value)
    if [[ -z "${SHOWY_QUOTA_TEST_NO_FZF:-}" ]] && [[ -t 0 ]] && command -v fzf >/dev/null 2>&1; then
        run_fzf_selector "${current}"
    else
        print_fallback_selector "${current}"
    fi
}

preview_fixture_json() {
    cat <<'JSON'
[
  {"provider":"claude","usage":{
    "primary":  {"usedPercent":17,"resetsAt":"2099-01-01T03:29:00Z","windowMinutes":300},
    "secondary":{"usedPercent":70,"resetsAt":"2099-01-03T00:00:00Z","windowMinutes":10080}
  }},
  {"provider":"codex","usage":{
    "primary":  {"usedPercent":92,"resetsAt":"2099-01-01T00:23:00Z","windowMinutes":10080},
    "secondary":{"usedPercent":35,"resetsAt":"2099-01-04T12:00:00Z","windowMinutes":10080}
  }}
]
JSON
}

preview_theme() {
    local name="$1"
    validate_theme_or_die "${name}"

    SHOWY_QUOTA_THEME="${name}" \
        SHOWY_QUOTA_NO_CONFIG=1 \
        SHOWY_QUOTA_FORCE_COLOR=1 \
        SHOWY_QUOTA_NOW_EPOCH=4070908800 \
        "${RENDERER}" --json - < <(preview_fixture_json)
}

print_tool_path() {
    local name="$1" path
    if path=$(command -v "${name}" 2>/dev/null); then
        printf '  %-12s %s\n' "${name}" "${path}"
    else
        printf '  %-12s (missing)\n' "${name}"
    fi
}

json_string() {
    jq -Rn --arg value "$1" '$value'
}

json_number_or_null() {
    local value="$1"
    if [[ "${value}" =~ ^[0-9]+$ ]]; then
        printf '%s' "${value}"
    else
        printf 'null'
    fi
}

diagnose_env_vars() {
    printf '%s\n' \
        SHOWY_QUOTA_REFRESH_SECONDS \
        SHOWY_QUOTA_LOCK_WAIT_TENTHS \
        SHOWY_QUOTA_CACHE_DIR \
        SHOWY_QUOTA_CODEXBAR_BIN \
        SHOWY_QUOTA_CODEXBAR_SERVE_URL \
        SHOWY_QUOTA_CODEXBAR_SERVE_TIMEOUT_SECONDS \
        SHOWY_QUOTA_CODEXBAR_SERVE_USAGE_TIMEOUT_SECONDS \
        SHOWY_QUOTA_CODEXBAR_SERVE_REFRESH_SECONDS \
        SHOWY_QUOTA_PROVIDERS \
        SHOWY_QUOTA_PROVIDERS_EXCLUDE \
        SHOWY_QUOTA_PROVIDER_ORDER \
        SHOWY_QUOTA_INCLUDE_STATUS \
        SHOWY_QUOTA_THEME \
        SHOWY_QUOTA_TIME_WARN_MINUTES \
        SHOWY_QUOTA_DEBUG \
        SHOWY_QUOTA_FORCE_COLOR \
        SHOWY_QUOTA_NO_CONFIG \
        SHOWY_QUOTA_SKETCHYBAR_PROVIDER_ICON_MODE \
        SHOWY_QUOTA_SKETCHYBAR_UPDATE_FREQ \
        SHOWY_QUOTA_ZELLIJ_WIDGET \
        SHOWY_QUOTA_ZELLIJ_PIPE_INTERVAL \
        SHOWY_QUOTA_ZELLIJ_BIN
}

diagnose_env_json() {
    local first=1 var value
    printf '{'
    while IFS= read -r var; do
        [[ -n "${!var:-}" ]] || continue
        value=$(json_string "${!var}")
        (( first )) || printf ','
        first=0
        printf '"%s":%s' "${var}" "${value}"
    done < <(diagnose_env_vars)
    printf '}'
}

diagnose_tools_json() {
    local first=1 name path
    printf '{'
    for name in "$@"; do
        (( first )) || printf ','
        first=0
        if path=$(command -v "${name}" 2>/dev/null); then
            printf '"%s":{"available":true,"path":%s}' "${name}" "$(json_string "${path}")"
        else
            printf '"%s":{"available":false,"path":null}' "${name}"
        fi
    done
    printf '}'
}

diagnose_json() {
    command -v jq >/dev/null 2>&1 || die 'jq is required for --diagnose --json'

    local fetch_bin state_bin cache_path cache_age cache_size_json state_json config_status config_readable
    local env_json required_tools_json optional_tools_json cb cb_path cb_available cb_cache_count_json
    fetch_bin="${SCRIPT_DIR}/showy-quota-fetch"
    state_bin="${SCRIPT_DIR}/showy-quota-state"

    cache_path=""
    cache_age=""
    cache_size_json=null
    if [[ -x "${fetch_bin}" ]]; then
        cache_path="$("${fetch_bin}" --path 2>/dev/null || true)"
        cache_age="$("${fetch_bin}" --age 2>/dev/null || true)"
        if [[ -n "${cache_path}" && -f "${cache_path}" ]]; then
            cache_size_json=$(json_number_or_null "$(wc -c < "${cache_path}" 2>/dev/null | tr -d ' ' || true)")
        fi
    fi

    if [[ -x "${state_bin}" ]]; then
        state_json="$("${state_bin}" 2>/dev/null || printf 'null')"
        if ! jq -e 'type == "object"' >/dev/null 2>&1 <<< "${state_json}"; then
            state_json=null
        fi
    else
        state_json=null
    fi

    if [[ -r "${CONFIG_FILE}" ]]; then
        config_status=readable
        config_readable=true
    elif [[ -e "${CONFIG_FILE}" ]]; then
        config_status=unreadable
        config_readable=false
    else
        config_status=absent
        config_readable=null
    fi

    cb="${SHOWY_QUOTA_CODEXBAR_BIN:-codexbar}"
    cb_available=false
    cb_path=""
    if cb_path=$(command -v "${cb}" 2>/dev/null); then
        cb_available=true
    fi
    cb_cache_count_json=null
    if [[ -n "${cache_path}" && -f "${cache_path}" ]]; then
        cb_cache_count_json=$(jq 'if type == "array" then length else null end' "${cache_path}" 2>/dev/null || printf 'null')
    fi

    env_json=$(diagnose_env_json)
    required_tools_json=$(diagnose_tools_json bash jq codexbar)
    optional_tools_json=$(diagnose_tools_json curl flock sketchybar magick zellij tmux fzf)

    jq -n \
        --arg showyQuota "${SCRIPT_PATH}" \
        --arg repoRoot "${REPO_ROOT}" \
        --arg bashVersion "${BASH_VERSION:-unknown}" \
        --arg uname "$(uname -srm 2>/dev/null || printf 'unknown')" \
        --arg configFile "${CONFIG_FILE}" \
        --arg configStatus "${config_status}" \
        --argjson configReadable "${config_readable}" \
        --arg theme "$(current_theme_value 2>/dev/null || true)" \
        --arg fetchBin "${fetch_bin}" \
        --arg cachePath "${cache_path}" \
        --arg cacheAge "${cache_age}" \
        --argjson cacheSize "${cache_size_json}" \
        --argjson state "${state_json}" \
        --argjson envKnobs "${env_json}" \
        --argjson requiredTools "${required_tools_json}" \
        --argjson optionalTools "${optional_tools_json}" \
        --arg codexbarCommand "${cb}" \
        --arg codexbarPath "${cb_path}" \
        --argjson codexbarAvailable "${cb_available}" \
        --argjson cachedProviderCount "${cb_cache_count_json}" \
        '{
            paths: {
                showyQuota: $showyQuota,
                repoRoot: $repoRoot,
                fetch: $fetchBin,
                cache: (if $cachePath == "" then null else $cachePath end),
                config: $configFile
            },
            runtime: {
                bash: $bashVersion,
                uname: $uname
            },
            tools: {
                required: $requiredTools,
                optional: $optionalTools
            },
            config: {
                path: $configFile,
                status: $configStatus,
                readable: $configReadable,
                theme: (if $theme == "" then null else $theme end)
            },
            cache: {
                path: (if $cachePath == "" then null else $cachePath end),
                ageSeconds: (if ($cacheAge | test("^[0-9]+$")) then ($cacheAge | tonumber) else null end),
                sizeBytes: $cacheSize
            },
            state: $state,
            env: $envKnobs,
            codexbarProbe: {
                command: $codexbarCommand,
                available: $codexbarAvailable,
                path: (if $codexbarPath == "" then null else $codexbarPath end),
                cachedProviderCount: $cachedProviderCount
            }
        }'
}

diagnose() {
    local fetch_bin state_bin cache_path cache_age
    fetch_bin="${SCRIPT_DIR}/showy-quota-fetch"
    state_bin="${SCRIPT_DIR}/showy-quota-state"

    printf '## showy-quota diagnose\n'
    printf 'showy-quota:    %s\n' "${SCRIPT_PATH}"
    printf 'repo root:    %s\n' "${REPO_ROOT}"
    printf 'bash:         %s\n' "${BASH_VERSION:-unknown}"
    printf 'uname:        %s\n' "$(uname -srm 2>/dev/null || printf 'unknown')"

    printf '\n# Required tools\n'
    print_tool_path bash
    print_tool_path jq
    print_tool_path codexbar
    printf '\n# Optional tools\n'
    print_tool_path curl
    print_tool_path flock
    print_tool_path sketchybar
    print_tool_path magick
    print_tool_path zellij
    print_tool_path tmux
    print_tool_path fzf

    printf '\n# Config\n'
    if [[ -r "${CONFIG_FILE}" ]]; then
        printf 'config:       %s (readable)\n' "${CONFIG_FILE}"
    elif [[ -e "${CONFIG_FILE}" ]]; then
        printf 'config:       %s (exists, unreadable)\n' "${CONFIG_FILE}"
    else
        printf 'config:       %s (none — defaults in effect)\n' "${CONFIG_FILE}"
    fi
    printf 'theme:        %s\n' "$(current_theme_value 2>/dev/null || printf '(none)')"

    printf '\n# Cache\n'
    if [[ -x "${fetch_bin}" ]]; then
        cache_path="$("${fetch_bin}" --path 2>/dev/null || printf '(unknown)')"
        cache_age="$("${fetch_bin}" --age 2>/dev/null || printf '(unknown)')"
        printf 'cache file:   %s\n' "${cache_path}"
        printf 'cache age:    %ss\n' "${cache_age}"
        if [[ -f "${cache_path}" ]]; then
            printf 'cache size:   %s bytes\n' "$(wc -c < "${cache_path}" 2>/dev/null | tr -d ' ' || printf 'unknown')"
        else
            printf 'cache size:   (file absent)\n'
        fi
    else
        printf 'cache:        showy-quota-fetch missing or non-executable: %s\n' "${fetch_bin}"
    fi

    printf '\n# State\n'
    if [[ -x "${state_bin}" ]]; then
        "${state_bin}" 2>&1 | sed 's/^/  /'
    else
        printf '  showy-quota-state missing or non-executable: %s\n' "${state_bin}"
    fi

    printf '\n# Env knobs (set values only)\n'
    local var
    while IFS= read -r var; do
        if [[ -n "${!var:-}" ]]; then
            printf '  %s=%s\n' "${var}" "${!var}"
        fi
    done < <(diagnose_env_vars)

    printf '\n# CodexBar probe\n'
    local cb="${SHOWY_QUOTA_CODEXBAR_BIN:-codexbar}"
    if ! command -v "${cb}" >/dev/null 2>&1; then
        printf 'codexbar binary not on PATH (set SHOWY_QUOTA_CODEXBAR_BIN or install codexbar)\n'
    elif ! command -v jq >/dev/null 2>&1; then
        printf 'codexbar present; jq missing — cannot count providers\n'
    elif [[ -f "${SHOWY_QUOTA_USAGE_FILE:-${HOME}/.cache/showy-quota/usage.json}" ]]; then
        local cache_file count
        cache_file="${SHOWY_QUOTA_USAGE_FILE:-${HOME}/.cache/showy-quota/usage.json}"
        count=$(jq 'length' "${cache_file}" 2>/dev/null || printf '?')
        printf 'cached provider count = %s (from %s)\n' "${count}" "${cache_file}"
        printf '(skipping live %s usage probe; rerun bin/showy-quota-fetch --refresh to refresh)\n' "${cb}"
    else
        printf 'no cache yet; run bin/showy-quota-fetch --refresh to populate, then re-run --diagnose\n'
    fi
}

zellij_permissions_file() {
    if [[ -n "${SHOWY_QUOTA_ZELLIJ_PERMISSIONS_FILE:-}" ]]; then
        # grant_zellij writes a KDL block to this path; require an absolute
        # *.kdl path so an attacker-set env var cannot redirect the write to a
        # shell rc, LaunchAgent plist, ~/.ssh/authorized_keys, cron file, etc.
        if [[ "${SHOWY_QUOTA_ZELLIJ_PERMISSIONS_FILE}" != /*.kdl ]]; then
            die "SHOWY_QUOTA_ZELLIJ_PERMISSIONS_FILE must be an absolute path to a .kdl file: ${SHOWY_QUOTA_ZELLIJ_PERMISSIONS_FILE}"
        fi
        printf '%s' "${SHOWY_QUOTA_ZELLIJ_PERMISSIONS_FILE}"
        return 0
    fi
    local dir
    case "$(uname -s 2>/dev/null || printf 'unknown')" in
        Darwin) dir="${HOME}/Library/Caches/org.Zellij-Contributors.Zellij" ;;
        *)      dir="${XDG_CACHE_HOME:-${HOME}/.cache}/zellij" ;;
    esac
    printf '%s/permissions.kdl' "${dir}"
}

# Expand a leading ~ and make the path absolute without resolving symlinks,
# matching how Zellij derives a plugin's permission-cache key (shellexpand only).
resolve_abs_path() {
    local path="$1" tilde='~'
    if [[ "${path}" == "${tilde}" ]]; then
        path="${HOME}"
    elif [[ "${path}" == "${tilde}/"* ]]; then
        path="${HOME}/${path:2}"
    fi
    [[ "${path}" == /* ]] || path="$(pwd -P)/${path}"
    printf '%s' "${path}"
}

# Pre-grant the standalone Zellij plugin's permissions so it never prompts on
# first launch. The grant lives in Zellij's permissions.kdl (a cache file that
# macOS may purge), keyed by the plugin's location; re-running this is safe and
# re-heals after a purge. Other plugins' grants are preserved.
grant_zellij() {
    local plugin_arg="${1:-}" plugin_path plugins_dir
    if [[ -n "${plugin_arg}" ]]; then
        plugin_path="$(resolve_abs_path "${plugin_arg}")"
    else
        plugins_dir="${ZELLIJ_PLUGINS:-${HOME}/.config/zellij/plugins}"
        plugin_path="$(resolve_abs_path "${plugins_dir}/showy-quota-zellij.wasm")"
    fi

    # The path is written into a KDL string literal ("<key>" { … }); a quote,
    # backslash, or control char would let it break out and inject KDL nodes.
    if [[ "${plugin_path}" == *'"'* || "${plugin_path}" == *\\* || "${plugin_path}" == *[$'\x01'-$'\x1f']* ]]; then
        die "plugin path contains characters unsafe for the KDL permissions file (quote, backslash, or control char): ${plugin_path}"
    fi

    if [[ ! -e "${plugin_path}" ]]; then
        printf 'showy-quota: warning: no plugin file at %s\n' "${plugin_path}" >&2
        printf 'showy-quota: granting anyway — ensure this matches the layout "location" entry\n' >&2
    fi

    # Zellij 0.44.x keys grants on the bare absolute path; older versions used
    # the `file:` URL form. Write every plausible key so the grant survives
    # version differences and home-relative `file:~` layout entries.
    local -a keys=("${plugin_path}" "file:${plugin_path}")
    [[ "${plugin_path}" == "${HOME}/"* ]] && keys+=("file:~/${plugin_path#"${HOME}/"}")

    local perms_file perms_dir
    perms_file="$(zellij_permissions_file)"
    perms_dir="${perms_file%/*}"
    mkdir -p -- "${perms_dir}" || die "cannot create ${perms_dir}"

    # Rebuild the file: drop any block we own (idempotent), preserve the rest.
    local block_re='^[[:space:]]*"?([^"{]*[^"[:space:]{])"?[[:space:]]*\{[[:space:]]*$'
    local close_re='^[[:space:]]*\}[[:space:]]*$'
    local -a kept=()
    local skipping=0 line name key managed last
    if [[ -f "${perms_file}" ]]; then
        while IFS= read -r line || [[ -n "${line}" ]]; do
            if (( skipping )); then
                [[ "${line}" =~ ${close_re} ]] && skipping=0
                continue
            fi
            if [[ "${line}" =~ ${block_re} ]]; then
                name="${BASH_REMATCH[1]}"
                managed=0
                for key in "${keys[@]}"; do
                    [[ "${name}" == "${key}" ]] && { managed=1; break; }
                done
                if (( managed )); then
                    skipping=1
                    continue
                fi
            fi
            kept+=("${line}")
        done < "${perms_file}"
    fi
    # Drop trailing blank lines so appended blocks sit flush.
    while ((${#kept[@]})); do
        last=$(( ${#kept[@]} - 1 ))
        [[ -z "${kept[$last]}" ]] || break
        unset "kept[$last]"
    done

    local tmp
    tmp="$(mktemp "${perms_file}.tmp.XXXXXX")" || die "cannot create temporary file next to ${perms_file}"
    if ! {
        if ((${#kept[@]})); then printf '%s\n' "${kept[@]}"; fi
        for key in "${keys[@]}"; do
            printf '"%s" {\n    WebAccess\n    OpenTerminalsOrPlugins\n    RunCommands\n}\n' "${key}"
        done
    } > "${tmp}"; then
        rm -f -- "${tmp}"
        die "cannot write temporary file next to ${perms_file}"
    fi
    if ! mv -f -- "${tmp}" "${perms_file}"; then
        rm -f -- "${tmp}"
        die "cannot replace ${perms_file}; temporary file left behind"
    fi

    printf 'showy-quota: pre-granted Zellij plugin permissions\n'
    printf '  permissions file: %s\n' "${perms_file}"
    printf '  plugin path:      %s\n' "${plugin_path}"
    printf '  keys written:     %s\n' "${#keys[@]}"
    printf '  permissions:      WebAccess OpenTerminalsOrPlugins RunCommands\n'
    printf 'Open a new Zellij tab (or restart Zellij) for the grant to take effect.\n'
}

main() {
    if (($# == 0)); then
        run_selector
        return 0
    fi

    case "$1" in
        --set)
            (($# == 2)) || usage_error '--set requires exactly one theme name'
            set_theme "$2"
            ;;
        --unset)
            (($# == 1)) || usage_error '--unset does not accept arguments'
            unset_theme
            ;;
        --current)
            (($# == 1)) || usage_error '--current does not accept arguments'
            print_current_theme
            ;;
        --list)
            (($# == 1)) || usage_error '--list does not accept arguments'
            list_theme_names
            ;;
        --preview)
            (($# == 2)) || usage_error '--preview requires exactly one theme name'
            preview_theme "$2"
            ;;
        --diagnose)
            if (($# == 2)); then
                [[ "$2" == "--json" ]] || usage_error '--diagnose only accepts --json'
                diagnose_json
            else
                (($# == 1)) || usage_error '--diagnose only accepts --json'
                diagnose
            fi
            ;;
        --grant-zellij)
            if (($# == 2)); then
                grant_zellij "$2"
            else
                (($# == 1)) || usage_error '--grant-zellij accepts at most one plugin path'
                grant_zellij ""
            fi
            ;;
        -h|--help)
            (($# == 1)) || usage_error '--help does not accept arguments'
            usage
            ;;
        *)
            usage_error "unknown argument: $1"
            ;;
    esac
}

main "$@"
