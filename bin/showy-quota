#!/usr/bin/env bash
# showy-quota — browse, preview, and persist palette themes.

if [ "${BASH_VERSINFO[0]:-0}" -lt 4 ]; then
    printf 'showy-quota: bash 4+ required (running %s). On macOS, install Homebrew bash and ensure it precedes /bin/bash on PATH.\n' "${BASH_VERSION:-unknown}" >&2
    exit 1
fi

set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    link=$(readlink "${SCRIPT_PATH}")
    if [[ "${link}" == /* ]]; then
        SCRIPT_PATH="${link}"
    else
        SCRIPT_PATH="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)/${link}"
    fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd -P)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd -P)"
CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/showy-quota"
CONFIG_FILE="${CONFIG_DIR}/config.env"
RENDERER="${SCRIPT_DIR}/showy-quota-zellij-bar"
THEME_NAME_RE='^[A-Za-z0-9._-]+$'

usage() {
    printf '%s\n' \
        'Usage: showy-quota [--set <name>|--unset|--current|--list|--preview <name>|--diagnose [--json]|--grant-zellij [path]]' \
        '       showy-quota guard [opts]   |   showy-quota prompt [opts]   (run either with -h for details)' \
        '' \
        'With no flags, opens an interactive theme selector when fzf and a TTY are available.' \
        'Without fzf or a TTY, prints a deterministic theme list and exact set/unset commands.' \
        '' \
        'Flags:' \
        '  --set <name>      Persist SHOWY_QUOTA_THEME=<name> in config.env' \
        '  --unset           Remove the active SHOWY_QUOTA_THEME= line from config.env' \
        '  --current         Print the persisted theme name, or (none)' \
        '  --list            Print available theme names, one per line' \
        '  --preview <name>  Print one ANSI preview strip for a theme' \
        '  --diagnose        Print runtime state useful for bug reports (--json for machines)' \
        '  --grant-zellij [p] Pre-grant Zellij plugin permissions (writes permissions.kdl)' \
        '  guard [opts]      Evaluate quota thresholds for automation (exit 0/1/2/3); "guard -h" for options' \
        '  prompt [opts]     Print a one-line quota segment for shell prompts; "prompt -h" for options' \
        '  -h, --help        Show this help'
}

usage_error() {
    printf 'showy-quota: %s\n\n' "$1" >&2
    usage >&2
    exit 2
}

die() {
    printf 'showy-quota: %s\n' "$1" >&2
    exit 1
}

TEMP_FILES=()

cleanup_temp_files() {
    local file
    for file in "${TEMP_FILES[@]}"; do
        [[ -n "${file}" ]] && rm -f -- "${file}"
    done
}

trap cleanup_temp_files EXIT
trap 'cleanup_temp_files; exit 130' INT
trap 'cleanup_temp_files; exit 143' TERM

track_temp_file() {
    TEMP_FILES+=("$1")
}


list_theme_names() {
    local dir path name
    local -a names=()
    declare -A seen=()

    for dir in "${CONFIG_DIR}/themes" "${REPO_ROOT}/share/themes"; do
        [[ -d "${dir}" ]] || continue
        for path in "${dir}"/*.env; do
            [[ -e "${path}" ]] || continue
            name="${path##*/}"
            name="${name%.env}"
            if [[ -z "${seen["${name}"]+x}" ]]; then
                seen["${name}"]=1
                names+=("${name}")
            fi
        done
    done

    ((${#names[@]} > 0)) || return 0
    printf '%s\n' "${names[@]}" | LC_ALL=C sort
}

find_theme_path() {
    local name="$1" path
    [[ "${name}" =~ ${THEME_NAME_RE} ]] || return 1
    for path in \
        "${CONFIG_DIR}/themes/${name}.env" \
        "${REPO_ROOT}/share/themes/${name}.env"
    do
        if [[ -r "${path}" ]]; then
            printf '%s\n' "${path}"
            return 0
        fi
    done
    return 1
}

print_available_themes() {
    local name any=0
    while IFS= read -r name; do
        if (( ! any )); then
            printf 'available themes:\n'
            any=1
        fi
        printf '  %s\n' "${name}"
    done < <(list_theme_names)
    (( any )) || printf 'available themes: (none)\n'
}

validate_theme_or_die() {
    local name="$1"
    if [[ -z "${name}" ]]; then
        die 'theme name is required'
    fi
    if [[ ! "${name}" =~ ${THEME_NAME_RE} ]]; then
        printf 'showy-quota: invalid theme name: %s\n' "${name}" >&2
        printf 'showy-quota: names may contain only A-Z, a-z, 0-9, dot, underscore, and dash\n' >&2
        print_available_themes >&2
        exit 1
    fi
    if ! find_theme_path "${name}" >/dev/null; then
        printf 'showy-quota: unknown theme: %s\n' "${name}" >&2
        print_available_themes >&2
        exit 1
    fi
}

strip_matching_quotes() {
    local value="$1"
    if (( ${#value} >= 2 )) && [[ "${value}" == \"*\" && "${value}" == *\" ]]; then
        value="${value:1:${#value}-2}"
    elif (( ${#value} >= 2 )) && [[ "${value}" == \'*\' && "${value}" == *\' ]]; then
        value="${value:1:${#value}-2}"
    fi
    printf '%s' "${value}"
}

current_theme_value() {
    local line value current=""
    [[ -r "${CONFIG_FILE}" ]] || return 0

    while IFS= read -r line || [[ -n "${line}" ]]; do
        if [[ "${line}" =~ ^[[:space:]]*(export[[:space:]]+)?SHOWY_QUOTA_THEME= ]]; then
            value="${line#*=}"
            value="${value%%[[:space:]]*}"
            value=$(strip_matching_quotes "${value}")
            current="${value}"
        fi
    done < "${CONFIG_FILE}"

    [[ -n "${current}" ]] && printf '%s\n' "${current}"

    return 0
}

print_current_theme() {
    local current
    current=$(current_theme_value)
    printf '%s\n' "${current:-(none)}"
}

write_config_lines() {
    local mode="$1" theme="${2:-}"
    local tmp line last_index
    local -a lines=()
    local matched=0
    local wrote=0
    local i

    if [[ -f "${CONFIG_FILE}" ]]; then
        while IFS= read -r line || [[ -n "${line}" ]]; do
            lines+=("${line}")
        done < "${CONFIG_FILE}"
    fi

    for line in "${lines[@]}"; do
        if [[ "${line}" =~ ^[[:space:]]*(export[[:space:]]+)?SHOWY_QUOTA_THEME= ]]; then
            matched=1
            break
        fi
    done

    if [[ "${mode}" == "unset" && "${matched}" == 0 ]]; then
        return 0
    fi

    tmp=$(umask 077 && mktemp "${CONFIG_FILE}.tmp.XXXXXX") || die "cannot create temporary config next to ${CONFIG_FILE}"
    track_temp_file "${tmp}"
    if ! {
        for i in "${!lines[@]}"; do
            line="${lines[$i]}"
            if [[ "${line}" =~ ^([[:space:]]*)(export[[:space:]]+)?SHOWY_QUOTA_THEME= ]]; then
                if [[ "${mode}" == "set" && "${wrote}" == 0 ]]; then
                    printf '%s%sSHOWY_QUOTA_THEME=%s\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]:-}" "${theme}"
                    wrote=1
                fi
                continue
            fi
            printf '%s\n' "${line}"
        done

        if [[ "${mode}" == "set" && "${matched}" == 0 ]]; then
            if ((${#lines[@]} > 0)); then
                last_index=$((${#lines[@]} - 1))
                [[ -z "${lines[$last_index]}" ]] || printf '\n'
            fi
            printf 'SHOWY_QUOTA_THEME=%s\n' "${theme}"
        fi
    } > "${tmp}"; then
        die "cannot write temporary config next to ${CONFIG_FILE}"
    fi

    if ! mv -f -- "${tmp}" "${CONFIG_FILE}"; then
        die "cannot replace ${CONFIG_FILE}"
    fi
}

set_theme() {
    local name="$1"
    validate_theme_or_die "${name}"
    (umask 077 && mkdir -p -- "${CONFIG_DIR}") || die "cannot create ${CONFIG_DIR}"
    write_config_lines set "${name}"
}

unset_theme() {
    [[ -e "${CONFIG_FILE}" ]] || return 0
    write_config_lines unset
}

ordered_theme_names() {
    local current="${1:-}" name
    local printed_current=0

    if [[ -n "${current}" ]] && find_theme_path "${current}" >/dev/null; then
        printf '%s\n' "${current}"
        printed_current=1
    fi

    while IFS= read -r name; do
        if (( printed_current )) && [[ "${name}" == "${current}" ]]; then
            continue
        fi
        printf '%s\n' "${name}"
    done < <(list_theme_names)
}

print_fallback_selector() {
    local current="$1" name any=0
    printf 'Current theme: %s\n' "${current:-(none)}"
    printf '\nAvailable themes:\n'
    while IFS= read -r name; do
        any=1
        printf '  %s\n' "${name}"
    done < <(ordered_theme_names "${current}")
    (( any )) || printf '  (none)\n'
    printf '\nSet a theme:\n  showy-quota --set <name>\n'
    printf 'Unset persisted theme:\n  showy-quota --unset\n'
}

run_fzf_selector() {
    local current="$1" selection preview_cmd unset_cmd
    printf -v preview_cmd '%q --preview {}' "${SCRIPT_PATH}"
    printf -v unset_cmd '%q --unset' "${SCRIPT_PATH}"

    if selection=$(ordered_theme_names "${current}" | fzf \
        --prompt='theme> ' \
        --header='enter: save  esc: cancel  ctrl-x: clear theme  arrows/hjkl: browse' \
        --preview="${preview_cmd}" \
        --preview-window='right,60%,wrap' \
        --bind='h:up,j:down,k:up,l:down,up:up,down:down' \
        --bind="ctrl-x:execute(${unset_cmd})+abort"); then
        [[ -n "${selection}" ]] && set_theme "${selection}"
    fi
}

run_selector() {
    local current
    current=$(current_theme_value)
    if [[ -z "${SHOWY_QUOTA_TEST_NO_FZF:-}" ]] && [[ -t 0 ]] && command -v fzf >/dev/null 2>&1; then
        run_fzf_selector "${current}"
    else
        print_fallback_selector "${current}"
    fi
}

preview_fixture_json() {
    cat <<'JSON'
[
  {"provider":"claude","usage":{
    "primary":  {"usedPercent":17,"resetsAt":"2099-01-01T03:29:00Z","windowMinutes":300},
    "secondary":{"usedPercent":70,"resetsAt":"2099-01-03T00:00:00Z","windowMinutes":10080}
  }},
  {"provider":"codex","usage":{
    "primary":  {"usedPercent":92,"resetsAt":"2099-01-01T00:23:00Z","windowMinutes":10080},
    "secondary":{"usedPercent":35,"resetsAt":"2099-01-04T12:00:00Z","windowMinutes":10080}
  }}
]
JSON
}

preview_theme() {
    local name="$1"
    validate_theme_or_die "${name}"

    SHOWY_QUOTA_THEME="${name}" \
        SHOWY_QUOTA_NO_CONFIG=1 \
        SHOWY_QUOTA_FORCE_COLOR=1 \
        SHOWY_QUOTA_NOW_EPOCH=4070908800 \
        "${RENDERER}" --json - < <(preview_fixture_json)
}

print_tool_path() {
    local name="$1" path
    if path=$(command -v "${name}" 2>/dev/null); then
        printf '  %-12s %s\n' "${name}" "${path}"
    else
        printf '  %-12s (missing)\n' "${name}"
    fi
}

json_string() {
    jq -Rn --arg value "$1" '$value'
}

json_number_or_null() {
    local value="$1"
    if [[ "${value}" =~ ^[0-9]+$ ]]; then
        printf '%s' "${value}"
    else
        printf 'null'
    fi
}

diagnose_env_vars() {
    printf '%s\n' \
        SHOWY_QUOTA_REFRESH_SECONDS \
        SHOWY_QUOTA_LOCK_WAIT_TENTHS \
        SHOWY_QUOTA_CACHE_DIR \
        SHOWY_QUOTA_CODEXBAR_BIN \
        SHOWY_QUOTA_CODEXBAR_SERVE_URL \
        SHOWY_QUOTA_CODEXBAR_SERVE_TIMEOUT_SECONDS \
        SHOWY_QUOTA_CODEXBAR_SERVE_USAGE_TIMEOUT_SECONDS \
        SHOWY_QUOTA_CODEXBAR_SERVE_REFRESH_SECONDS \
        SHOWY_QUOTA_PROVIDERS \
        SHOWY_QUOTA_PROVIDERS_EXCLUDE \
        SHOWY_QUOTA_PROVIDER_ORDER \
        SHOWY_QUOTA_INCLUDE_STATUS \
        SHOWY_QUOTA_PROMPT_FETCH \
        SHOWY_QUOTA_THEME \
        SHOWY_QUOTA_TIME_WARN_MINUTES \
        SHOWY_QUOTA_DEBUG \
        SHOWY_QUOTA_FORCE_COLOR \
        SHOWY_QUOTA_NO_CONFIG \
        SHOWY_QUOTA_SKETCHYBAR_PROVIDER_ICON_MODE \
        SHOWY_QUOTA_SKETCHYBAR_UPDATE_FREQ \
        SHOWY_QUOTA_ZELLIJ_WIDGET \
        SHOWY_QUOTA_ZELLIJ_PIPE_INTERVAL \
        SHOWY_QUOTA_ZELLIJ_BIN
}

diagnose_env_json() {
    local first=1 var value
    printf '{'
    while IFS= read -r var; do
        [[ -n "${!var:-}" ]] || continue
        value=$(json_string "${!var}")
        (( first )) || printf ','
        first=0
        printf '"%s":%s' "${var}" "${value}"
    done < <(diagnose_env_vars)
    printf '}'
}

diagnose_tools_json() {
    local first=1 name path
    printf '{'
    for name in "$@"; do
        (( first )) || printf ','
        first=0
        if path=$(command -v "${name}" 2>/dev/null); then
            printf '"%s":{"available":true,"path":%s}' "${name}" "$(json_string "${path}")"
        else
            printf '"%s":{"available":false,"path":null}' "${name}"
        fi
    done
    printf '}'
}

diagnose_json() {
    command -v jq >/dev/null 2>&1 || die 'jq is required for --diagnose --json'

    local fetch_bin state_bin cache_path cache_age cache_size_json state_json config_status config_readable
    local env_json required_tools_json optional_tools_json cb cb_path cb_available cb_cache_count_json
    fetch_bin="${SCRIPT_DIR}/showy-quota-fetch"
    state_bin="${SCRIPT_DIR}/showy-quota-state"

    cache_path=""
    cache_age=""
    cache_size_json=null
    if [[ -x "${fetch_bin}" ]]; then
        cache_path="$("${fetch_bin}" --path 2>/dev/null || true)"
        cache_age="$("${fetch_bin}" --age 2>/dev/null || true)"
        if [[ -n "${cache_path}" && -f "${cache_path}" ]]; then
            cache_size_json=$(json_number_or_null "$(wc -c < "${cache_path}" 2>/dev/null | tr -d ' ' || true)")
        fi
    fi

    if [[ -x "${state_bin}" ]]; then
        state_json="$("${state_bin}" 2>/dev/null || printf 'null')"
        if ! jq -e 'type == "object"' >/dev/null 2>&1 <<< "${state_json}"; then
            state_json=null
        fi
    else
        state_json=null
    fi

    if [[ -r "${CONFIG_FILE}" ]]; then
        config_status=readable
        config_readable=true
    elif [[ -e "${CONFIG_FILE}" ]]; then
        config_status=unreadable
        config_readable=false
    else
        config_status=absent
        config_readable=null
    fi

    cb="${SHOWY_QUOTA_CODEXBAR_BIN:-codexbar}"
    cb_available=false
    cb_path=""
    if cb_path=$(command -v "${cb}" 2>/dev/null); then
        cb_available=true
    fi
    cb_cache_count_json=null
    if [[ -n "${cache_path}" && -f "${cache_path}" ]]; then
        cb_cache_count_json=$(jq 'if type == "array" then length else null end' "${cache_path}" 2>/dev/null || printf 'null')
    fi

    env_json=$(diagnose_env_json)
    required_tools_json=$(diagnose_tools_json bash jq codexbar)
    optional_tools_json=$(diagnose_tools_json curl flock sketchybar magick zellij tmux fzf)

    jq -n \
        --arg showyQuota "${SCRIPT_PATH}" \
        --arg repoRoot "${REPO_ROOT}" \
        --arg bashVersion "${BASH_VERSION:-unknown}" \
        --arg uname "$(uname -srm 2>/dev/null || printf 'unknown')" \
        --arg configFile "${CONFIG_FILE}" \
        --arg configStatus "${config_status}" \
        --argjson configReadable "${config_readable}" \
        --arg theme "$(current_theme_value 2>/dev/null || true)" \
        --arg fetchBin "${fetch_bin}" \
        --arg cachePath "${cache_path}" \
        --arg cacheAge "${cache_age}" \
        --argjson cacheSize "${cache_size_json}" \
        --argjson state "${state_json}" \
        --argjson envKnobs "${env_json}" \
        --argjson requiredTools "${required_tools_json}" \
        --argjson optionalTools "${optional_tools_json}" \
        --arg codexbarCommand "${cb}" \
        --arg codexbarPath "${cb_path}" \
        --argjson codexbarAvailable "${cb_available}" \
        --argjson cachedProviderCount "${cb_cache_count_json}" \
        '{
            paths: {
                showyQuota: $showyQuota,
                repoRoot: $repoRoot,
                fetch: $fetchBin,
                cache: (if $cachePath == "" then null else $cachePath end),
                config: $configFile
            },
            runtime: {
                bash: $bashVersion,
                uname: $uname
            },
            tools: {
                required: $requiredTools,
                optional: $optionalTools
            },
            config: {
                path: $configFile,
                status: $configStatus,
                readable: $configReadable,
                theme: (if $theme == "" then null else $theme end)
            },
            cache: {
                path: (if $cachePath == "" then null else $cachePath end),
                ageSeconds: (if ($cacheAge | test("^[0-9]+$")) then ($cacheAge | tonumber) else null end),
                sizeBytes: $cacheSize
            },
            state: $state,
            env: $envKnobs,
            codexbarProbe: {
                command: $codexbarCommand,
                available: $codexbarAvailable,
                path: (if $codexbarPath == "" then null else $codexbarPath end),
                cachedProviderCount: $cachedProviderCount
            }
        }'
}

diagnose() {
    local fetch_bin state_bin cache_path cache_age
    fetch_bin="${SCRIPT_DIR}/showy-quota-fetch"
    state_bin="${SCRIPT_DIR}/showy-quota-state"

    printf '## showy-quota diagnose\n'
    printf 'showy-quota:    %s\n' "${SCRIPT_PATH}"
    printf 'repo root:    %s\n' "${REPO_ROOT}"
    printf 'bash:         %s\n' "${BASH_VERSION:-unknown}"
    printf 'uname:        %s\n' "$(uname -srm 2>/dev/null || printf 'unknown')"

    printf '\n# Required tools\n'
    print_tool_path bash
    print_tool_path jq
    print_tool_path codexbar
    printf '\n# Optional tools\n'
    print_tool_path curl
    print_tool_path flock
    print_tool_path sketchybar
    print_tool_path magick
    print_tool_path zellij
    print_tool_path tmux
    print_tool_path fzf

    printf '\n# Config\n'
    if [[ -r "${CONFIG_FILE}" ]]; then
        printf 'config:       %s (readable)\n' "${CONFIG_FILE}"
    elif [[ -e "${CONFIG_FILE}" ]]; then
        printf 'config:       %s (exists, unreadable)\n' "${CONFIG_FILE}"
    else
        printf 'config:       %s (none — defaults in effect)\n' "${CONFIG_FILE}"
    fi
    printf 'theme:        %s\n' "$(current_theme_value 2>/dev/null || printf '(none)')"

    printf '\n# Cache\n'
    if [[ -x "${fetch_bin}" ]]; then
        cache_path="$("${fetch_bin}" --path 2>/dev/null || printf '(unknown)')"
        cache_age="$("${fetch_bin}" --age 2>/dev/null || printf '(unknown)')"
        printf 'cache file:   %s\n' "${cache_path}"
        printf 'cache age:    %ss\n' "${cache_age}"
        if [[ -f "${cache_path}" ]]; then
            printf 'cache size:   %s bytes\n' "$(wc -c < "${cache_path}" 2>/dev/null | tr -d ' ' || printf 'unknown')"
        else
            printf 'cache size:   (file absent)\n'
        fi
    else
        printf 'cache:        showy-quota-fetch missing or non-executable: %s\n' "${fetch_bin}"
    fi

    printf '\n# State\n'
    if [[ -x "${state_bin}" ]]; then
        "${state_bin}" 2>&1 | sed 's/^/  /'
    else
        printf '  showy-quota-state missing or non-executable: %s\n' "${state_bin}"
    fi

    printf '\n# Env knobs (set values only)\n'
    local var
    while IFS= read -r var; do
        if [[ -n "${!var:-}" ]]; then
            printf '  %s=%s\n' "${var}" "${!var}"
        fi
    done < <(diagnose_env_vars)

    printf '\n# CodexBar probe\n'
    local cb="${SHOWY_QUOTA_CODEXBAR_BIN:-codexbar}"
    if ! command -v "${cb}" >/dev/null 2>&1; then
        printf 'codexbar binary not on PATH (set SHOWY_QUOTA_CODEXBAR_BIN or install codexbar)\n'
    elif ! command -v jq >/dev/null 2>&1; then
        printf 'codexbar present; jq missing — cannot count providers\n'
    elif [[ -f "${SHOWY_QUOTA_USAGE_FILE:-${HOME}/.cache/showy-quota/usage.json}" ]]; then
        local cache_file count
        cache_file="${SHOWY_QUOTA_USAGE_FILE:-${HOME}/.cache/showy-quota/usage.json}"
        count=$(jq 'length' "${cache_file}" 2>/dev/null || printf '?')
        printf 'cached provider count = %s (from %s)\n' "${count}" "${cache_file}"
        printf '(skipping live %s usage probe; rerun bin/showy-quota-fetch --refresh to refresh)\n' "${cb}"
    else
        printf 'no cache yet; run bin/showy-quota-fetch --refresh to populate, then re-run --diagnose\n'
    fi
}

zellij_permissions_file() {
    if [[ -n "${SHOWY_QUOTA_ZELLIJ_PERMISSIONS_FILE:-}" ]]; then
        # grant_zellij writes a KDL block to this path; require an absolute
        # *.kdl path so an attacker-set env var cannot redirect the write to a
        # shell rc, LaunchAgent plist, ~/.ssh/authorized_keys, cron file, etc.
        if [[ "${SHOWY_QUOTA_ZELLIJ_PERMISSIONS_FILE}" != /*.kdl ]]; then
            die "SHOWY_QUOTA_ZELLIJ_PERMISSIONS_FILE must be an absolute path to a .kdl file: ${SHOWY_QUOTA_ZELLIJ_PERMISSIONS_FILE}"
        fi
        printf '%s' "${SHOWY_QUOTA_ZELLIJ_PERMISSIONS_FILE}"
        return 0
    fi
    local dir
    case "$(uname -s 2>/dev/null || printf 'unknown')" in
        Darwin) dir="${HOME}/Library/Caches/org.Zellij-Contributors.Zellij" ;;
        *)      dir="${XDG_CACHE_HOME:-${HOME}/.cache}/zellij" ;;
    esac
    printf '%s/permissions.kdl' "${dir}"
}

# Expand a leading ~ and make the path absolute without resolving symlinks,
# matching how Zellij derives a plugin's permission-cache key (shellexpand only).
resolve_abs_path() {
    local path="$1" tilde='~'
    if [[ "${path}" == "${tilde}" ]]; then
        path="${HOME}"
    elif [[ "${path}" == "${tilde}/"* ]]; then
        path="${HOME}/${path:2}"
    fi
    [[ "${path}" == /* ]] || path="$(pwd -P)/${path}"
    printf '%s' "${path}"
}

# Pre-grant the standalone Zellij plugin's permissions so it never prompts on
# first launch. The grant lives in Zellij's permissions.kdl (a cache file that
# macOS may purge), keyed by the plugin's location; re-running this is safe and
# re-heals after a purge. Other plugins' grants are preserved.
grant_zellij() {
    local plugin_arg="${1:-}" plugin_path plugins_dir
    if [[ -n "${plugin_arg}" ]]; then
        plugin_path="$(resolve_abs_path "${plugin_arg}")"
    else
        plugins_dir="${ZELLIJ_PLUGINS:-${HOME}/.config/zellij/plugins}"
        plugin_path="$(resolve_abs_path "${plugins_dir}/showy-quota-zellij.wasm")"
    fi

    # The path is written into a KDL string literal ("<key>" { … }); a quote,
    # backslash, or control char would let it break out and inject KDL nodes.
    if [[ "${plugin_path}" == *'"'* || "${plugin_path}" == *\\* || "${plugin_path}" == *[$'\x01'-$'\x1f']* ]]; then
        die "plugin path contains characters unsafe for the KDL permissions file (quote, backslash, or control char): ${plugin_path}"
    fi

    if [[ ! -e "${plugin_path}" ]]; then
        printf 'showy-quota: warning: no plugin file at %s\n' "${plugin_path}" >&2
        printf 'showy-quota: granting anyway — ensure this matches the layout "location" entry\n' >&2
    fi

    # Zellij 0.44.x keys grants on the bare absolute path; older versions used
    # the `file:` URL form. Write every plausible key so the grant survives
    # version differences and home-relative `file:~` layout entries.
    local -a keys=("${plugin_path}" "file:${plugin_path}")
    [[ "${plugin_path}" == "${HOME}/"* ]] && keys+=("file:~/${plugin_path#"${HOME}/"}")

    local perms_file perms_dir
    perms_file="$(zellij_permissions_file)"
    perms_dir="${perms_file%/*}"
    mkdir -p -- "${perms_dir}" || die "cannot create ${perms_dir}"

    # Rebuild the file: drop any block we own (idempotent), preserve the rest.
    local block_re='^[[:space:]]*"?([^"{]*[^"[:space:]{])"?[[:space:]]*\{[[:space:]]*$'
    local close_re='^[[:space:]]*\}[[:space:]]*$'
    local -a kept=()
    local skipping=0 line name key managed last
    if [[ -f "${perms_file}" ]]; then
        while IFS= read -r line || [[ -n "${line}" ]]; do
            if (( skipping )); then
                [[ "${line}" =~ ${close_re} ]] && skipping=0
                continue
            fi
            if [[ "${line}" =~ ${block_re} ]]; then
                name="${BASH_REMATCH[1]}"
                managed=0
                for key in "${keys[@]}"; do
                    [[ "${name}" == "${key}" ]] && { managed=1; break; }
                done
                if (( managed )); then
                    skipping=1
                    continue
                fi
            fi
            kept+=("${line}")
        done < "${perms_file}"
    fi
    # Drop trailing blank lines so appended blocks sit flush.
    while ((${#kept[@]})); do
        last=$(( ${#kept[@]} - 1 ))
        [[ -z "${kept[$last]}" ]] || break
        unset "kept[$last]"
    done

    local tmp
    tmp="$(umask 077 && mktemp "${perms_file}.tmp.XXXXXX")" || die "cannot create temporary file next to ${perms_file}"
    track_temp_file "${tmp}"
    if ! {
        if ((${#kept[@]})); then printf '%s\n' "${kept[@]}"; fi
        for key in "${keys[@]}"; do
            printf '"%s" {\n    WebAccess\n    OpenTerminalsOrPlugins\n    RunCommands\n}\n' "${key}"
        done
    } > "${tmp}"; then
        die "cannot write temporary file next to ${perms_file}"
    fi
    if ! mv -f -- "${tmp}" "${perms_file}"; then
        die "cannot replace ${perms_file}"
    fi

    printf 'showy-quota: pre-granted Zellij plugin permissions\n'
    printf '  permissions file: %s\n' "${perms_file}"
    printf '  plugin path:      %s\n' "${plugin_path}"
    printf '  keys written:     %s\n' "${#keys[@]}"
    printf '  permissions:      WebAccess OpenTerminalsOrPlugins RunCommands\n'
    printf 'Open a new Zellij tab (or restart Zellij) for the grant to take effect.\n'
}

# ── automation: quota guard + prompt segment ───────────────────────────
# guard and prompt consume the same provider metrics every bar renderer uses,
# via showy-quota-state, so they never re-parse CodexBar's JSON schema. Both
# lazily source the shared libs (common.sh sets `set -uo pipefail`, so -e is
# off inside these handlers — every step below checks errors explicitly).

SHOWY_QUOTA_STATE_LIBS_LOADED=0
load_state_libs() {
    (( SHOWY_QUOTA_STATE_LIBS_LOADED )) && return 0
    # shellcheck disable=SC1091
    . "${REPO_ROOT}/lib/common.sh"
    # shellcheck disable=SC1091
    . "${REPO_ROOT}/lib/strip.sh"
    SHOWY_QUOTA_STATE_LIBS_LOADED=1
}

# Resolve showy-quota-fetch the same way the bar drivers do, honoring a custom
# SHOWY_QUOTA_FETCH_BIN or a copied install tree.
automation_fetch_bin() {
    local fetch="${SHOWY_QUOTA_FETCH_BIN:-${SCRIPT_DIR}/showy-quota-fetch}"
    fetch="$(showy_quota_valid_bin "${fetch}")" || fetch="${SCRIPT_DIR}/showy-quota-fetch"
    printf '%s' "${fetch}"
}

# Split a comma-separated provider list into PROVIDER_IDS[]. Rejects ids outside
# CodexBar's id charset so a malformed flag is a usage error, not "unknown".
parse_provider_list() {
    local raw="$1" part
    PROVIDER_IDS=()
    local IFS=','
    for part in ${raw}; do
        part="${part#"${part%%[![:space:]]*}"}"
        part="${part%"${part##*[![:space:]]}"}"
        [[ -n "${part}" ]] || continue
        [[ "${part}" =~ ^[A-Za-z0-9_.-]+$ ]] || return 1
        PROVIDER_IDS+=("${part}")
    done
    (( ${#PROVIDER_IDS[@]} > 0 )) || return 1
    return 0
}

# PROVIDER_IDS[] as a compact JSON array (empty array when none selected).
providers_json() {
    (( ${#PROVIDER_IDS[@]} )) || { printf '[]'; return; }
    printf '%s\n' "${PROVIDER_IDS[@]}" | jq -Rsc 'split("\n") | map(select(length > 0))'
}

# jq: reduce state.providerMetrics to the facts guard needs. For each selected
# provider pick a window (explicit slot, or the worst = lowest-remaining slot),
# and partition into unknown / errored / null-window / evaluable.
# shellcheck disable=SC2016  # jq program: $-names are jq variables, not shell
GUARD_JQ='
def slots($m):
  [ {name:"primary",   w:$m.windows.primary},
    {name:"secondary", w:$m.windows.secondary},
    {name:"tertiary",  w:$m.windows.tertiary} ];
def usable($w): ($w != null) and (($w.remainingPercent|type) == "number");
def pick($m):
  if $window == "worst" then
    ( slots($m) | map(select(usable(.w))) )
    | if length == 0 then null else min_by(.w.remainingPercent) end
  else
    ( slots($m) | map(select(.name == $window)) | (.[0] // null) )
    | if (. == null) or (usable(.w) | not) then null else . end
  end;
def entry($pid; $slot):
  { provider: $pid, window: $slot.name,
    usedPercent: $slot.w.usedPercent,
    remainingPercent: $slot.w.remainingPercent,
    minutesUntilReset: $slot.w.minutesUntilReset,
    resetsAt: $slot.w.resetsAt };
(.available) as $available
| (.stale) as $stale
| (.providerMetrics // []) as $pm
| ($pm | map(.provider)) as $present
| (if ($requested|length) > 0 then $requested else $present end) as $targets
| (if ($requested|length) > 0 then ($requested - $present) else [] end) as $unknown
| [ $targets[] as $pid
    | ($pm[] | select(.provider == $pid)) as $m
    | { provider: $pid, error: ($m.error), slot: (pick($m)) }
  ] as $classified
| { available: $available,
    stale: $stale,
    unknown: $unknown,
    errored: [ $classified[] | select(.error != null) | {provider: .provider, kind: (.error.kind), message: (.error.message)} ],
    nullWindow: [ $classified[] | select((.error == null) and (.slot == null)) | .provider ],
    evaluated: [ $classified[] | select((.error == null) and (.slot != null)) | entry(.provider; .slot) ]
  }
| .worst = (if (.evaluated|length) > 0 then (.evaluated | min_by(.remainingPercent)) else null end)
'


guard_help() {
    printf '%s\n' \
        'Usage: showy-quota guard [--provider ID[,ID...]] [--window primary|secondary|tertiary|worst]' \
        '                         [--min-remaining PCT | --max-used PCT] [--allow-stale]' \
        '                         [--wait-max SECONDS] [--json] [--quiet]' \
        '' \
        'Runs a refresh-window fetch, then evaluates provider metrics.' \
        'Window default "worst" = the non-null slot with the least remaining per provider.' \
        'Default threshold: --min-remaining 10. The boundary is inclusive-pass:' \
        '  --min-remaining N passes when remaining >= N (breach when remaining < N);' \
        '  --max-used N       passes when used <= N      (breach when used > N).' \
        'Exit codes: 0 pass, 1 breach, 2 unusable data, 3 usage error.'
}

guard_usage_error() {
    printf 'showy-quota guard: %s\n\n' "$1" >&2
    guard_help >&2
    exit 3
}

guard_valid_pct() { [[ "$1" =~ ^[0-9]+$ ]] && (( 10#$1 <= 100 )); }
guard_valid_uint() { [[ "$1" =~ ^[0-9]+$ ]]; }

# Evaluate once against showy-quota-state --json. Reads globals G_WIN, G_TK,
# G_TV, G_AS, REQUESTED_JSON, PROVIDER_IDS, STATE_BIN; sets G_EXIT, G_REASON,
# G_STALE, G_EVALUATED, G_WORST_JSON, G_BREACH.
guard_evaluate() {
    G_BREACH=0
    local state_json facts
    state_json="$("${STATE_BIN}" --json 2>/dev/null)" || state_json=""
    if [[ -z "${state_json}" ]] || ! printf '%s' "${state_json}" | jq -e 'type == "object"' >/dev/null 2>&1; then
        G_EXIT=2; G_REASON="no-cache"; G_STALE=false; G_EVALUATED=0; G_WORST_JSON=null; return
    fi
    if ! facts="$(printf '%s' "${state_json}" | jq -c --argjson requested "${REQUESTED_JSON}" --arg window "${G_WIN}" "${GUARD_JQ}")"; then
        G_EXIT=2; G_REASON="state-error"; G_STALE=false; G_EVALUATED=0; G_WORST_JSON=null; return
    fi

    # One jq pass extracts every scalar the decision needs (one line each, so
    # empty joins survive as empty elements); worst stays a JSON object.
    local -a F=()
    mapfile -t F < <(printf '%s' "${facts}" | jq -r '
        [ (.available | tostring),
          (.stale | tostring),
          (.unknown | length | tostring),
          (.errored | length | tostring),
          (.nullWindow | length | tostring),
          (.evaluated | length | tostring),
          (.unknown | join(",")),
          ([.errored[] | "\(.provider)(\(.kind // "unknown"))"] | join(",")),
          (.nullWindow | join(",")),
          (((.worst.remainingPercent) // "null") | tostring),
          (((.worst.usedPercent) // "null") | tostring)
        ] | .[]')
    G_WORST_JSON="$(printf '%s' "${facts}" | jq -c '.worst')"

    local available="${F[0]}" errored_join="${F[7]}"
    G_STALE="${F[1]}"
    local unknown_n="${F[2]}" errored_n="${F[3]}" nullw_n="${F[4]}"
    G_EVALUATED="${F[5]}"
    local unknown_join="${F[6]}" nullw_join="${F[8]}"
    local wr="${F[9]}" wu="${F[10]}"

    if [[ "${available}" != "true" ]]; then
        G_EXIT=2; G_REASON="no-cache"; return
    fi
    if (( ${#PROVIDER_IDS[@]} > 0 )); then
        if (( unknown_n > 0 )); then
            G_EXIT=2; G_REASON="unknown-provider: ${unknown_join}"; return
        fi
        if (( errored_n > 0 )); then
            G_EXIT=2; G_REASON="provider-error: ${errored_join}"; return
        fi
        if (( nullw_n > 0 )); then
            G_EXIT=2; G_REASON="null-window: ${nullw_join}/${G_WIN}"; return
        fi
    fi
    if (( G_EVALUATED == 0 )); then
        if (( errored_n > 0 )); then
            G_EXIT=2; G_REASON="provider-error: ${errored_join}"; return
        fi
        G_EXIT=2; G_REASON="no-usable-data"; return
    fi
    if [[ "${G_STALE}" == "true" && "${G_AS}" != "1" ]]; then
        G_EXIT=2; G_REASON="stale"; return
    fi

    if [[ "${G_TK}" == "max-used" ]]; then
        (( wu > G_TV )) && G_BREACH=1
    else
        (( wr < G_TV )) && G_BREACH=1
    fi
    if (( G_BREACH )); then G_EXIT=1; G_REASON="breach"; else G_EXIT=0; G_REASON="pass"; fi
}

guard_emit_json() {
    jq -cn \
        --argjson exitc "${G_EXIT}" \
        --arg reason "${G_REASON}" \
        --argjson stale "${G_STALE}" \
        --argjson evaluated "${G_EVALUATED}" \
        --argjson worst "${G_WORST_JSON}" \
        '{exit: $exitc, ok: ($exitc == 0), reason: $reason, stale: $stale, evaluated: $evaluated, worst: $worst}'
}

guard_emit_human() {
    local clause
    if [[ "${G_TK}" == "max-used" ]]; then clause="max-used ${G_TV}%"; else clause="min-remaining ${G_TV}%"; fi
    if (( G_EXIT == 2 )); then
        printf 'showy-quota guard: unusable — %s\n' "${G_REASON}"
        return
    fi
    if [[ "${G_WORST_JSON}" == "null" ]]; then
        printf 'showy-quota guard: ok\n'
        return
    fi
    local -a W=()
    mapfile -t W < <(printf '%s' "${G_WORST_JSON}" | jq -r '[.provider, .window, (.remainingPercent|tostring), (.usedPercent|tostring)] | .[]')
    local p="${W[0]}" w="${W[1]}" r="${W[2]}" u="${W[3]}"
    if (( G_EXIT == 1 )); then
        if [[ "${G_TK}" == "max-used" ]]; then
            printf 'showy-quota guard: BREACH — %s/%s %s%% used > %s%% (%s)\n' "${p}" "${w}" "${u}" "${G_TV}" "${clause}"
        else
            printf 'showy-quota guard: BREACH — %s/%s %s%% remaining < %s%% (%s)\n' "${p}" "${w}" "${r}" "${G_TV}" "${clause}"
        fi
    else
        if [[ "${G_TK}" == "max-used" ]]; then
            printf 'showy-quota guard: ok — %s/%s %s%% used <= %s%% (%s)\n' "${p}" "${w}" "${u}" "${G_TV}" "${clause}"
        else
            printf 'showy-quota guard: ok — %s/%s %s%% remaining >= %s%% (%s)\n' "${p}" "${w}" "${r}" "${G_TV}" "${clause}"
        fi
    fi
}

cmd_guard() {
    load_state_libs
    showy_quota_have jq || { printf 'showy-quota guard: jq is required\n' >&2; exit 3; }

    PROVIDER_IDS=()
    local window="worst" threshold_kind="" threshold_value=""
    local allow_stale=0 wait_max=0 json_mode=0 quiet=0

    while (($#)); do
        case "$1" in
            --provider)
                (($# >= 2)) || guard_usage_error '--provider requires a value'
                parse_provider_list "$2" || guard_usage_error "invalid --provider value: $2"
                shift 2 ;;
            --window)
                (($# >= 2)) || guard_usage_error '--window requires a value'
                case "$2" in
                    primary|secondary|tertiary|worst) window="$2" ;;
                    *) guard_usage_error "invalid --window (primary|secondary|tertiary|worst): $2" ;;
                esac
                shift 2 ;;
            --min-remaining)
                (($# >= 2)) || guard_usage_error '--min-remaining requires a value'
                [[ -z "${threshold_kind}" ]] || guard_usage_error '--min-remaining and --max-used are mutually exclusive'
                guard_valid_pct "$2" || guard_usage_error "invalid --min-remaining (0-100): $2"
                threshold_kind="min-remaining"; threshold_value=$((10#$2))
                shift 2 ;;
            --max-used)
                (($# >= 2)) || guard_usage_error '--max-used requires a value'
                [[ -z "${threshold_kind}" ]] || guard_usage_error '--min-remaining and --max-used are mutually exclusive'
                guard_valid_pct "$2" || guard_usage_error "invalid --max-used (0-100): $2"
                threshold_kind="max-used"; threshold_value=$((10#$2))
                shift 2 ;;
            --allow-stale) allow_stale=1; shift ;;
            --wait-max)
                (($# >= 2)) || guard_usage_error '--wait-max requires a value'
                guard_valid_uint "$2" || guard_usage_error "invalid --wait-max (seconds): $2"
                wait_max=$((10#$2)); shift 2 ;;
            --json)  json_mode=1; shift ;;
            --quiet) quiet=1; shift ;;
            -h|--help) guard_help; return 0 ;;
            *) guard_usage_error "unknown argument: $1" ;;
        esac
    done

    if [[ -z "${threshold_kind}" ]]; then
        threshold_kind="min-remaining"; threshold_value=10
    fi

    STATE_BIN="${SCRIPT_DIR}/showy-quota-state"
    local fetch; fetch="$(automation_fetch_bin)"
    REQUESTED_JSON="$(providers_json)"
    G_WIN="${window}"; G_TK="${threshold_kind}"; G_TV="${threshold_value}"; G_AS="${allow_stale}"

    # Guard always fetches (automation wants current data): refresh-window
    # semantics; a fetch failure is non-fatal when a cache exists.
    "${fetch}" >/dev/null 2>&1 || true
    guard_evaluate

    # --wait-max: if breaching and the worst window's reset is known and lands
    # within the budget, sleep past it (+30s grace), force one refresh, retry once.
    if (( G_BREACH )) && (( wait_max > 0 )); then
        local wmin wsecs
        wmin="$(printf '%s' "${G_WORST_JSON}" | jq -r '.minutesUntilReset // "null"')"
        if [[ "${wmin}" =~ ^[0-9]+$ ]]; then
            wsecs=$(( wmin * 60 ))
            if (( wsecs <= wait_max )); then
                sleep $(( wsecs + 30 ))
                "${fetch}" --refresh >/dev/null 2>&1 || true
                guard_evaluate
            fi
        fi
    fi

    if (( json_mode )); then
        guard_emit_json
    elif (( quiet )); then
        (( G_EXIT != 0 )) && guard_emit_human
    else
        guard_emit_human
    fi
    exit "${G_EXIT}"
}

prompt_usage_error() {
    printf 'showy-quota prompt: %s\n' "$1" >&2
    printf 'Usage: showy-quota prompt [--ansi] [--provider ID]\n' >&2
    exit 3
}

cmd_prompt() {
    load_state_libs
    # A prompt segment must never break a shell: any environment failure prints
    # the neutral "AI ?" and exits 0. Only argument errors exit non-zero.

    PROVIDER_IDS=()
    local ansi=0
    while (($#)); do
        case "$1" in
            --ansi) ansi=1; shift ;;
            --provider)
                (($# >= 2)) || prompt_usage_error '--provider requires a value'
                parse_provider_list "$2" || prompt_usage_error "invalid --provider value: $2"
                shift 2 ;;
            -h|--help)
                printf '%s\n' \
                    'Usage: showy-quota prompt [--ansi] [--provider ID]' \
                    '' \
                    'Prints "<SIGIL> <used>% <countdown>" for the worst-remaining provider window.' \
                    'Reads the cache as-is; set SHOWY_QUOTA_PROMPT_FETCH=1 to refresh first.' \
                    '--ansi adds severity color (suppressed by NO_COLOR). Always exits 0 (usage errors aside).'
                return 0 ;;
            *) prompt_usage_error "unknown argument: $1" ;;
        esac
    done

    showy_quota_export_config

    local render_bin
    if ! render_bin="$(showy_quota_resolve_render_bin "${SCRIPT_DIR}" "${SCRIPT_DIR}/..")"; then
        printf 'AI ?\n'
        exit 0
    fi

    if [[ "${SHOWY_QUOTA_PROMPT_FETCH:-}" == "1" ]]; then
        local fetch; fetch="$(automation_fetch_bin)"
        "${fetch}" --refresh >/dev/null 2>&1 || true
    fi

    local -a provider_args=()
    if (( ${#PROVIDER_IDS[@]} > 0 )); then
        local provider_csv
        provider_csv="$(IFS=,; printf '%s' "${PROVIDER_IDS[*]}")"
        provider_args=(--provider "${provider_csv}")
    fi

    local -a render_args=(--emit prompt --from-cache)
    (( ansi )) && render_args+=(--ansi)
    render_args+=("${provider_args[@]}")

    if ! "${render_bin}" "${render_args[@]}" 2>/dev/null; then
        printf 'AI ?\n'
    fi
    exit 0
}

main() {
    if (($# == 0)); then
        run_selector
        return 0
    fi

    case "$1" in
        --set)
            (($# == 2)) || usage_error '--set requires exactly one theme name'
            set_theme "$2"
            ;;
        --unset)
            (($# == 1)) || usage_error '--unset does not accept arguments'
            unset_theme
            ;;
        --current)
            (($# == 1)) || usage_error '--current does not accept arguments'
            print_current_theme
            ;;
        --list)
            (($# == 1)) || usage_error '--list does not accept arguments'
            list_theme_names
            ;;
        --preview)
            (($# == 2)) || usage_error '--preview requires exactly one theme name'
            preview_theme "$2"
            ;;
        --diagnose)
            if (($# == 2)); then
                [[ "$2" == "--json" ]] || usage_error '--diagnose only accepts --json'
                diagnose_json
            else
                (($# == 1)) || usage_error '--diagnose only accepts --json'
                diagnose
            fi
            ;;
        --grant-zellij)
            if (($# == 2)); then
                grant_zellij "$2"
            else
                (($# == 1)) || usage_error '--grant-zellij accepts at most one plugin path'
                grant_zellij ""
            fi
            ;;
        guard)
            shift
            cmd_guard "$@"
            ;;
        prompt)
            shift
            cmd_prompt "$@"
            ;;
        -h|--help)
            (($# == 1)) || usage_error '--help does not accept arguments'
            usage
            ;;
        *)
            usage_error "unknown argument: $1"
            ;;
    esac
}

main "$@"
