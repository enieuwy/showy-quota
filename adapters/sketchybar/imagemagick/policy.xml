<?xml version="1.0" encoding="UTF-8"?>
<!--
  Restrictive ImageMagick policy used only by showy-quota's SketchyBar plugin
  (injected via MAGICK_CONFIGURE_PATH). It blocks the network coders,
  delegate execution, and indirect-read syntax so a provider SVG under
  SHOWY_QUOTA_CODEXBAR_RESOURCES cannot make ImageMagick fetch a remote
  href (SSRF / data exfiltration). The plugin prefixes provider SVG reads with
  MSVG: so ImageMagick uses its internal XML/MSVG decoder instead of delegate
  renderers such as librsvg or inkscape; the MVG/drawing coders remain
  available so drawn fallback icons keep working when a provider SVG is missing.
-->
<policymap>
  <policy domain="coder" rights="none" pattern="URL" />
  <policy domain="coder" rights="none" pattern="HTTP" />
  <policy domain="coder" rights="none" pattern="HTTPS" />
  <policy domain="coder" rights="none" pattern="FTP" />
  <policy domain="coder" rights="none" pattern="MSL" />
  <policy domain="delegate" rights="none" pattern="*" />
  <policy domain="path" rights="none" pattern="@*" />
</policymap>
