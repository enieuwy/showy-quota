# showy-bar — Dracula palette theme
# Primary indicators use Dracula's signature purple/pink accents rather than
# generic ANSI green/red traffic colors.
: "${SHOWY_BAR_PALETTE_PRIMARY_GOOD:=bd93f9}"
: "${SHOWY_BAR_PALETTE_PRIMARY_WARN:=ffb86c}"
: "${SHOWY_BAR_PALETTE_PRIMARY_BAD:=ff79c6}"
: "${SHOWY_BAR_PALETTE_PRIMARY_UNKNOWN:=6272a4}"
: "${SHOWY_BAR_PALETTE_BG:=282a36}"
: "${SHOWY_BAR_PALETTE_SURFACE:=44475a}"
: "${SHOWY_BAR_PALETTE_TRACK:=343746}"
: "${SHOWY_BAR_PALETTE_ICON_TEXT:=f8f8f2}"
: "${SHOWY_BAR_PALETTE_COUNTDOWN:=6272a4}"
: "${SHOWY_BAR_PALETTE_COUNTDOWN_WARN:=ff79c6}"
: "${SHOWY_BAR_PALETTE_ELAPSED:=8be9fd}"
