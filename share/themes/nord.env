# showy-bar — Nord palette theme
# Primary indicators lean into Nord's Frost/Aurora accents; green remains in
# the canonical palette, but it is not the visual identity of this theme.
: "${SHOWY_BAR_PALETTE_PRIMARY_GOOD:=88c0d0}"
: "${SHOWY_BAR_PALETTE_PRIMARY_WARN:=ebcb8b}"
: "${SHOWY_BAR_PALETTE_PRIMARY_BAD:=bf616a}"
: "${SHOWY_BAR_PALETTE_PRIMARY_UNKNOWN:=4c566a}"
: "${SHOWY_BAR_PALETTE_BG:=2e3440}"
: "${SHOWY_BAR_PALETTE_SURFACE:=3b4252}"
: "${SHOWY_BAR_PALETTE_TRACK:=434c5e}"
: "${SHOWY_BAR_PALETTE_ICON_TEXT:=d8dee9}"
: "${SHOWY_BAR_PALETTE_COUNTDOWN:=4c566a}"
: "${SHOWY_BAR_PALETTE_COUNTDOWN_WARN:=bf616a}"
: "${SHOWY_BAR_PALETTE_ELAPSED:=b48ead}"
