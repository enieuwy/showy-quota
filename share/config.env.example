# codexbar-bars — optional config
#
# Copy to ~/.config/codexbar-bars/config.env (or set the variables in your
# shell startup) to override defaults. Every value is optional.
#
# All scripts source this file when CB_BARS_NO_CONFIG is unset.

# ── data plane ─────────────────────────────────────────────────────────

# Refresh interval for the shared codexbar JSON cache. Bars themselves can
# poll the cache more frequently; this is the upper bound on how often
# `codexbar` itself runs.
# CB_BARS_REFRESH_SECONDS=120

# How long lock losers wait for an in-flight refresh, in tenths of seconds.
# Default 100 = 10 seconds.
# CB_BARS_LOCK_WAIT_TENTHS=100

# Cache directory. Falls back to $XDG_CACHE_HOME/codexbar-bars or
# ~/.cache/codexbar-bars.
# CB_BARS_CACHE_DIR=

# Path to the codexbar binary. Falls back to `codexbar` on PATH.
# CB_BARS_CODEXBAR_BIN=/opt/homebrew/bin/codexbar

# Path to the cb-bars-fetch script. Falls back to this repo's bin/ copy
# for source-tree usage, or to the installed script next to a renderer.
# CB_BARS_FETCH_BIN=

# Comma-separated provider id allow-list for rendering. Empty = render the
# enabled provider set returned by `codexbar usage`.
# CB_BARS_PROVIDERS=claude,codex,gemini

# Pass --status to codexbar so we get incident indicators. Slow on cold
# fetches; off by default.
# CB_BARS_INCLUDE_STATUS=0

# ── presentation ───────────────────────────────────────────────────────

# Hex (no '#') palette. Defaults match the original ai-quota SketchyBar bars.
# CB_BARS_PALETTE_GOOD=25be6a
# CB_BARS_PALETTE_WARN=f0af00
# CB_BARS_PALETTE_BAD=ee5396
# CB_BARS_PALETTE_UNKNOWN=6c7086
# CB_BARS_PALETTE_TRACK=3a3a4a
# CB_BARS_PALETTE_TEXT=f2f4f8

# Threshold (in % remaining) below which a window switches color band.
# CB_BARS_GOOD_MIN_REMAINING=40
# CB_BARS_WARN_MIN_REMAINING=15

# Time-label minute threshold for warn coloring.
# CB_BARS_TIME_WARN_MINUTES=30

# ── sketchybar ─────────────────────────────────────────────────────────

# Cache dir for generated PNG bars and provider icons.
# CB_BARS_SKETCHYBAR_IMAGE_CACHE=~/.cache/codexbar-bars/sketchybar

# Where to find CodexBar's provider SVGs. The default tracks the macOS app
# bundle; override for non-default install paths.
# CB_BARS_CODEXBAR_RESOURCES=/Applications/CodexBar.app/Contents/Resources

# Click target for sketchybar items. Default brings CodexBar.app forward.
# Note: bundle id is lowercase 'codexbar'.
# CB_BARS_SKETCHYBAR_CLICK="open -b com.steipete.codexbar"

# Update frequency for the sketchybar trigger item.
# CB_BARS_SKETCHYBAR_UPDATE_FREQ=120

# Stacked-bar PNG geometry (pixels).
# CB_BARS_PNG_BAR_W=80
# CB_BARS_PNG_BAR_H=18

# SketchyBar item widths. Bar width should normally be PNG width + padding.
# CB_BARS_SKETCHYBAR_ICON_WIDTH=22
# CB_BARS_SKETCHYBAR_BAR_WIDTH=84
# CB_BARS_SKETCHYBAR_ICON_SCALE=0.28
# CB_BARS_SKETCHYBAR_ICON_PADDING_LEFT=5

# ── zellij / tmux ──────────────────────────────────────────────────────

# zjstatus widget name (must match `pipe_<name>_format` in your layout).
# CB_BARS_ZELLIJ_WIDGET=pipe_codexbar

# zellij pipe routing name (arbitrary; zjstatus listens on any name).
# CB_BARS_ZELLIJ_PIPE_NAME=cb-bars

# How often the long-running pipe re-emits the strip (seconds).
# CB_BARS_ZELLIJ_PIPE_INTERVAL=10

# Path to the zellij binary for the long-running pipe loop. Use an
# absolute path when Zellij sessions do not inherit your interactive PATH.
# CB_BARS_ZELLIJ_BIN=/opt/homebrew/bin/zellij

# ── debug ──────────────────────────────────────────────────────────────

# Set to 1 to emit `[cb-bars] …` diagnostics on stderr.
# CB_BARS_DEBUG=0

# Force ANSI color in the zellij renderer even when stdout is not a TTY.
# CB_BARS_FORCE_COLOR=0
