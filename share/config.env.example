# showy-quota — optional config
#
# Copy to ~/.config/showy-quota/config.env (or set the variables in your
# shell startup) to override defaults. Every value is optional.
#
# All scripts source this file when SHOWY_QUOTA_NO_CONFIG is unset. This file is
# `source`d as shell, not parsed as key=value — keep it to assignments and
# comments, and never paste untrusted content here.
#
# Run `bin/showy-quota --diagnose` (or `make diagnose`) to inspect which values
# this file resolved to alongside cache state, tool paths, and the active
# theme — that's the right thing to paste into bug reports.

# ── data plane ─────────────────────────────────────────────────────────

# Slow refresh interval for the shared codexbar JSON cache. This is the upper
# bound on how often `codexbar usage` itself runs when `codexbar serve` is not
# available or cannot return publishable usage JSON.
# SHOWY_QUOTA_REFRESH_SECONDS=120

# How long lock losers wait for an in-flight refresh, in tenths of seconds.
# Default 100 = 10 seconds.
# SHOWY_QUOTA_LOCK_WAIT_TENTHS=100

# Cache directory. Falls back to $XDG_CACHE_HOME/showy-quota or
# ~/.cache/showy-quota.
# SHOWY_QUOTA_CACHE_DIR=

# Path to the codexbar binary. Falls back to `codexbar` on PATH.
# SHOWY_QUOTA_CODEXBAR_BIN=/opt/homebrew/bin/codexbar

# Base URL for `codexbar serve` (CodexBar 0.26.1+). showy-quota-fetch probes
# /health and /usage before falling back to SHOWY_QUOTA_CODEXBAR_BIN. Only
# localhost URLs are accepted; set this empty to skip the HTTP probe.
# SHOWY_QUOTA_CODEXBAR_SERVE_URL=http://127.0.0.1:8080
# Start `codexbar serve` automatically when /health is unavailable. Set 0 if
# another supervisor owns the server lifecycle.
# SHOWY_QUOTA_MANAGE_SERVE=1
# Optional legacy override; normally leave this unset and let
# SHOWY_QUOTA_CODEXBAR_SERVE_URL choose the managed serve port.
# SHOWY_QUOTA_CODEXBAR_SERVE_PORT=
# SHOWY_QUOTA_CODEXBAR_SERVE_REFRESH_INTERVAL_SECONDS=60
# SHOWY_QUOTA_CODEXBAR_SERVE_TIMEOUT_SECONDS=10
# /health probes use the timeout above; the /usage probe gets its own, larger
# budget because a healthy `codexbar serve` bounds collection per provider and
# can take up to ~0.8x its request deadline (~24s by default) to return the
# healthy providers when a slow one degrades to an error row. Keep this at or
# above the server's request deadline so a brief provider slowdown does not drop
# the bar to degraded CLI output.
# SHOWY_QUOTA_CODEXBAR_SERVE_USAGE_TIMEOUT_SECONDS=30
# SHOWY_QUOTA_CODEXBAR_SERVE_START_WAIT_TENTHS=30
# When `codexbar serve` is available, probe it on this shorter cadence so bars
# repaint seconds after the server's own response cache refreshes. Failed probes
# while the current cache is still fresh keep the cache and do not force
# the slower CLI fallback until SHOWY_QUOTA_REFRESH_SECONDS.
# SHOWY_QUOTA_CODEXBAR_SERVE_REFRESH_SECONDS=10

# Path to the showy-quota-fetch script. Falls back to this repo's bin/ copy
# for source-tree usage, or to the installed script next to a renderer.
# SHOWY_QUOTA_FETCH_BIN=

# Comma-separated provider id allow-list for rendering. Empty = render the
# enabled provider set returned by `codexbar usage`.
# SHOWY_QUOTA_PROVIDERS=codex,claude,gemini
# Comma-separated provider id exclude-list. Applied after SHOWY_QUOTA_PROVIDERS,
# so exclude wins on overlap.
# SHOWY_QUOTA_PROVIDERS_EXCLUDE=codex
# Comma-separated provider id order. This ranks providers without filtering:
# missing providers are skipped, and unlisted providers render after this list.
# SHOWY_QUOTA_PROVIDERS, when set, is both an allow-list and the render order.
# SHOWY_QUOTA_PROVIDER_ORDER=codex,claude,copilot,opencode,gemini

# Pass --status to codexbar so provider outage indicators are included.
# Set to 0 to skip status-page polling in the CLI path.
# SHOWY_QUOTA_INCLUDE_STATUS=1

# ── presentation ───────────────────────────────────────────────────────

# Optional theme name. Looks in ~/.config/showy-quota/themes/<name>.env
# first, then the repo/install tree's share/themes/<name>.env.
# `showy-quota` is the supported way to browse and persist this setting.
# Built-ins include default, carbonfox, catppuccin-mocha,
# catppuccin-mocha-blue, dracula, gruvbox-dark, nord, and tokyonight.
# SHOWY_QUOTA_THEME=default

# Role-aware 6-char hex palette. Primary is canonical; secondary/tertiary
# auto-derive from primary via the scale knobs when unset. Defaults preserve
# the original ai-quota look for the stacked rows.
# Minimal custom palette:
# SHOWY_QUOTA_PALETTE_PRIMARY_GOOD=25be6a
# SHOWY_QUOTA_PALETTE_PRIMARY_WARN=f0af00
# SHOWY_QUOTA_PALETTE_PRIMARY_BAD=ee5396
# SHOWY_QUOTA_PALETTE_PRIMARY_UNKNOWN=6c7086
# Long-horizon windows are dimmed from the primary palette; there are no
# separate secondary/tertiary palettes. (The removed SECONDARY_*/TERTIARY_* and
# *_SCALE knobs are replaced by one dim scale plus a horizon threshold.)
# SHOWY_QUOTA_PALETTE_DIM_SCALE=0.55
# SHOWY_QUOTA_DIM_WINDOW_MINUTES=10080
# Global colors shared by every renderer.
# ICON_TEXT is high-contrast text inside fallback provider icons.
# COUNTDOWN is the normal countdown label color.
# COUNTDOWN_WARN is used when reset time is inside SHOWY_QUOTA_TIME_WARN_MINUTES.
# STALE is used when a cache snapshot is older than 2x the refresh interval.
# SHOWY_QUOTA_PALETTE_BG=161616
# SHOWY_QUOTA_PALETTE_SURFACE=2a2a2a
# SHOWY_QUOTA_PALETTE_TRACK=3a3a4a
# SHOWY_QUOTA_PALETTE_ICON_TEXT=f2f4f8
# SHOWY_QUOTA_PALETTE_COUNTDOWN=7b8496
# SHOWY_QUOTA_PALETTE_COUNTDOWN_WARN=ee5396
# SHOWY_QUOTA_PALETTE_STALE=6c7086
# SHOWY_QUOTA_STALE_GLYPH=⚠
# SHOWY_QUOTA_DEGRADED_CLI_GLYPH=⚠cli
# SHOWY_QUOTA_PALETTE_ELAPSED=be95ff

# Threshold (in % remaining) below which a window switches color band.
# SHOWY_QUOTA_GOOD_MIN_REMAINING=40
# SHOWY_QUOTA_WARN_MIN_REMAINING=15

# Time-label minute threshold for warn coloring.
# SHOWY_QUOTA_TIME_WARN_MINUTES=30

# ── sketchybar ─────────────────────────────────────────────────────────

# Cache dir for generated PNG bars and provider icons.
# SHOWY_QUOTA_SKETCHYBAR_IMAGE_CACHE=~/.cache/showy-quota/sketchybar

# Where to find CodexBar's provider SVGs. The default tracks the macOS app
# bundle; override for non-default install paths.
# SHOWY_QUOTA_CODEXBAR_RESOURCES=/Applications/CodexBar.app/Contents/Resources

# Default click target for sketchybar items. Degraded provider icons open the
# provider's HTTP(S) status URL when CodexBar reports one; other clicks use
# this command. Note: bundle id is lowercase 'codexbar'.
# SECURITY: this value is run by SketchyBar as a shell command on click (it is
# appended verbatim to the item click_script), so set it only to a command you
# trust — exactly like any other entry in this file, which is sourced as shell.
# SHOWY_QUOTA_SKETCHYBAR_CLICK="open -b com.steipete.codexbar"

# Update frequency for the sketchybar trigger item. Keep this aligned with the
# Zellij pipe interval to avoid visible countdown drift between surfaces.
# SHOWY_QUOTA_SKETCHYBAR_UPDATE_FREQ=10

# Provider-count threshold surfaced by showy-quota-state for external SketchyBar
# layout managers. The SketchyBar plugin itself does not compact or move
# unrelated items.
# SHOWY_QUOTA_SKETCHYBAR_COMPACT_PROVIDER_COUNT=5
# SketchyBar bracket pill styling. Existing sketchybarrc PILL_RADIUS and
# PILL_HEIGHT envs are forwarded here unless you set these explicitly.
# SHOWY_QUOTA_SKETCHYBAR_PILL_RADIUS=14
# SHOWY_QUOTA_SKETCHYBAR_PILL_HEIGHT=28
# SHOWY_QUOTA_SKETCHYBAR_PILL_COLOR=0xcc24273a

# Corner radius of the native usage-row tracks. Default 3 matches the
# 6-pixel row height for fully rounded ends; set to 0 for a squared
# track.
# SHOWY_QUOTA_SKETCHYBAR_ROW_RADIUS=3

# Stacked-bar PNG geometry (pixels).
# SHOWY_QUOTA_PNG_BAR_W=80
# SHOWY_QUOTA_PNG_BAR_H=18

# SketchyBar item widths. Bar width should normally be PNG width + padding.
# SHOWY_QUOTA_SKETCHYBAR_ICON_WIDTH=22
# SHOWY_QUOTA_SKETCHYBAR_BAR_WIDTH=84
# SHOWY_QUOTA_SKETCHYBAR_ICON_SCALE=0.28
# SHOWY_QUOTA_SKETCHYBAR_ICON_PADDING_LEFT=5

# ── zellij plugin ───────────────────────────────────────────────────────

# The recommended standalone Zellij plugin is configured in KDL, not by this
# shell file. It is intentionally self-contained: it owns serve probing,
# managed serve startup, provider discovery, and per-provider CLI fallback.
# Equivalent KDL keys include:
#   serve_url "http://127.0.0.1:8080"
#   interval_seconds 10
#   cli_fallback "degraded"   # set to "off" to disable CLI fallback entirely
#   cli_command "codexbar"     # binary used for discovery + per-provider fallback
#   cli_interval_seconds 120
#   provider_failure_backoff_seconds 120
#   provider_discovery_backoff_seconds 60
#   providers "codex,claude"   # allow-list (also constrains fallback)
#   providers_exclude "antigravity"
#   provider_order "codex,claude,copilot,opencode,gemini"
#   bar_width 12
#   terminal_bar_mode "auto"
# See docs/plugin.md for the full plugin table.

#
# The variables below apply to shell terminal renderers:
# - showy-quota-tmux-bar
# - showy-quota-zellij-bar
# - showy-quota-zellij-pipe (advanced zjstatus composition path)
#
#
# Advanced zjstatus-only knobs. Ignore these for the standalone plugin.
# SHOWY_QUOTA_ZELLIJ_WIDGET=pipe_showy_quota
# SHOWY_QUOTA_ZELLIJ_PIPE_NAME=showy-quota
# SHOWY_QUOTA_ZELLIJ_PLUGIN=
# SHOWY_QUOTA_ZELLIJ_PIPE_INTERVAL=10
# SHOWY_QUOTA_ZELLIJ_PIPE_TIMEOUT_TENTHS=20

# Width in terminal cells for each Zellij/tmux provider strip.
# SHOWY_QUOTA_ZELLIJ_BAR_WIDTH=12

# Terminal renderer mode. `auto` (default) renders each provider per
# SHOWY_QUOTA_PROVIDER_MODES; unmapped providers render `dual`. Force one body
# mode for every provider with `dual`, `dual2`, `mono3`, `sextant3`, or `mono4`
# (`mono4` needs an octant-capable terminal: Ghostty/kitty/WezTerm).
# SHOWY_QUOTA_TERMINAL_BAR_MODE=auto

# Per-provider body map for `auto` mode (`provider=mode,…`). Default maps Gemini
# and Cursor to `mono3`; every other provider renders `dual`.
# SHOWY_QUOTA_PROVIDER_MODES=gemini=mono3,cursor=mono3

# mono3/mono4 color policy. `lowest` (default) colors by the lowest remaining
# present window using the primary palette; `primary` keys off the primary row.
# SHOWY_QUOTA_MONO_COLOR_MODE=lowest

# Paced window slots drawn as pacing separators (comma list: primary, secondary,
# tertiary, quaternary; `none` disables). The first marker uses PALETTE_ELAPSED,
# the rest PALETTE_ELAPSED_LONG. Stale snapshots hide the markers.
# SHOWY_QUOTA_MONO_MARKERS=primary

# End-cap glyphs wrapping each Zellij provider chunk. Defaults are
# Powerline-Extra rounded (U+E0B6 / U+E0B4) and require a Nerd Font
# (or any font with the Powerline Extra range). Common alternatives:
#   slant:  '' / ''
#   flame:  '' / ''
# Set either to '' for a flat edge.
# SHOWY_QUOTA_CAP_LEFT=
# SHOWY_QUOTA_CAP_RIGHT=

# Path to the zellij binary for the advanced long-running pipe loop. Use an
# absolute path when Zellij sessions do not inherit your interactive PATH.
# SHOWY_QUOTA_ZELLIJ_BIN=/opt/homebrew/bin/zellij

# ── debug ──────────────────────────────────────────────────────────────

# Set to 1 to emit `[showy-quota] …` diagnostics on stderr. Anything other than
# `1` is treated as off.
# SHOWY_QUOTA_DEBUG=0

# Force ANSI color in the zellij renderer even when stdout is not a TTY.
# Anything other than `1` is treated as off.
# SHOWY_QUOTA_FORCE_COLOR=0
