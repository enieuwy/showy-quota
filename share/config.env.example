# showy-bar — optional config
#
# Copy to ~/.config/showy-bar/config.env (or set the variables in your
# shell startup) to override defaults. Every value is optional.
#
# All scripts source this file when SHOWY_BAR_NO_CONFIG is unset.

# ── data plane ─────────────────────────────────────────────────────────

# Refresh interval for the shared codexbar JSON cache. Bars themselves can
# poll the cache more frequently; this is the upper bound on how often
# `codexbar` itself runs.
# SHOWY_BAR_REFRESH_SECONDS=120

# How long lock losers wait for an in-flight refresh, in tenths of seconds.
# Default 100 = 10 seconds.
# SHOWY_BAR_LOCK_WAIT_TENTHS=100

# Cache directory. Falls back to $XDG_CACHE_HOME/showy-bar or
# ~/.cache/showy-bar.
# SHOWY_BAR_CACHE_DIR=

# Path to the codexbar binary. Falls back to `codexbar` on PATH.
# SHOWY_BAR_CODEXBAR_BIN=/opt/homebrew/bin/codexbar

# Path to the showy-bar-fetch script. Falls back to this repo's bin/ copy
# for source-tree usage, or to the installed script next to a renderer.
# SHOWY_BAR_FETCH_BIN=

# Comma-separated provider id allow-list for rendering. Empty = render the
# enabled provider set returned by `codexbar usage`.
# SHOWY_BAR_PROVIDERS=codex,claude,gemini
# Comma-separated provider id exclude-list. Applied after SHOWY_BAR_PROVIDERS,
# so exclude wins on overlap.
# SHOWY_BAR_PROVIDERS_EXCLUDE=codex
# Comma-separated provider id order. This ranks providers without filtering:
# missing providers are skipped, and unlisted providers render after this list.
# SHOWY_BAR_PROVIDERS, when set, is both an allow-list and the render order.
# SHOWY_BAR_PROVIDER_ORDER=codex,claude,opencode,gemini

# Pass --status to codexbar so provider outage indicators are included.
# Set to 0 to skip status-page polling in the CLI path.
# SHOWY_BAR_INCLUDE_STATUS=1

# ── presentation ───────────────────────────────────────────────────────

# Optional theme name. Looks in ~/.config/showy-bar/themes/<name>.env
# first, then the repo/install tree's share/themes/<name>.env.
# `showy-bar` is the supported way to browse and persist this setting.
# Built-ins include default, carbonfox, catppuccin-mocha,
# catppuccin-mocha-blue, dracula, gruvbox-dark, nord, and tokyonight.
# SHOWY_BAR_THEME=default

# Role-aware 6-char hex palette. Primary is canonical; secondary/tertiary
# auto-derive from primary via the scale knobs when unset. Defaults preserve
# the original ai-quota look for the stacked rows.
# Minimal custom palette:
# SHOWY_BAR_PALETTE_PRIMARY_GOOD=25be6a
# SHOWY_BAR_PALETTE_PRIMARY_WARN=f0af00
# SHOWY_BAR_PALETTE_PRIMARY_BAD=ee5396
# SHOWY_BAR_PALETTE_PRIMARY_UNKNOWN=6c7086
# Auto-derive secondary/tertiary from primary:
# SHOWY_BAR_PALETTE_SECONDARY_SCALE=0.55
# SHOWY_BAR_PALETTE_TERTIARY_SCALE=0.55
# Optional explicit role overrides:
# SHOWY_BAR_PALETTE_SECONDARY_GOOD=14683a
# SHOWY_BAR_PALETTE_SECONDARY_WARN=846000
# SHOWY_BAR_PALETTE_SECONDARY_BAD=822d52
# SHOWY_BAR_PALETTE_SECONDARY_UNKNOWN=3b3d49
# SHOWY_BAR_PALETTE_TERTIARY_GOOD=14683a
# SHOWY_BAR_PALETTE_TERTIARY_WARN=846000
# SHOWY_BAR_PALETTE_TERTIARY_BAD=822d52
# SHOWY_BAR_PALETTE_TERTIARY_UNKNOWN=3b3d49
# Global colors shared by every renderer.
# ICON_TEXT is high-contrast text inside fallback provider icons.
# COUNTDOWN is the normal countdown label color.
# COUNTDOWN_WARN is used when reset time is inside SHOWY_BAR_TIME_WARN_MINUTES.
# SHOWY_BAR_PALETTE_BG=161616
# SHOWY_BAR_PALETTE_SURFACE=2a2a2a
# SHOWY_BAR_PALETTE_TRACK=3a3a4a
# SHOWY_BAR_PALETTE_ICON_TEXT=f2f4f8
# SHOWY_BAR_PALETTE_COUNTDOWN=7b8496
# SHOWY_BAR_PALETTE_COUNTDOWN_WARN=ee5396
# SHOWY_BAR_PALETTE_ELAPSED=be95ff

# Threshold (in % remaining) below which a window switches color band.
# SHOWY_BAR_GOOD_MIN_REMAINING=40
# SHOWY_BAR_WARN_MIN_REMAINING=15

# Time-label minute threshold for warn coloring.
# SHOWY_BAR_TIME_WARN_MINUTES=30

# ── sketchybar ─────────────────────────────────────────────────────────

# Cache dir for generated PNG bars and provider icons.
# SHOWY_BAR_SKETCHYBAR_IMAGE_CACHE=~/.cache/showy-bar/sketchybar

# Where to find CodexBar's provider SVGs. The default tracks the macOS app
# bundle; override for non-default install paths.
# SHOWY_BAR_CODEXBAR_RESOURCES=/Applications/CodexBar.app/Contents/Resources

# Default click target for sketchybar items. Degraded provider icons open the
# provider's HTTP(S) status URL when CodexBar reports one; other clicks use
# this command. Note: bundle id is lowercase 'codexbar'.
# SHOWY_BAR_SKETCHYBAR_CLICK="open -b com.steipete.codexbar"

# Update frequency for the sketchybar trigger item.
# SHOWY_BAR_SKETCHYBAR_UPDATE_FREQ=120

# Provider-count threshold surfaced by showy-bar-state for external SketchyBar
# layout managers. The SketchyBar plugin itself does not compact or move
# unrelated items.
# SHOWY_BAR_SKETCHYBAR_COMPACT_PROVIDER_COUNT=5
# SketchyBar bracket pill styling. Existing sketchybarrc PILL_RADIUS and
# PILL_HEIGHT envs are forwarded here unless you set these explicitly.
# SHOWY_BAR_SKETCHYBAR_PILL_RADIUS=14
# SHOWY_BAR_SKETCHYBAR_PILL_HEIGHT=28
# SHOWY_BAR_SKETCHYBAR_PILL_COLOR=0xcc24273a

# Stacked-bar PNG geometry (pixels).
# SHOWY_BAR_PNG_BAR_W=80
# SHOWY_BAR_PNG_BAR_H=18

# SketchyBar item widths. Bar width should normally be PNG width + padding.
# SHOWY_BAR_SKETCHYBAR_ICON_WIDTH=22
# SHOWY_BAR_SKETCHYBAR_BAR_WIDTH=84
# SHOWY_BAR_SKETCHYBAR_ICON_SCALE=0.28
# SHOWY_BAR_SKETCHYBAR_ICON_PADDING_LEFT=5

# ── zellij / tmux ──────────────────────────────────────────────────────

# zjstatus widget name (must match `pipe_<name>_format` in your layout).
# SHOWY_BAR_ZELLIJ_WIDGET=pipe_showy_bar

# zellij pipe routing name.
# SHOWY_BAR_ZELLIJ_PIPE_NAME=showy-bar

# Optional explicit plugin URL. Leave empty for normal broadcast mode; setting
# this without matching plugin configuration can launch another plugin instance.
# SHOWY_BAR_ZELLIJ_PLUGIN=

# How often the long-running pipe re-emits the strip, and how long one
# `zellij pipe` helper may run before the feeder abandons it (tenths of seconds).
# SHOWY_BAR_ZELLIJ_PIPE_INTERVAL=10
# SHOWY_BAR_ZELLIJ_PIPE_TIMEOUT_TENTHS=20

# Width in half-block cells for each Zellij 5h/7d provider strip.
# SHOWY_BAR_ZELLIJ_BAR_WIDTH=12

# Path to the zellij binary for the long-running pipe loop. Use an
# absolute path when Zellij sessions do not inherit your interactive PATH.
# SHOWY_BAR_ZELLIJ_BIN=/opt/homebrew/bin/zellij

# ── debug ──────────────────────────────────────────────────────────────

# Set to 1 to emit `[showy-bar] …` diagnostics on stderr.
# SHOWY_BAR_DEBUG=0

# Force ANSI color in the zellij renderer even when stdout is not a TTY.
# SHOWY_BAR_FORCE_COLOR=0
