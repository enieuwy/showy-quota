# codexbar-bars — tmux popup keybinding for an on-demand detail panel.
#
# Add to ~/.tmux.conf. Adjust the prefix-relative key to taste. The popup
# runs `codexbar usage` on a 30 s loop and closes when dismissed.

bind-key '/' display-popup -E -h 36 -w 92 -T "CodexBar usage" 'watch -n 30 codexbar usage'
